---
import SeoHead from '../components/SeoHead.astro';
import '../styles/theme.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = '読書 with Coco - 書評とギャラリーを中心に、読後の余韻を静かにひらく読書サイト',
  image,
  type = 'website',
  jsonLd,
} = Astro.props;
const base = import.meta.env.BASE_URL;
const canonical = new URL(Astro.url.pathname, Astro.site!).toString();
const currentPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;

const navItems = [
  { href: '', label: 'Home' },
  { href: 'about/', label: 'About' },
  { href: 'gallery/', label: 'Gallery' },
  { href: 'reviews/', label: 'Reviews' },
  { href: 'profile/', label: 'Profile' },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <SeoHead title={title} description={description} image={image} type={type} jsonLd={jsonLd} />
    <style>
      .container {
        max-width: var(--container-max);
        margin: 0 auto;
        padding: 0 clamp(16px, 2vw, 28px);
      }

      header {
        position: sticky;
        top: 0;
        z-index: 40;
        padding-top: 12px;
        background: linear-gradient(to bottom, rgba(246, 242, 235, 0.88), rgba(246, 242, 235, 0));
        backdrop-filter: saturate(180%) blur(18px);
      }

      .nav-shell {
        min-width: 0;
        border: 1px solid var(--color-border);
        border-radius: 999px;
        background: color-mix(in srgb, var(--color-nav) 92%, transparent);
        box-shadow: 0 10px 30px rgba(30, 24, 18, 0.05);
      }

      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        min-height: 46px;
        gap: 14px;
        padding: 0 10px 0 16px;
        min-width: 0;
      }

      .brand {
        font-family: var(--font-display);
        font-size: 1rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        max-width: 100%;
        min-width: 0;
        white-space: nowrap;
        color: var(--color-text);
      }

      .links {
        display: flex;
        gap: 4px;
        font-size: 0.88rem;
        min-width: 0;
        align-items: center;
      }

      .link {
        padding: 8px 12px;
        border-radius: 999px;
        max-width: 100%;
        min-width: 0;
        white-space: normal;
        overflow-wrap: anywhere;
        box-sizing: border-box;
        text-align: center;
        color: var(--color-muted);
        transition:
          background-color 0.2s ease,
          color 0.2s ease,
          box-shadow 0.2s ease;
      }

      .link[aria-current='page'] {
        color: var(--color-text);
        background: var(--color-nav-strong);
        box-shadow: inset 0 0 0 1px rgba(75, 58, 38, 0.08);
      }

      .link:hover {
        background: rgba(255, 255, 255, 0.7);
        color: var(--color-text);
      }

      main {
        padding: 18px 0 44px;
      }

      footer {
        padding: 28px 0 40px;
        opacity: 0.72;
        font-size: 0.88rem;
        color: var(--color-muted);
      }

      @media (max-width: 640px) {
        header {
          padding-top: 8px;
        }

        .nav-shell {
          border-radius: 24px;
        }

        .nav {
          flex-wrap: wrap;
          height: auto;
          padding: 10px;
          gap: 8px;
        }

        .brand {
          width: 100%;
          text-align: center;
          font-size: 0.98rem;
          min-height: 36px;
          display: flex;
          align-items: center;
          justify-content: center;
        }

        .links {
          width: 100%;
          justify-content: center;
          flex-wrap: wrap;
          gap: 6px 4px;
          font-size: 0.82rem;
        }

        .link {
          min-height: 48px;
          display: flex;
          align-items: center;
          padding: 8px 10px;
          box-sizing: border-box;
        }
      }
    </style>
    <style is:global>
      :where(.ui-action) {
        max-width: 100%;
        min-width: 0;
        white-space: normal;
        overflow-wrap: anywhere;
        box-sizing: border-box;
      }

      :where(.ui-action-group) {
        min-width: 0;
        flex-wrap: wrap;
      }

      :where(.ui-action-group > *) {
        min-width: 0;
      }

      @media (max-width: 640px) {
        :where(.ui-action-group--stack) {
          flex-direction: column;
        }

        :where(.ui-action-group--stack > .ui-action) {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <div class="nav-shell">
          <div class="nav">
            <a class="brand" href={base}>読書 with Coco</a>
            <nav class="links" aria-label="Primary">
              {navItems.map((i) => {
                const href = `${base}${i.href}`;
                const normalizedHref = href.endsWith('/') ? href : `${href}/`;
                const isCurrent = normalizedHref === currentPath;

                return (
                  <a class="link" href={href} aria-current={isCurrent ? 'page' : undefined}>
                    {i.label}
                  </a>
                );
              })}
            </nav>
          </div>
        </div>
      </div>
    </header>

    <main>
      <div class="container">
        <slot />
      </div>
    </main>

    <footer>
      <div class="container">© {new Date().getFullYear()} 読書 with Coco</div>
    </footer>
  </body>
</html>
