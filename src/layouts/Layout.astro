---
import SeoHead from '../components/SeoHead.astro';
import '../styles/theme.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = '読書 with Coco - 書評、ギャラリー、動画を通じて本の魅力をお届けする読書サイト',
  image,
  type = 'website',
  jsonLd,
} = Astro.props;
const base = import.meta.env.BASE_URL;
const canonical = new URL(Astro.url.pathname, Astro.site!).toString();

const navItems = [
  { href: '', label: 'Home' },
  { href: 'about/', label: 'About' },
  { href: 'gallery/', label: 'Gallery' },
  { href: 'videos/', label: 'Videos' },
  { href: 'reviews/', label: 'Reviews' },
  { href: 'profile/', label: 'Profile' },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <SeoHead title={title} description={description} image={image} type={type} jsonLd={jsonLd} />
    <style>
      .container { max-width: 980px; margin: 0 auto; padding: 0 16px; }
      header {
        position: sticky;
        top: 0;
        z-index: 20;
        background: color-mix(in srgb, var(--color-surface) 84%, transparent);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--color-border);
      }
      .nav { display: flex; align-items: center; justify-content: space-between; height: 58px; min-width: 0; }
      .brand {
        font-family: var(--font-display);
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: .03em;
        max-width: 100%;
        min-width: 0;
      }
      .links { display: flex; gap: 14px; font-size: .95rem; min-width: 0; }
      .link {
        padding: 8px 10px;
        border-radius: 10px;
        max-width: 100%;
        min-width: 0;
        white-space: normal;
        overflow-wrap: anywhere;
        box-sizing: border-box;
        text-align: center;
        color: var(--color-muted);
        transition: background-color 0.2s ease, color 0.2s ease;
      }
      .link:hover { background: rgba(255,255,255,.55); color: var(--color-text); }
      main { padding: 28px 0 40px; }
      footer { padding: 28px 0 40px; opacity: .7; font-size: .9rem; }

      @media (max-width: 640px) {
        .nav {
          flex-wrap: wrap;
          height: auto;
          padding: 6px 0;
          gap: 6px;
        }

        .brand {
          width: 100%;
          text-align: center;
          font-size: 1rem;
          min-height: 44px;
          display: flex;
          align-items: center;
          justify-content: center;
        }

        .links {
          width: 100%;
          justify-content: center;
          flex-wrap: wrap;
          gap: 4px;
          font-size: 0.85rem;
        }

        .link {
          min-height: 44px;
          display: flex;
          align-items: center;
          padding: 8px 10px;
          box-sizing: border-box;
        }
      }
    </style>
    <style is:global>
      :where(.ui-action) {
        max-width: 100%;
        min-width: 0;
        white-space: normal;
        overflow-wrap: anywhere;
        box-sizing: border-box;
      }

      :where(.ui-action-group) {
        min-width: 0;
        flex-wrap: wrap;
      }

      :where(.ui-action-group > *) {
        min-width: 0;
      }

      @media (max-width: 640px) {
        :where(.ui-action-group--stack) {
          flex-direction: column;
        }

        :where(.ui-action-group--stack > .ui-action) {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <div class="nav">
          <a class="brand" href={base}>読書 with Coco</a>
          <nav class="links" aria-label="Primary">
            {navItems.map((i) => (
              <a class="link" href={`${base}${i.href}`}>{i.label}</a>
            ))}
          </nav>
        </div>
      </div>
    </header>

    <main>
      <div class="container">
        <slot />
      </div>
    </main>

    <footer>
      <div class="container">© {new Date().getFullYear()} 読書 with Coco</div>
    </footer>
  </body>
</html>
