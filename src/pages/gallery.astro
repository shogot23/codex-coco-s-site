---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { GALLERY_GENRES } from "../content/config";

const BASE_URL = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const isAbsoluteUrl = (value: string) =>
  /^(?:[a-z][a-z\d+.-]*:|\/\/)/i.test(value);

const withBase = (assetPath: string) => {
  if (!assetPath) return BASE_URL;
  if (isAbsoluteUrl(assetPath)) return assetPath;
  if (assetPath.startsWith(BASE_URL)) return assetPath;
  return `${BASE_URL}${assetPath.replace(/^\/+/, "")}`;
};

const galleryEntries = await getCollection("gallery");

// Group items by genre
const galleryByGenre = GALLERY_GENRES.map((genre) => ({
  name: genre,
  items: galleryEntries
    .filter((entry) => entry.data.genre === genre)
    .map((entry) => ({
      title: entry.data.title,
      image: withBase(entry.data.image),
      genre: entry.data.genre,
      author: entry.data.author,
      note: entry.data.note,
    })),
})).filter((g) => g.items.length > 0);
---

<Layout title="Gallery | 読書 with Coco">
  <main class="wrap">
    <h1>Gallery</h1>
    <p class="lead">本とココちゃんの写真をジャンル別に並べるページ（いまは仮データ）。</p>

    {galleryByGenre.map((g) => (
      <section class="section">
        <h2>{g.name}</h2>
        <div class="grid">
          {g.items.map((item) => (
            <article class="card">
              <div class="thumb">
                <img src={item.image} alt={item.title} loading="lazy" decoding="async" width="400" height="300" />
              </div>
              <div class="body">
                <div class="title">{item.title}</div>
                {item.author && <div class="meta">著者: {item.author}</div>}
                {item.note && <div class="meta">{item.note}</div>}
              </div>
            </article>
          ))}
        </div>
      </section>
    ))}
  </main>
</Layout>

<style>
  .wrap{max-width:980px;margin:0 auto;padding:32px 16px;}
  .lead{opacity:.8;margin:8px 0 24px;}
  .section{margin:28px 0 38px;}
  .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;}
  .card{border:1px solid rgba(0,0,0,.08);border-radius:14px;overflow:hidden;background:#fff;}
  .thumb{aspect-ratio: 4 / 3; background: rgba(0,0,0,.04); display:flex;align-items:center;justify-content:center;}
  img{width:100%;height:100%;object-fit:cover;}
  .body{padding:12px 14px;}
  .title{font-weight:700;}
  .meta{margin-top:6px;opacity:.7;font-size:.9rem;}
</style>
