---
import { getEntry, type CollectionEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import GalleryBrowse from '../components/gallery/GalleryBrowse.astro';
import {
  GALLERY_HORIZON_GENRES,
  GALLERY_LEARNING_GENRES,
} from '../lib/gallery-taxonomy';
import {
  buildGalleryBrowseModel,
  getGallerySceneSummary,
  getPublishedGallery,
  hasDetailContent,
  sortGalleryEntries,
  type GalleryBrowseChapter,
} from '../utils/gallery';

type GalleryEntry = CollectionEntry<'gallery'>;

const baseWithSlash = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const isAbsoluteUrl = (value: string) =>
  /^(?:[a-z][a-z\d+.-]*:|\/\/)/i.test(value);

const withBase = (assetPath: string) => {
  if (!assetPath) return baseWithSlash;
  if (isAbsoluteUrl(assetPath)) return assetPath;
  if (assetPath.startsWith(baseWithSlash)) return assetPath;
  return `${baseWithSlash}${assetPath.replace(/^\/+/, '')}`;
};

const getSceneHref = (entry: GalleryEntry) =>
  hasDetailContent(entry) ? `${baseWithSlash}gallery/${entry.slug}/` : null;

const getChapterSectionId = (chapter: GalleryBrowseChapter) => `chapter-${chapter.id}`;

const galleryEntries = sortGalleryEntries(await getPublishedGallery());
const browseModel = buildGalleryBrowseModel(galleryEntries, baseWithSlash);
const browseChapters = browseModel.chapters;
const detailedEntries = galleryEntries.filter((entry) => hasDetailContent(entry));
const linkedReviewCount = (await Promise.all(
  galleryEntries.map(async (entry) => {
    if (!entry.data.relatedReview) return false;
    const linked = await getEntry(entry.data.relatedReview);
    return linked?.data.published === true;
  })
)).filter(Boolean).length;

const reviewsUrl = `${baseWithSlash}reviews/`;
const aboutUrl = `${baseWithSlash}about/`;
const archiveUrl = `${baseWithSlash}gallery/archive/`;

const entriesWithPublishedReview = await Promise.all(
  detailedEntries.map(async (entry) => {
    if (!entry.data.relatedReview) return null;
    const linked = await getEntry(entry.data.relatedReview);
    return linked?.data.published === true ? entry : null;
  })
);
const heroLeadEntry =
  entriesWithPublishedReview.find(Boolean) ?? detailedEntries[0] ?? galleryEntries[0] ?? null;
const heroSupportEntries = galleryEntries
  .filter((entry) => entry.slug !== heroLeadEntry?.slug)
  .slice(0, 3);

const usedFeaturedSlugs = new Set<string>();

const hasGenreIn = (entry: GalleryEntry, genres: readonly string[]) => {
  const genre = entry.data.genre;
  return Boolean(genre && genres.includes(genre));
};

const pickScene = (genres: readonly string[]) =>
  galleryEntries.find((entry) => {
    if (usedFeaturedSlugs.has(entry.slug)) return false;
    return hasGenreIn(entry, genres);
  }) ?? null;

const featuredMoments: Array<{
  eyebrow: string;
  title: string;
  copy: string;
  entry: GalleryEntry;
}> = [];

const addFeaturedMoment = (
  eyebrow: string,
  title: string,
  copy: string,
  entry: GalleryEntry | null
) => {
  if (!entry || usedFeaturedSlugs.has(entry.slug)) return;
  usedFeaturedSlugs.add(entry.slug);
  featuredMoments.push({ eyebrow, title, copy, entry });
};

addFeaturedMoment(
  'From Review',
  '言葉から景色へ渡る一枚',
  '主導線のレビューから離れすぎないように、最初の一枚は読後の余韻とつながっている作品を置いています。',
  heroLeadEntry
);

addFeaturedMoment(
  'Learning Glow',
  '学びを景色に変える棚',
  '考え方や習慣の本が残す輪郭は、整った結論よりも、日々の見え方の変化として受け取りたいものです。',
  pickScene(GALLERY_LEARNING_GENRES)
);

addFeaturedMoment(
  'Far Horizon',
  '少し遠くへ連れていく景色',
  '歴史や漫画やホビーの本は、今いる場所から少し離れた地平を見せてくれます。その広がりを副導線として残します。',
  pickScene(GALLERY_HORIZON_GENRES)
);

const chapterLinks = browseChapters.map((chapter) => ({
  href: `#${getChapterSectionId(chapter)}`,
  label: chapter.title,
  count: chapter.items.length,
}));
---

<Layout
  title="Gallery | 読書 with Coco"
  description="レビューの余韻から続く景色を、ココちゃんと静かに見返す Gallery ページ。"
>
  {galleryEntries.length ? (
    <div class="gallery-world">
      <section class="gallery-hero" aria-labelledby="gallery-page-title">
        <div class="hero-copy">
          <p class="section-label">Gallery / Scenic Side Path</p>
          <p class="hero-brand">読書 with Coco</p>
          <h1 id="gallery-page-title">読後の景色を、ココちゃんと静かに見返す。</h1>
          <p class="hero-lead">
            レビューで受け取った余韻を、ここでは色や構図のほうから確かめます。主役はあくまで本。
            そのそばでココちゃんが、読書から広がる景色を静かに案内します。
          </p>

          {heroLeadEntry && (
            <p class="hero-note">
              いま先頭に置いている景色は <span>{heroLeadEntry.data.title}</span>。
              Reviews 主導の流れを壊さないように、最初の一枚は言葉の余韻に近い場所から始めています。
            </p>
          )}

          <div class="hero-actions ui-action-group ui-action-group--stack">
            <a class="hero-link hero-link-primary ui-action" href="#scene-featured">景色をめくる</a>
            <a class="hero-link hero-link-secondary ui-action" href={reviewsUrl}>レビューの主導線へ戻る</a>
          </div>
        </div>

        <div class="hero-visual">
          {heroLeadEntry && (
            (() => {
              const href = getSceneHref(heroLeadEntry);
              const summary = getGallerySceneSummary(heroLeadEntry);

              return href ? (
                <a class="hero-scene hero-scene-lead" href={href} aria-label={`${heroLeadEntry.data.title}の景色を見る`}>
                  <div class="hero-scene-media">
                    <img
                      src={withBase(heroLeadEntry.data.image)}
                      alt={`${heroLeadEntry.data.title}の展示画像`}
                      loading="eager"
                      decoding="async"
                      width="960"
                      height="1080"
                    />
                  </div>
                  <div class="hero-scene-body">
                    <p class="hero-scene-kicker">Lead Scene</p>
                    <h2>{heroLeadEntry.data.title}</h2>
                    {heroLeadEntry.data.author && <p class="scene-author">著者: {heroLeadEntry.data.author}</p>}
                    <p class="scene-summary">{summary}</p>
                    <span class="scene-action">景色の余韻を見る</span>
                  </div>
                </a>
              ) : (
                <article class="hero-scene hero-scene-lead">
                  <div class="hero-scene-media">
                    <img
                      src={withBase(heroLeadEntry.data.image)}
                      alt={`${heroLeadEntry.data.title}の展示画像`}
                      loading="eager"
                      decoding="async"
                      width="960"
                      height="1080"
                    />
                  </div>
                  <div class="hero-scene-body">
                    <p class="hero-scene-kicker">Lead Scene</p>
                    <h2>{heroLeadEntry.data.title}</h2>
                    {heroLeadEntry.data.author && <p class="scene-author">著者: {heroLeadEntry.data.author}</p>}
                    <p class="scene-summary">{summary}</p>
                    <span class="scene-status">展示中</span>
                  </div>
                </article>
              );
            })()
          )}

          <div class="hero-echoes" aria-label="景色の断片">
            {heroSupportEntries.map((entry) => {
              const href = getSceneHref(entry);
              const summary = getGallerySceneSummary(entry);

              return href ? (
                <a class="hero-echo" href={href} aria-label={`${entry.data.title}の景色を見る`}>
                  <div class="hero-echo-media">
                    <img
                      src={withBase(entry.data.image)}
                      alt={`${entry.data.title}の展示画像`}
                      loading="lazy"
                      decoding="async"
                      width="480"
                      height="540"
                    />
                  </div>
                  <div class="hero-echo-body">
                    <p class="hero-echo-title">{entry.data.title}</p>
                    <p>{summary}</p>
                  </div>
                </a>
              ) : (
                <article class="hero-echo">
                  <div class="hero-echo-media">
                    <img
                      src={withBase(entry.data.image)}
                      alt={`${entry.data.title}の展示画像`}
                      loading="lazy"
                      decoding="async"
                      width="480"
                      height="540"
                    />
                  </div>
                  <div class="hero-echo-body">
                    <p class="hero-echo-title">{entry.data.title}</p>
                    <p>{summary}</p>
                  </div>
                </article>
              );
            })}
          </div>

          <aside class="hero-panel" aria-label="Gallery のしおり">
            <p class="panel-label">Scenic Notes</p>

            <dl class="panel-stats">
              <div>
                <dt>公開中の景色</dt>
                <dd>{galleryEntries.length}</dd>
              </div>
              <div>
                <dt>Review につながる入口</dt>
                <dd>{linkedReviewCount}</dd>
              </div>
            </dl>

            {chapterLinks.length > 0 && (
              <div class="panel-block">
                <p>このページの歩き方</p>
                <ul class="chapter-links">
                  {chapterLinks.map((chapter) => (
                    <li>
                      <a href={chapter.href}>
                        <span>{chapter.label}</span>
                        <strong>{chapter.count}</strong>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </aside>
        </div>
      </section>

      {featuredMoments.length > 0 && (
        <section class="featured-room" id="scene-featured" aria-labelledby="featured-scenes-title">
          <div class="room-intro">
            <p class="section-label">Featured Scenes</p>
            <h2 id="featured-scenes-title">本から生まれた景色を、先に3つだけひらく。</h2>
            <p>
              一覧を急いで見せるより、まずはこのサイトらしい空気が伝わる景色から始めます。
              ここで受け取った気配が、その後の棚めぐりの導入になります。
            </p>
          </div>

          <div class="featured-grid">
            {featuredMoments.map((moment) => {
              const href = getSceneHref(moment.entry);
              const summary = getGallerySceneSummary(moment.entry);

              return href ? (
                <a class="feature-card" href={href} aria-label={`${moment.entry.data.title}の景色を見る`}>
                  <div class="feature-media">
                    <img
                      src={withBase(moment.entry.data.image)}
                      alt={`${moment.entry.data.title}の展示画像`}
                      loading="lazy"
                      decoding="async"
                      width="720"
                      height="860"
                    />
                  </div>
                  <div class="feature-body">
                    <p class="feature-kicker">{moment.eyebrow}</p>
                    <h3>{moment.title}</h3>
                    <p class="feature-entry-title">{moment.entry.data.title}</p>
                    <p>{moment.copy}</p>
                    <p class="feature-summary">{summary}</p>
                    <span class="scene-action">景色を見る</span>
                  </div>
                </a>
              ) : (
                <article class="feature-card">
                  <div class="feature-media">
                    <img
                      src={withBase(moment.entry.data.image)}
                      alt={`${moment.entry.data.title}の展示画像`}
                      loading="lazy"
                      decoding="async"
                      width="720"
                      height="860"
                    />
                  </div>
                  <div class="feature-body">
                    <p class="feature-kicker">{moment.eyebrow}</p>
                    <h3>{moment.title}</h3>
                    <p class="feature-entry-title">{moment.entry.data.title}</p>
                    <p>{moment.copy}</p>
                    <p class="feature-summary">{summary}</p>
                    <span class="scene-status">展示中</span>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      )}

      <section class="browse-room" aria-labelledby="browse-room-title">
        <div class="browse-intro">
          <div class="browse-copy">
            <p class="section-label">Browse The Shelf</p>
            <h2 id="browse-room-title">展示の余韻は残したまま、ここからは探しやすく。</h2>
            <p>
              ここでは展示の空気を残した補助棚だけを置きます。気になる一枚を静かに拾う役目はこのままにして、
              全体を探したいときは archive の目録へ自然に渡せるようにします。
            </p>
          </div>

          <div class="browse-side">
            <p class="browse-note">
              ここは展示の補助棚です。件数が増えても比べやすい一覧は
              <span>/gallery/archive/</span> に切り出し、Gallery 本体は余韻をめくる入口として保ちます。
            </p>
            <dl class="browse-stats">
              <div>
                <dt>Browse items</dt>
                <dd>{browseModel.items.length}</dd>
              </div>
              <div>
                <dt>Curated chapters</dt>
                <dd>{browseChapters.length}</dd>
              </div>
            </dl>
            <div class="browse-actions ui-action-group ui-action-group--stack">
              <a class="hero-link hero-link-primary ui-action" href={archiveUrl}>archive で探す</a>
              <a class="hero-link hero-link-secondary ui-action" href="#scene-featured">展示へ戻る</a>
            </div>
          </div>
        </div>

        <GalleryBrowse
          browseModel={browseModel}
          testId="gallery-browse"
          noScriptMessage="JavaScript を使わない環境では、Gallery は Curated view のまま静かに眺められる構成にしています。"
          statusLabel="Curated view / すべての景色"
        />
      </section>

      <section class="bridge-room" aria-labelledby="bridge-room-title">
        <div class="bridge-copy">
          <p class="section-label">Back To The Main Path</p>
          <h2 id="bridge-room-title">主導線は Reviews に置いたまま、Gallery は余韻を深くする。</h2>
          <p>
            このページで見せたいのは、画像の数ではなく読書の空気です。迷ったときはレビューへ戻り、
            世界観の根っこをたどりたいときは About / world bridge へつなぎます。
          </p>
        </div>

        <div class="bridge-actions ui-action-group ui-action-group--stack">
          <a class="hero-link hero-link-primary ui-action" href={reviewsUrl}>レビューを見る</a>
          <a class="hero-link hero-link-secondary ui-action" href={aboutUrl}>About / world bridge へ</a>
        </div>
      </section>
    </div>
  ) : (
    <section class="gallery-empty">
      <h1>Gallery</h1>
      <p>公開中の作品はまだありません。</p>
    </section>
  )}
</Layout>

<style>
  .gallery-world {
    display: grid;
    gap: clamp(1.9rem, 4vw, 3.2rem);
  }

  .gallery-hero,
  .featured-room,
  .browse-room,
  .bridge-room {
    position: relative;
    overflow: clip;
    border: 1px solid rgba(100, 76, 42, 0.14);
    border-radius: clamp(26px, 4vw, 40px);
    box-shadow: 0 24px 70px rgba(83, 55, 28, 0.1);
  }

  .gallery-hero {
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(320px, 1.12fr);
    gap: clamp(1.5rem, 3vw, 3rem);
    padding: clamp(2rem, 4.5vw, 3.8rem);
    background:
      radial-gradient(circle at top left, rgba(235, 224, 209, 0.74), transparent 32%),
      radial-gradient(circle at bottom right, rgba(208, 219, 231, 0.24), transparent 34%),
      linear-gradient(145deg, rgba(252, 249, 244, 0.98), rgba(245, 246, 244, 0.95));
  }

  .section-label,
  .panel-label,
  .hero-scene-kicker,
  .feature-kicker {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(66, 52, 35, 0.62);
  }

  .hero-brand {
    margin: 0.85rem 0 0;
    font-size: clamp(1.3rem, 1.9vw, 1.6rem);
    color: color-mix(in srgb, var(--color-text) 92%, transparent);
  }

  .hero-copy h1,
  .room-intro h2,
  .browse-copy h2,
  .bridge-copy h2 {
    margin: 0;
    font-size: clamp(2.15rem, 4vw, 3.55rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .hero-copy,
  .room-intro,
  .browse-copy,
  .bridge-copy {
    display: grid;
    align-content: start;
    gap: 0.85rem;
  }

  .hero-lead,
  .hero-note,
  .room-intro p,
  .browse-copy p,
  .browse-note,
  .bridge-copy p,
  .hero-echo-body p {
    margin: 0;
    line-height: 1.8;
    color: rgba(32, 22, 15, 0.84);
  }

  .hero-lead,
  .hero-note {
    max-width: 31rem;
  }

  .hero-note span,
  .browse-note span {
    font-weight: 700;
    color: rgba(32, 22, 15, 0.98);
  }

  .hero-actions,
  .bridge-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 0.5rem;
  }

  .hero-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.9rem 1.3rem;
    border-radius: 999px;
    border: 1px solid rgba(82, 56, 28, 0.16);
    font-weight: 700;
    transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
  }

  .hero-link:hover,
  .feature-card:hover,
  .hero-scene:hover,
  .hero-echo:hover {
    transform: translateY(-3px);
  }

  .hero-link-primary {
    background: rgba(255, 252, 248, 0.94);
    box-shadow: 0 16px 32px rgba(83, 55, 28, 0.1);
  }

  .hero-link-secondary {
    background: rgba(255, 255, 255, 0.52);
  }

  .hero-visual {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .hero-scene,
  .feature-card {
    display: grid;
    gap: 1rem;
    color: inherit;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid var(--color-border);
    border-radius: clamp(20px, 3vw, 28px);
    box-shadow: 0 14px 32px rgba(83, 55, 28, 0.06);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .hero-scene {
    padding: 1rem;
  }

  .hero-scene-lead {
    grid-template-columns: minmax(0, 1.05fr) minmax(240px, 0.95fr);
    align-items: center;
  }

  .hero-scene-media,
  .feature-media,
  .hero-echo-media {
    overflow: hidden;
    border-radius: clamp(18px, 2vw, 24px);
    background: rgba(63, 42, 25, 0.08);
  }

  .hero-scene-media {
    aspect-ratio: 1 / 1.08;
  }

  .hero-scene-media img,
  .feature-media img,
  .hero-echo-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-scene-body,
  .feature-body,
  .hero-echo-body {
    display: grid;
    align-content: start;
    gap: 0.65rem;
  }

  .hero-scene-body h2,
  .feature-body h3 {
    margin: 0;
    font-size: clamp(1.3rem, 2.2vw, 1.85rem);
    line-height: 1.2;
  }

  .scene-author {
    margin: 0;
    color: rgba(66, 52, 35, 0.72);
    font-size: 0.94rem;
  }

  .scene-action,
  .scene-status {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.2rem;
    font-size: 0.92rem;
    font-weight: 700;
    color: #0a4a8b;
  }

  .scene-action::after {
    content: "→";
  }

  .scene-status {
    color: rgba(66, 52, 35, 0.72);
  }

  .hero-echoes {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .hero-echo {
    display: grid;
    gap: 0.7rem;
    align-content: start;
    color: inherit;
    padding: 0.8rem;
    border-radius: 22px;
    border: 1px solid rgba(100, 76, 42, 0.12);
    background: rgba(255, 255, 255, 0.68);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .hero-echo-media {
    aspect-ratio: 1 / 1.12;
  }

  .hero-echo-title,
  .feature-entry-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: rgba(32, 22, 15, 0.96);
  }

  .hero-panel {
    display: grid;
    gap: 1rem;
    padding: 1.1rem 1.2rem 1.2rem;
    border-radius: 24px;
    background: rgba(248, 242, 233, 0.9);
    border: 1px solid rgba(100, 76, 42, 0.12);
  }

  .panel-stats,
  .browse-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
    margin: 0;
  }

  .panel-stats div,
  .browse-stats div {
    padding: 0.9rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.74);
    border: 1px solid rgba(100, 76, 42, 0.08);
  }

  .panel-stats dt,
  .browse-stats dt {
    margin: 0;
    font-size: 0.8rem;
    color: rgba(66, 52, 35, 0.62);
  }

  .panel-stats dd,
  .browse-stats dd {
    margin: 0.35rem 0 0;
    font-family: var(--font-headline);
    font-size: clamp(1.35rem, 2vw, 1.85rem);
  }

  .panel-block {
    display: grid;
    gap: 0.75rem;
  }

  .panel-block p {
    margin: 0;
    font-weight: 700;
    color: rgba(32, 22, 15, 0.9);
  }

  .chapter-links {
    display: grid;
    gap: 0.55rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .chapter-links a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.8rem 0.95rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(100, 76, 42, 0.08);
  }

  .chapter-links strong {
    font-family: var(--font-headline);
    font-size: 1.1rem;
  }

  .featured-room,
  .browse-room,
  .bridge-room {
    padding: clamp(1.7rem, 4vw, 3rem);
  }

  .featured-room {
    background:
      radial-gradient(circle at top right, rgba(247, 214, 176, 0.26), transparent 28%),
      linear-gradient(180deg, rgba(255, 250, 243, 0.96), rgba(249, 244, 237, 0.94));
  }

  .featured-grid {
    display: grid;
