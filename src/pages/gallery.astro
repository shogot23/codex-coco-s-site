---
import { getEntry, type CollectionEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import {
  GALLERY_HORIZON_GENRES,
  GALLERY_LEARNING_GENRES,
} from '../lib/gallery-taxonomy';
import {
  buildGalleryBrowseModel,
  getGallerySceneSummary,
  getPublishedGallery,
  hasDetailContent,
  sortGalleryEntries,
  type GalleryBrowseChapter,
} from '../utils/gallery';

type GalleryEntry = CollectionEntry<'gallery'>;

const baseWithSlash = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const isAbsoluteUrl = (value: string) =>
  /^(?:[a-z][a-z\d+.-]*:|\/\/)/i.test(value);

const withBase = (assetPath: string) => {
  if (!assetPath) return baseWithSlash;
  if (isAbsoluteUrl(assetPath)) return assetPath;
  if (assetPath.startsWith(baseWithSlash)) return assetPath;
  return `${baseWithSlash}${assetPath.replace(/^\/+/, '')}`;
};

const getSceneHref = (entry: GalleryEntry) =>
  hasDetailContent(entry) ? `${baseWithSlash}gallery/${entry.slug}/` : null;

const getChapterSectionId = (chapter: GalleryBrowseChapter) => `chapter-${chapter.id}`;

const galleryEntries = sortGalleryEntries(await getPublishedGallery());
const browseModel = buildGalleryBrowseModel(galleryEntries, baseWithSlash);
const browseChapters = browseModel.chapters;
const detailedEntries = galleryEntries.filter((entry) => hasDetailContent(entry));
const linkedReviewCount = (await Promise.all(
  galleryEntries.map(async (entry) => {
    if (!entry.data.relatedReview) return false;
    const linked = await getEntry(entry.data.relatedReview);
    return linked?.data.published === true;
  })
)).filter(Boolean).length;

const reviewsUrl = `${baseWithSlash}reviews/`;
const aboutUrl = `${baseWithSlash}about/`;
const browseData = {
  chapters: browseChapters,
  genres: [...browseModel.genres],
  items: browseModel.items,
};

const entriesWithPublishedReview = await Promise.all(
  detailedEntries.map(async (entry) => {
    if (!entry.data.relatedReview) return null;
    const linked = await getEntry(entry.data.relatedReview);
    return linked?.data.published === true ? entry : null;
  })
);
const heroLeadEntry =
  entriesWithPublishedReview.find(Boolean) ?? detailedEntries[0] ?? galleryEntries[0] ?? null;
const heroSupportEntries = galleryEntries
  .filter((entry) => entry.slug !== heroLeadEntry?.slug)
  .slice(0, 3);

const usedFeaturedSlugs = new Set<string>();

const hasGenreIn = (entry: GalleryEntry, genres: readonly string[]) => {
  const genre = entry.data.genre;
  return Boolean(genre && genres.includes(genre));
};

const pickScene = (genres: readonly string[]) =>
  galleryEntries.find((entry) => {
    if (usedFeaturedSlugs.has(entry.slug)) return false;
    return hasGenreIn(entry, genres);
  }) ?? null;

const featuredMoments: Array<{
  eyebrow: string;
  title: string;
  copy: string;
  entry: GalleryEntry;
}> = [];

const addFeaturedMoment = (
  eyebrow: string,
  title: string,
  copy: string,
  entry: GalleryEntry | null
) => {
  if (!entry || usedFeaturedSlugs.has(entry.slug)) return;
  usedFeaturedSlugs.add(entry.slug);
  featuredMoments.push({ eyebrow, title, copy, entry });
};

addFeaturedMoment(
  'From Review',
  '言葉から景色へ渡る一枚',
  '主導線のレビューから離れすぎないように、最初の一枚は読後の余韻とつながっている作品を置いています。',
  heroLeadEntry
);

addFeaturedMoment(
  'Learning Glow',
  '学びを景色に変える棚',
  '考え方や習慣の本が残す輪郭は、整った結論よりも、日々の見え方の変化として受け取りたいものです。',
  pickScene(GALLERY_LEARNING_GENRES)
);

addFeaturedMoment(
  'Far Horizon',
  '少し遠くへ連れていく景色',
  '歴史や漫画やホビーの本は、今いる場所から少し離れた地平を見せてくれます。その広がりを副導線として残します。',
  pickScene(GALLERY_HORIZON_GENRES)
);

const chapterLinks = browseChapters.map((chapter) => ({
  href: `#${getChapterSectionId(chapter)}`,
  label: chapter.title,
  count: chapter.items.length,
}));
---

<Layout
  title="Gallery | 読書 with Coco"
  description="レビューの余韻から続く景色を、ココちゃんと静かに見返す Gallery ページ。"
>
  {galleryEntries.length ? (
    <div class="gallery-world">
      <section class="gallery-hero" aria-labelledby="gallery-page-title">
        <div class="hero-copy">
          <p class="section-label">Gallery / Scenic Side Path</p>
          <p class="hero-brand">読書 with Coco</p>
          <h1 id="gallery-page-title">読後の景色を、ココちゃんと静かに見返す。</h1>
          <p class="hero-lead">
            レビューで受け取った余韻を、ここでは色や構図のほうから確かめます。主役はあくまで本。
            そのそばでココちゃんが、読書から広がる景色を静かに案内します。
          </p>

          {heroLeadEntry && (
            <p class="hero-note">
              いま先頭に置いている景色は <span>{heroLeadEntry.data.title}</span>。
              Reviews 主導の流れを壊さないように、最初の一枚は言葉の余韻に近い場所から始めています。
            </p>
          )}

          <div class="hero-actions ui-action-group ui-action-group--stack">
            <a class="hero-link hero-link-primary ui-action" href="#scene-featured">景色をめくる</a>
            <a class="hero-link hero-link-secondary ui-action" href={reviewsUrl}>レビューの主導線へ戻る</a>
          </div>
        </div>

        <div class="hero-visual">
          {heroLeadEntry && (
            (() => {
              const href = getSceneHref(heroLeadEntry);
              const summary = getGallerySceneSummary(heroLeadEntry);

              return href ? (
                <a class="hero-scene hero-scene-lead" href={href} aria-label={`${heroLeadEntry.data.title}の景色を見る`}>
                  <div class="hero-scene-media">
                    <img
                      src={withBase(heroLeadEntry.data.image)}
                      alt={`${heroLeadEntry.data.title}の展示画像`}
                      loading="eager"
                      decoding="async"
                      width="960"
                      height="1080"
                    />
                  </div>
                  <div class="hero-scene-body">
                    <p class="hero-scene-kicker">Lead Scene</p>
                    <h2>{heroLeadEntry.data.title}</h2>
                    {heroLeadEntry.data.author && <p class="scene-author">著者: {heroLeadEntry.data.author}</p>}
                    <p class="scene-summary">{summary}</p>
                    <span class="scene-action">景色の余韻を見る</span>
                  </div>
                </a>
              ) : (
                <article class="hero-scene hero-scene-lead">
                  <div class="hero-scene-media">
                    <img
                      src={withBase(heroLeadEntry.data.image)}
                      alt={`${heroLeadEntry.data.title}の展示画像`}
                      loading="eager"
                      decoding="async"
                      width="960"
                      height="1080"
                    />
                  </div>
                  <div class="hero-scene-body">
                    <p class="hero-scene-kicker">Lead Scene</p>
                    <h2>{heroLeadEntry.data.title}</h2>
                    {heroLeadEntry.data.author && <p class="scene-author">著者: {heroLeadEntry.data.author}</p>}
                    <p class="scene-summary">{summary}</p>
                    <span class="scene-status">展示中</span>
                  </div>
                </article>
              );
            })()
          )}

          <div class="hero-echoes" aria-label="景色の断片">
            {heroSupportEntries.map((entry) => {
              const href = getSceneHref(entry);
              const summary = getGallerySceneSummary(entry);

              return href ? (
                <a class="hero-echo" href={href} aria-label={`${entry.data.title}の景色を見る`}>
                  <div class="hero-echo-media">
                    <img
                      src={withBase(entry.data.image)}
                      alt={`${entry.data.title}の展示画像`}
                      loading="lazy"
                      decoding="async"
                      width="480"
                      height="540"
                    />
                  </div>
                  <div class="hero-echo-body">
                    <p class="hero-echo-title">{entry.data.title}</p>
                    <p>{summary}</p>
                  </div>
                </a>
              ) : (
                <article class="hero-echo">
                  <div class="hero-echo-media">
                    <img
                      src={withBase(entry.data.image)}
                      alt={`${entry.data.title}の展示画像`}
                      loading="lazy"
                      decoding="async"
                      width="480"
                      height="540"
                    />
                  </div>
                  <div class="hero-echo-body">
                    <p class="hero-echo-title">{entry.data.title}</p>
                    <p>{summary}</p>
                  </div>
                </article>
              );
            })}
          </div>

          <aside class="hero-panel" aria-label="Gallery のしおり">
            <p class="panel-label">Scenic Notes</p>

            <dl class="panel-stats">
              <div>
                <dt>公開中の景色</dt>
                <dd>{galleryEntries.length}</dd>
              </div>
              <div>
                <dt>Review につながる入口</dt>
                <dd>{linkedReviewCount}</dd>
              </div>
            </dl>

            {chapterLinks.length > 0 && (
              <div class="panel-block">
                <p>このページの歩き方</p>
                <ul class="chapter-links">
                  {chapterLinks.map((chapter) => (
                    <li>
                      <a href={chapter.href}>
                        <span>{chapter.label}</span>
                        <strong>{chapter.count}</strong>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </aside>
        </div>
      </section>

      {featuredMoments.length > 0 && (
        <section class="featured-room" id="scene-featured" aria-labelledby="featured-scenes-title">
          <div class="room-intro">
            <p class="section-label">Featured Scenes</p>
            <h2 id="featured-scenes-title">本から生まれた景色を、先に3つだけひらく。</h2>
            <p>
              一覧を急いで見せるより、まずはこのサイトらしい空気が伝わる景色から始めます。
              ここで受け取った気配が、その後の棚めぐりの導入になります。
            </p>
          </div>

          <div class="featured-grid">
            {featuredMoments.map((moment) => {
              const href = getSceneHref(moment.entry);
              const summary = getGallerySceneSummary(moment.entry);

              return href ? (
                <a class="feature-card" href={href} aria-label={`${moment.entry.data.title}の景色を見る`}>
                  <div class="feature-media">
                    <img
                      src={withBase(moment.entry.data.image)}
                      alt={`${moment.entry.data.title}の展示画像`}
                      loading="lazy"
                      decoding="async"
                      width="720"
                      height="860"
                    />
                  </div>
                  <div class="feature-body">
                    <p class="feature-kicker">{moment.eyebrow}</p>
                    <h3>{moment.title}</h3>
                    <p class="feature-entry-title">{moment.entry.data.title}</p>
                    <p>{moment.copy}</p>
                    <p class="feature-summary">{summary}</p>
                    <span class="scene-action">景色を見る</span>
                  </div>
                </a>
              ) : (
                <article class="feature-card">
                  <div class="feature-media">
                    <img
                      src={withBase(moment.entry.data.image)}
                      alt={`${moment.entry.data.title}の展示画像`}
                      loading="lazy"
                      decoding="async"
                      width="720"
                      height="860"
                    />
                  </div>
                  <div class="feature-body">
                    <p class="feature-kicker">{moment.eyebrow}</p>
                    <h3>{moment.title}</h3>
                    <p class="feature-entry-title">{moment.entry.data.title}</p>
                    <p>{moment.copy}</p>
                    <p class="feature-summary">{summary}</p>
                    <span class="scene-status">展示中</span>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      )}

      <section class="browse-room" aria-labelledby="browse-room-title">
        <div class="browse-intro">
          <div class="browse-copy">
            <p class="section-label">Browse The Shelf</p>
            <h2 id="browse-room-title">展示の余韻は残したまま、ここからは探しやすく。</h2>
            <p>
              ここでは眺める棚と探す棚を少しだけ分けます。Curated では章立ての空気を残し、
              Grid では比較しやすさを優先して、同じ作品群を軽く見返せるようにします。
            </p>
          </div>

          <div class="browse-side">
            <p class="browse-note">
              まずは Gallery 内で段階改善し、将来はこの browse model と compact card を
              <span>/gallery/archive/</span> 側へ持っていける骨格に寄せます。
            </p>
            <dl class="browse-stats">
              <div>
                <dt>Browse items</dt>
                <dd>{browseModel.items.length}</dd>
              </div>
              <div>
                <dt>Curated chapters</dt>
                <dd>{browseChapters.length}</dd>
              </div>
            </dl>
          </div>
        </div>

        <div class="browse-controls" data-gallery-controls hidden>
          <div class="browse-control-group">
            <p class="browse-control-label">View mode</p>
            <div class="view-switch" role="group" aria-label="表示モード">
              <button
                type="button"
                class="view-switch-button is-active"
                data-view-button="curated"
                aria-pressed="true"
              >
                Curated
              </button>
              <button type="button" class="view-switch-button" data-view-button="grid" aria-pressed="false">
                Grid
              </button>
            </div>
          </div>

          <div class="browse-control-group browse-control-group-chips">
            <p class="browse-control-label">Genre filter</p>
            <div class="genre-chips" role="group" aria-label="ジャンルフィルタ">
              <button
                type="button"
                class="genre-chip is-active"
                data-genre-button="all"
                aria-pressed="true"
              >
                すべて
              </button>
              {browseModel.genres.map((genre) => (
                <button type="button" class="genre-chip" data-genre-button={genre} aria-pressed="false">
                  {genre}
                </button>
              ))}
            </div>
          </div>

          <p class="browse-status" data-browse-status aria-live="polite">
            Curated view / すべての景色
          </p>
        </div>

        <noscript>
          <p class="browse-noscript">
            JavaScript を使わない環境では、Gallery は Curated view のまま静かに眺められる構成にしています。
          </p>
        </noscript>

        <div
          class="browse-panels"
          data-gallery-browse-root
          data-current-view="curated"
          data-current-genre="all"
          data-testid="gallery-browse"
        >
          <div class="browse-curated" data-browse-panel="curated" data-gallery-curated>
            {browseChapters.map((chapter) => (
              <section
                class={`chapter-room chapter-room-${chapter.mood}`}
                id={getChapterSectionId(chapter)}
                aria-labelledby={`${getChapterSectionId(chapter)}-title`}
                data-chapter-section={chapter.id}
              >
                <div class="chapter-intro">
                  <p class="section-label">{chapter.eyebrow}</p>
                  <h2 id={`${getChapterSectionId(chapter)}-title`}>{chapter.title}</h2>
                  <p>{chapter.description}</p>
                  <p class="chapter-count">{chapter.items.length} pieces</p>
                </div>

                <div class="chapter-stage">
                  {chapter.items[0] && (
                    chapter.items[0].href ? (
                      <a class="chapter-lead" href={chapter.items[0].href} aria-label={`${chapter.items[0].title}の景色を見る`}>
                        <div class="chapter-lead-media">
                          <img
                            src={withBase(chapter.items[0].image)}
                            alt={`${chapter.items[0].title}の展示画像`}
                            loading="lazy"
                            decoding="async"
                            width="960"
                            height="720"
                          />
                        </div>
                        <div class="chapter-lead-body">
                          {chapter.items[0].genre && <p class="genre-label">{chapter.items[0].genre}</p>}
                          <h3>{chapter.items[0].title}</h3>
                          {chapter.items[0].author && <p class="scene-author">著者: {chapter.items[0].author}</p>}
                          <p class="scene-summary">{chapter.items[0].summary}</p>
                          <span class="scene-action">景色をひらく</span>
                        </div>
                      </a>
                    ) : (
                      <article class="chapter-lead">
                        <div class="chapter-lead-media">
                          <img
                            src={withBase(chapter.items[0].image)}
                            alt={`${chapter.items[0].title}の展示画像`}
                            loading="lazy"
                            decoding="async"
                            width="960"
                            height="720"
                          />
                        </div>
                        <div class="chapter-lead-body">
                          {chapter.items[0].genre && <p class="genre-label">{chapter.items[0].genre}</p>}
                          <h3>{chapter.items[0].title}</h3>
                          {chapter.items[0].author && <p class="scene-author">著者: {chapter.items[0].author}</p>}
                          <p class="scene-summary">{chapter.items[0].summary}</p>
                          <span class="scene-status">展示中</span>
                        </div>
                      </article>
                    )
                  )}

                  {chapter.items.length > 1 && (
                    <div class="chapter-trail">
                      {chapter.items.slice(1).map((item) => (
                        item.href ? (
                          <a class="trail-card" href={item.href} aria-label={`${item.title}の景色を見る`}>
                            <div class="trail-media">
                              <img
                            src={item.imageSrc}
                                alt={`${item.title}の展示画像`}
                                loading="lazy"
                                decoding="async"
                                width="640"
                                height="480"
                              />
                            </div>
                            <div class="trail-body">
                              {item.genre && <p class="genre-label">{item.genre}</p>}
                              <h3>{item.title}</h3>
                              <p>{item.summary}</p>
                            </div>
                          </a>
                        ) : (
                          <article class="trail-card trail-card-static">
                            <div class="trail-media">
                              <img
                                src={item.imageSrc}
                                alt={`${item.title}の展示画像`}
                                loading="lazy"
                                decoding="async"
                                width="640"
                                height="480"
                              />
                            </div>
                            <div class="trail-body">
                              {item.genre && <p class="genre-label">{item.genre}</p>}
                              <h3>{item.title}</h3>
                              <p>{item.summary}</p>
                            </div>
                          </article>
                        )
                      ))}
                    </div>
                  )}
                </div>
              </section>
            ))}
          </div>

          <div class="browse-grid" data-browse-panel="grid" hidden>
            <div class="grid-catalog" data-grid-catalog></div>
          </div>
        </div>
      </section>

      <section class="bridge-room" aria-labelledby="bridge-room-title">
        <div class="bridge-copy">
          <p class="section-label">Back To The Main Path</p>
          <h2 id="bridge-room-title">主導線は Reviews に置いたまま、Gallery は余韻を深くする。</h2>
          <p>
            このページで見せたいのは、画像の数ではなく読書の空気です。迷ったときはレビューへ戻り、
            世界観の根っこをたどりたいときは About / world bridge へつなぎます。
          </p>
        </div>

        <div class="bridge-actions ui-action-group ui-action-group--stack">
          <a class="hero-link hero-link-primary ui-action" href={reviewsUrl}>レビューを見る</a>
          <a class="hero-link hero-link-secondary ui-action" href={aboutUrl}>About / world bridge へ</a>
        </div>
      </section>
    </div>
  ) : (
    <section class="gallery-empty">
      <h1>Gallery</h1>
      <p>公開中の作品はまだありません。</p>
    </section>
  )}
</Layout>

<script is:inline define:vars={{ browseData }}>
  const root = document.querySelector('[data-gallery-browse-root]');

  if (root) {
    const controls = document.querySelector('[data-gallery-controls]');
    const viewButtons = Array.from(document.querySelectorAll('[data-view-button]'));
    const genreButtons = Array.from(document.querySelectorAll('[data-genre-button]'));
    const statusNode = document.querySelector('[data-browse-status]');
    const curatedPanel = root.querySelector('[data-gallery-curated]');
    const gridPanel = root.querySelector('[data-browse-panel="grid"]');
    const gridCatalog = root.querySelector('[data-grid-catalog]');
    const validViews = new Set(['curated', 'grid']);
    const validGenres = new Set(['all', ...browseData.genres]);
    const expandedChapters = new Set();
    let hasBuiltGrid = false;

    const chapterSectionId = (chapterId) => `chapter-${chapterId}`;
    const chapterTrailId = (chapterId) => `chapter-trail-${chapterId}`;
    const escapeHtml = (value = '') =>
      value
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    const isCompactViewport = () => window.matchMedia('(max-width: 820px)').matches;
    const getVisibleItemCount = () => (isCompactViewport() ? 4 : 5);

    const getStateFromUrl = () => {
      const params = new URLSearchParams(window.location.search);
      const viewParam = params.get('view');
      const genreParam = params.get('genre');

      return {
        view: validViews.has(viewParam) ? viewParam : 'curated',
        genre: validGenres.has(genreParam) ? genreParam : 'all',
      };
    };

    const state = getStateFromUrl();

    const filteredChapters = () =>
      browseData.chapters
        .map((chapter) => ({
          ...chapter,
          items: chapter.items.filter((item) => state.genre === 'all' || item.genre === state.genre),
        }))
        .filter((chapter) => chapter.items.length > 0);

    const filteredItems = () =>
      browseData.items.filter((item) => state.genre === 'all' || item.genre === state.genre);

    const renderLeadCard = (item) => {
      const genre = item.genre ? `<p class="genre-label">${escapeHtml(item.genre)}</p>` : '';
      const author = item.author ? `<p class="scene-author">著者: ${escapeHtml(item.author)}</p>` : '';
      const summary = `<p class="scene-summary">${escapeHtml(item.summary)}</p>`;
      const media = `
        <div class="chapter-lead-media">
          <img
            src="${escapeHtml(item.imageSrc || item.image)}"
            alt="${escapeHtml(item.title)}の展示画像"
            loading="lazy"
            decoding="async"
            width="960"
            height="720"
          />
        </div>
      `;
      const body = `
        <div class="chapter-lead-body">
          ${genre}
          <h3>${escapeHtml(item.title)}</h3>
          ${author}
          ${summary}
          <span class="${item.href ? 'scene-action' : 'scene-status'}">${item.href ? '景色をひらく' : '展示中'}</span>
        </div>
      `;

      return item.href
        ? `<a class="chapter-lead" href="${escapeHtml(item.href)}" aria-label="${escapeHtml(item.title)}の景色を見る">${media}${body}</a>`
        : `<article class="chapter-lead">${media}${body}</article>`;
    };

    const renderTrailCard = (item) => {
      const genre = item.genre ? `<p class="genre-label">${escapeHtml(item.genre)}</p>` : '';
      const content = `
        <div class="trail-media">
          <img
            src="${escapeHtml(item.imageSrc || item.image)}"
            alt="${escapeHtml(item.title)}の展示画像"
            loading="lazy"
            decoding="async"
            width="640"
            height="480"
          />
        </div>
        <div class="trail-body">
          ${genre}
          <h3>${escapeHtml(item.title)}</h3>
          <p>${escapeHtml(item.summary)}</p>
        </div>
      `;

      return item.href
        ? `<a class="trail-card" href="${escapeHtml(item.href)}" aria-label="${escapeHtml(item.title)}の景色を見る" data-curated-item>${content}</a>`
        : `<article class="trail-card trail-card-static" data-curated-item>${content}</article>`;
    };

    const renderCurated = () => {
      const chapters = filteredChapters();
      const visibleCount = getVisibleItemCount();

      if (!chapters.length) {
        curatedPanel.innerHTML = `
          <div class="browse-empty-state" data-browse-empty>
            <h3>この条件に合う景色はまだ並んでいません。</h3>
            <p>別のジャンルに切り替えると、読後の棚をもう少し広く見返せます。</p>
          </div>
        `;
        return;
      }

      curatedPanel.innerHTML = chapters
        .map((chapter) => {
          const lead = chapter.items[0];
          const trail = chapter.items.slice(1);
          const isExpanded = expandedChapters.has(chapter.id);
          const visibleTrail = isExpanded ? trail : trail.slice(0, Math.max(visibleCount - 1, 0));
          const visibleItems = 1 + visibleTrail.length;
          const remainingCount = Math.max(chapter.items.length - visibleItems, 0);
          const showToggle = chapter.items.length > visibleCount;

          return `
            <section
              class="chapter-room chapter-room-${escapeHtml(chapter.mood)}"
              id="${chapterSectionId(chapter.id)}"
              aria-labelledby="${chapterSectionId(chapter.id)}-title"
              data-chapter-section="${escapeHtml(chapter.id)}"
            >
              <div class="chapter-intro">
                <p class="section-label">${escapeHtml(chapter.eyebrow)}</p>
                <h2 id="${chapterSectionId(chapter.id)}-title">${escapeHtml(chapter.title)}</h2>
                <p>${escapeHtml(chapter.description)}</p>
                <p class="chapter-count">${chapter.items.length} pieces</p>
              </div>

              <div class="chapter-stage">
                ${renderLeadCard(lead)}
                ${
                  visibleTrail.length
                    ? `<div class="chapter-trail" id="${chapterTrailId(chapter.id)}">${visibleTrail.map(renderTrailCard).join('')}</div>`
                    : `<div class="chapter-trail" id="${chapterTrailId(chapter.id)}" hidden></div>`
                }
                ${
                  showToggle
                    ? `<button
                        type="button"
                        class="chapter-more"
                        data-chapter-more="${escapeHtml(chapter.id)}"
                        aria-expanded="${isExpanded ? 'true' : 'false'}"
                        aria-controls="${chapterTrailId(chapter.id)}"
                      >${isExpanded ? '閉じる' : `残り${remainingCount}件を見る`}</button>`
                    : ''
                }
              </div>
            </section>
          `;
        })
        .join('');
    };

    const renderGridCard = (item) => {
      const genre = item.genre
        ? `<span class="grid-badge">${escapeHtml(item.genre)}</span>`
        : `<span class="grid-badge grid-badge-muted">展示</span>`;
      const author = item.author ? `<p class="grid-card-author">${escapeHtml(item.author)}</p>` : '';
      const content = `
        <div class="grid-card-media">
          <img
            src="${escapeHtml(item.imageSrc || item.image)}"
            alt="${escapeHtml(item.title)}の展示画像"
            loading="lazy"
            decoding="async"
            width="720"
            height="860"
          />
        </div>
        <div class="grid-card-body">
          <div class="grid-card-meta">${genre}</div>
          <h3>${escapeHtml(item.title)}</h3>
          ${author}
        </div>
      `;

      return item.href
        ? `<a class="grid-card" href="${escapeHtml(item.href)}" aria-label="${escapeHtml(item.title)}の景色を見る" data-grid-card>${content}</a>`
        : `<article class="grid-card grid-card-static" data-grid-card>${content}</article>`;
    };

    const renderGrid = () => {
      const items = filteredItems();
      hasBuiltGrid = true;

      gridCatalog.innerHTML = items.length
        ? items.map(renderGridCard).join('')
        : `
          <div class="browse-empty-state" data-browse-empty>
            <h3>この条件ではまだ比較できる景色がありません。</h3>
            <p>別のジャンルに切り替えると、目録のように並べて見返せます。</p>
          </div>
        `;
    };

    const syncControls = () => {
      viewButtons.forEach((button) => {
        const isActive = button.dataset.viewButton === state.view;
        button.setAttribute('aria-pressed', String(isActive));
        button.classList.toggle('is-active', isActive);
      });

      genreButtons.forEach((button) => {
        const isActive = button.dataset.genreButton === state.genre;
        button.setAttribute('aria-pressed', String(isActive));
        button.classList.toggle('is-active', isActive);
      });

      curatedPanel.hidden = state.view !== 'curated';
      gridPanel.hidden = state.view !== 'grid';

      if (statusNode) {
        const viewLabel = state.view === 'curated' ? 'Curated view' : 'Grid view';
        const genreLabel = state.genre === 'all' ? 'すべての景色' : state.genre;
        statusNode.textContent = `${viewLabel} / ${genreLabel}`;
      }
    };

    const syncUrl = (mode = 'replace') => {
      const url = new URL(window.location.href);

      if (state.view === 'curated') {
        url.searchParams.delete('view');
      } else {
        url.searchParams.set('view', state.view);
      }

      if (state.genre === 'all') {
        url.searchParams.delete('genre');
      } else {
        url.searchParams.set('genre', state.genre);
      }

      if (mode === 'push') {
        history.pushState({}, '', url);
        return;
      }

      if (mode === 'replace') {
        history.replaceState({}, '', url);
      }
    };

    const render = ({ historyMode = 'replace' } = {}) => {
      if (controls instanceof HTMLElement) {
        controls.hidden = false;
      }

      syncControls();
      renderCurated();

      if (state.view === 'grid' || hasBuiltGrid) {
        renderGrid();
      }

      if (historyMode !== 'skip') {
        syncUrl(historyMode);
      }
    };

    viewButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const nextView = button.dataset.viewButton;
        if (!validViews.has(nextView) || nextView === state.view) return;
        state.view = nextView;
        render({ historyMode: 'push' });
      });
    });

    genreButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const nextGenre = button.dataset.genreButton;
        if (!validGenres.has(nextGenre) || nextGenre === state.genre) return;
        state.genre = nextGenre;
        expandedChapters.clear();
        render({ historyMode: 'push' });
      });
    });

    curatedPanel.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const button = target.closest('[data-chapter-more]');
      if (!(button instanceof HTMLButtonElement)) return;

      const chapterId = button.dataset.chapterMore;
      if (!chapterId) return;

      if (expandedChapters.has(chapterId)) {
        expandedChapters.delete(chapterId);
      } else {
        expandedChapters.add(chapterId);
      }

      renderCurated();
      syncControls();
    });

    const viewportQuery = window.matchMedia('(max-width: 820px)');
    const handleViewportChange = () => {
      if (state.view === 'curated') {
        renderCurated();
        syncControls();
      }
    };

    viewportQuery.addEventListener('change', handleViewportChange);

    window.addEventListener('popstate', () => {
      const nextState = getStateFromUrl();
      state.view = nextState.view;
      state.genre = nextState.genre;
      expandedChapters.clear();
      render({ historyMode: 'skip' });
    });

    render();
  }
</script>

