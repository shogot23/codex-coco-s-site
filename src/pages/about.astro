---
import { getCollection, getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";

const items = await getCollection("about");
const entry = items[0] ?? null;

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const isAbsoluteUrl = (value: string) => /^(?:[a-z][a-z\d+.-]*:|\/\/)/i.test(value);

const withBase = (path: string) => {
  if (!path) return base;
  if (isAbsoluteUrl(path)) return path;
  if (path.startsWith(base)) return path;
  return `${base}${path.replace(/^\/+/, "")}`;
};

const stripMarkdown = (value: string) =>
  value
    .replace(/^#{1,6}\s+/gm, "")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/[*_`>-]/g, "")
    .replace(/\n{3,}/g, "\n\n")
    .trim();

const getParagraphs = (value: string) =>
  stripMarkdown(value)
    .split(/\n\s*\n/)
    .map((paragraph) => paragraph.replace(/\s*\n\s*/g, " ").trim())
    .filter(Boolean);

let profileEntry = null;

try {
  profileEntry = await getEntry("profile", "profile");
} catch {
  // Profile content is optional during local content setup.
}

const aboutParagraphs = entry ? getParagraphs(entry.body) : [];
const profileParagraphs = profileEntry ? getParagraphs(profileEntry.body) : [];

const heroImageUrl = withBase("/uploads/about-hero.png");
const avatarUrl = withBase(profileEntry?.data?.avatar ?? "/uploads/bc1bf64b-abcd-4e08-80ff-870c34201abf.png");

const updatedAtLabel = entry?.data?.updatedAt
  ? new Intl.DateTimeFormat("ja-JP", {
      year: "numeric",
      month: "long",
      day: "numeric",
      timeZone: "UTC",
    }).format(entry.data.updatedAt)
  : null;

const reviewsUrl = withBase("reviews/");
const galleryUrl = withBase("gallery/");
const videosUrl = withBase("videos/");
const homeUrl = withBase("");

const aboutLead =
  aboutParagraphs[0] ??
  "読書 with Coco は、本を読み終えたあとに静かに残る気配を、もう一度見つめ直すための場所です。";
const aboutBridge =
  aboutParagraphs[1] ??
  "読んで終わりにしない。本のそばにココちゃんがいることで、言葉だけでは届かない景色や学びに、やわらかな呼吸を与えます。";
const pathLead =
  aboutParagraphs[2] ??
  "レビューでは言葉の輪郭を、ギャラリーでは景色の記憶を、ときどき動く断片では余韻の呼吸を、ゆっくりたどります。";
const closingLead =
  aboutParagraphs[3] ??
  "ここで見せたいのは要約や正解ではなく、本を閉じたあとに世界の見え方が少し変わる、その小さな瞬間です。";
const profileLead =
  profileParagraphs[0] ??
  "ココちゃんは、この場所で読後の景色にやわらかな呼吸を入れる案内役です。";

const manifestoItems = [
  {
    prompt: "なぜ本を読むのか",
    text: "まだうまく言葉にできない気持ちに、そっと輪郭を与えてもらうため。",
  },
  {
    prompt: "なぜココちゃんと一緒なのか",
    text: "まじめな感想だけでは少し硬くなる世界に、やわらかな体温を戻すため。",
  },
  {
    prompt: "この場所で見せたいもの",
    text: "本を閉じたあと、景色の見え方がほんの少し変わる瞬間の静かな手ざわり。",
  },
];

const bridgeSteps = [
  {
    label: "Review",
    title: "読後の輪郭を、まず言葉で拾う。",
    description: "主役はレビューです。一冊から受け取った感情や学びを、短くても逃がさずに残します。",
    href: reviewsUrl,
    cta: "レビューを見る",
  },
  {
    label: "Gallery",
    title: "言葉の外にある景色を、ココちゃんと見返す。",
    description: "文字のあいだに立ち上がった空気や色を、読後の景色としてそっと確かめ直します。",
    href: galleryUrl,
    cta: "ギャラリーを見る",
  },
  {
    label: "Fragments",
    title: "余韻が動いた瞬間だけ、静かな断片として置く。",
    description: "ここは映像の主役席ではなく、読後に残ったテンポや呼吸を、必要なときだけ見返すための小さな補助室です。",
    href: videosUrl,
    cta: "動く断片を見る",
  },
];
---

<Layout
  title={entry ? `${entry.data.title} | 読書 with Coco` : "About | 読書 with Coco"}
  description={entry?.data?.description}
  image={heroImageUrl}
>
  <div class="about-world">
    <section class="about-hero" aria-labelledby="about-title">
      <div class="hero-copy">
        <p class="section-label">About / World Bridge</p>
        <p class="hero-brand">読書 with Coco</p>
        <h1 id="about-title">本を閉じたあとも、ココちゃんと世界はつづいていく。</h1>
        <p class="hero-lead">{aboutLead}</p>
        <p class="hero-bridge">{aboutBridge}</p>

        <div class="hero-actions ui-action-group ui-action-group--stack">
          <a class="hero-link hero-link-primary ui-action" href={reviewsUrl}>レビューを見る</a>
          <a class="hero-link hero-link-secondary ui-action" href={galleryUrl}>ギャラリーを見る</a>
        </div>

        <div class="hero-footnote">
          <p>{entry?.data?.description ?? "読書 with Coco について"}</p>
          {updatedAtLabel && <span>更新: {updatedAtLabel}</span>}
        </div>
      </div>

      <div class="hero-visual">
        <figure class="hero-image-frame">
          <img
            src={heroImageUrl}
            alt="本に囲まれたココちゃん"
            width="960"
            height="960"
            loading="eager"
            decoding="async"
          />
        </figure>

        <aside class="hero-note">
          <div class="hero-note-avatar">
            <img
              src={avatarUrl}
              alt="読書 with Coco の案内役、ココちゃん"
              width="160"
              height="160"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="hero-note-copy">
            <p class="hero-note-label">Coco&apos;s Presence</p>
            <p>{profileLead}</p>
          </div>
        </aside>
      </div>
    </section>

    <section class="manifesto-room" aria-labelledby="manifesto-title">
      <div class="manifesto-intro">
        <p class="section-label">Quiet Manifesto</p>
        <h2 id="manifesto-title">説明より先に、この場所のまなざしを置く。</h2>
      </div>

      <div class="manifesto-lines">
        {manifestoItems.map((item) => (
          <article class="manifesto-line">
            <p class="manifesto-prompt">{item.prompt}</p>
            <p class="manifesto-text">{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="philosophy-room" aria-labelledby="philosophy-title">
      <div class="philosophy-copy">
        <p class="section-label">Living Philosophy</p>
        <h2 id="philosophy-title">本と暮らしのあいだで</h2>
        <p>読書withCocoは、本を正しく要約するためだけの場所ではありません。</p>
        <p>
          一冊の本をきっかけに、自分の暮らし、働き方、学び方、弱さ、回復、これからの生き方を
          少しだけ見つめ直すための場所です。
        </p>
        <p>本の中にある知識を、今日の行動に変える。<br />難しい言葉を、自分の生活に置き直す。<br />読み終えたあとに残る感覚を、ココちゃんと一緒にそっと拾い上げる。</p>
        <p>そんな読書の記録を、ここに残していきます。</p>
      </div>
    </section>

    <section class="bridge-room" aria-labelledby="bridge-title">
      <div class="bridge-intro">
        <p class="section-label">World Bridge</p>
        <h2 id="bridge-title">本 × ココちゃん × 学び は、余韻のなかでゆっくり交わる。</h2>
        <p>{pathLead}</p>
      </div>

      <div class="bridge-steps">
        {bridgeSteps.map((step, index) => (
          <article class="bridge-step">
            <p class="bridge-count">{String(index + 1).padStart(2, "0")}</p>
            <div class="bridge-body">
              <p class="bridge-label">{step.label}</p>
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </div>
            <a class="bridge-link ui-action" href={step.href}>{step.cta}</a>
          </article>
        ))}
      </div>
    </section>

    <section class="closing-room" aria-labelledby="closing-title">
      <div class="closing-copy">
        <p class="section-label">A Small Promise</p>
        <h2 id="closing-title">ここは、読後の景色を急がずに確かめるための場所です。</h2>
        <p>{closingLead}</p>
        <p class="closing-note">
          派手に説明する代わりに、言葉と景色とココちゃんで、読後の気配を少しずつ読み返せる場所にしていきます。
        </p>
      </div>

      <div class="closing-links ui-action-group ui-action-group--stack">
        <a class="hero-link hero-link-primary ui-action" href={reviewsUrl}>レビューを見る</a>
        <a class="hero-link hero-link-secondary ui-action" href={homeUrl}>Home へ戻る</a>
      </div>
    </section>
  </div>
</Layout>

<style>
  .about-world {
    display: grid;
    gap: clamp(1.75rem, 4vw, 3.25rem);
  }

  .about-hero,
  .manifesto-room,
  .philosophy-room,
  .bridge-room,
  .closing-room {
    position: relative;
    overflow: clip;
    border: 1px solid rgba(100, 76, 42, 0.14);
    border-radius: clamp(26px, 4vw, 40px);
    box-shadow: 0 24px 70px rgba(83, 55, 28, 0.1);
  }

  .about-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(320px, 0.98fr);
    gap: clamp(1.5rem, 3vw, 3rem);
    padding: clamp(2rem, 4.5vw, 3.8rem);
    background:
      radial-gradient(circle at top left, rgba(235, 224, 209, 0.78), transparent 30%),
      radial-gradient(circle at bottom right, rgba(209, 218, 228, 0.22), transparent 32%),
      linear-gradient(145deg, rgba(252, 249, 244, 0.98), rgba(245, 245, 242, 0.94));
  }

  .manifesto-room,
  .philosophy-room,
  .bridge-room,
  .closing-room {
    padding: clamp(1.35rem, 3vw, 2.3rem);
    background:
      linear-gradient(180deg, rgba(255, 253, 249, 0.98), rgba(248, 245, 239, 0.92));
  }

  .hero-copy,
  .hero-visual,
  .bridge-intro,
  .philosophy-copy,
  .closing-copy {
    position: relative;
    z-index: 1;
  }

  .section-label,
  .hero-note-label,
  .manifesto-prompt,
  .bridge-label,
  .bridge-count {
    margin: 0;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-label,
  .hero-note-label,
  .bridge-label {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .hero-brand {
    margin: 0.95rem 0 0;
    font-size: clamp(1.4rem, 1.9vw, 1.75rem);
    color: color-mix(in srgb, var(--color-text) 92%, transparent);
  }

  .about-hero h1,
  .manifesto-intro h2,
  .bridge-intro h2,
  .bridge-body h3,
  .philosophy-copy h2,
  .closing-copy h2 {
    margin: 0;
    font-family: var(--font-display);
    line-height: 1.1;
    letter-spacing: 0.02em;
    color: #1b2330;
  }

  .about-hero h1 {
    margin-top: 1rem;
    font-size: clamp(2.7rem, 5vw, 4.5rem);
    max-width: 10ch;
    text-wrap: balance;
    letter-spacing: -0.025em;
  }

  .hero-lead,
  .hero-bridge,
  .bridge-intro p,
  .bridge-body p,
  .philosophy-copy p,
  .closing-copy p,
  .hero-note-copy p {
    color: rgba(33, 23, 16, 0.78);
  }

  .hero-lead,
  .hero-bridge {
    margin: 1.2rem 0 0;
    max-width: 31rem;
    line-height: 1.82;
    font-size: var(--text-lead);
  }

  .hero-actions,
  .closing-links {
    display: flex;
    gap: 0.9rem;
    margin-top: 1.8rem;
  }

  .hero-link,
  .bridge-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    font-weight: 700;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  .hero-link {
    min-height: 48px;
    padding: 0.85rem 1.3rem;
  }

  .hero-link:hover,
  .bridge-link:hover {
    transform: translateY(-1px);
  }

  .hero-link-primary {
    background: linear-gradient(180deg, rgba(50, 45, 41, 0.96), rgba(29, 27, 25, 0.96));
    color: #fffdf9;
    box-shadow: 0 18px 34px rgba(26, 22, 20, 0.16);
  }

  .hero-link-secondary,
  .bridge-link {
    border: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.78);
    color: color-mix(in srgb, var(--color-text) 84%, transparent);
  }

  .hero-footnote,
  .hero-note {
    border: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.76);
  }

  .hero-footnote {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    align-items: center;
    width: fit-content;
    margin-top: 1.5rem;
    padding: 0.8rem 1rem;
    border-radius: 18px;
  }

  .hero-footnote p,
  .hero-footnote span {
    margin: 0;
    color: rgba(33, 23, 16, 0.7);
    font-size: 0.9rem;
  }

  .hero-visual {
    display: grid;
    align-items: end;
  }

  .hero-image-frame {
    margin: 0;
    overflow: hidden;
    border-radius: clamp(24px, 3vw, 34px);
    min-height: 100%;
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.64), rgba(237, 212, 184, 0.76));
  }

  .hero-image-frame img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 460px;
    object-fit: cover;
  }

  .hero-note {
    position: absolute;
    right: clamp(1rem, 2vw, 1.4rem);
    bottom: clamp(1rem, 2vw, 1.4rem);
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.9rem;
    align-items: center;
    max-width: 320px;
    padding: 0.95rem 1rem;
    border-radius: 22px;
  }

  .hero-note-avatar {
    width: 72px;
    height: 72px;
    border-radius: 22px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 12px 24px rgba(83, 55, 28, 0.12);
  }

  .hero-note-avatar img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-note-copy {
    display: grid;
    gap: 0.35rem;
  }

  .hero-note-copy p {
    margin: 0;
    line-height: 1.7;
    font-size: 0.93rem;
  }

  .manifesto-room {
    display: grid;
    gap: 1.6rem;
  }

  .philosophy-room {
    display: grid;
    gap: 1.6rem;
  }

  .philosophy-copy {
    display: grid;
    gap: 0.95rem;
    max-width: 40rem;
  }

  .manifesto-intro {
    display: grid;
    gap: 0.65rem;
    max-width: 36rem;
  }

  .manifesto-intro h2,
  .bridge-intro h2,
  .philosophy-copy h2,
  .closing-copy h2 {
    font-size: clamp(2rem, 3vw, 2.8rem);
    text-wrap: balance;
  }

  .manifesto-lines {
    display: grid;
    gap: 1rem;
  }

  .manifesto-line {
    display: grid;
    gap: 0.55rem;
    padding: 1.15rem 0;
    border-top: 1px solid rgba(100, 76, 42, 0.12);
  }

  .manifesto-line:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .manifesto-prompt {
    font-size: 0.76rem;
    font-weight: 700;
    color: #8d5b2a;
  }

  .manifesto-text {
    margin: 0;
    max-width: 40rem;
    font-family: var(--font-headline);
    font-size: clamp(1.15rem, 1.8vw, 1.45rem);
    line-height: 1.65;
    color: #2c2017;
  }

  .bridge-room {
    display: grid;
    gap: 1.75rem;
    background:
      radial-gradient(circle at top right, rgba(244, 219, 186, 0.45), transparent 24%),
      linear-gradient(180deg, rgba(255, 252, 247, 0.98), rgba(244, 238, 229, 0.9));
  }

  .bridge-intro {
    display: grid;
    gap: 0.75rem;
    max-width: 42rem;
  }

  .bridge-intro p,
  .philosophy-copy p,
  .closing-copy p {
    margin: 0;
    line-height: 1.85;
  }

  .bridge-steps {
    display: grid;
    gap: 0.95rem;
  }

  .bridge-step {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 1rem 1.2rem;
    align-items: center;
    padding: 1rem 1.1rem;
    border: 1px solid rgba(100, 76, 42, 0.12);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.66);
  }

  .bridge-count {
    display: grid;
    place-items: center;
    width: 54px;
    height: 54px;
    border-radius: 18px;
    background: rgba(247, 214, 176, 0.42);
    color: #7d4c22;
    font-weight: 700;
    font-size: 0.82rem;
  }

  .bridge-body {
    display: grid;
    gap: 0.45rem;
  }

  .bridge-body h3 {
    font-size: clamp(1.2rem, 2vw, 1.6rem);
  }

  .bridge-body p {
    margin: 0;
    line-height: 1.8;
  }

  .bridge-link {
    min-height: 44px;
    padding: 0.8rem 1.1rem;
  }

  .closing-room {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.6rem;
    align-items: center;
    background:
      radial-gradient(circle at bottom left, rgba(62, 93, 139, 0.08), transparent 28%),
      linear-gradient(180deg, rgba(255, 253, 248, 0.98), rgba(246, 238, 226, 0.92));
  }

  .closing-copy {
    display: grid;
    gap: 0.95rem;
    max-width: 38rem;
  }

  .closing-note {
    color: #6d4e34;
    max-width: 34rem;
  }

  @media (max-width: 920px) {
    .about-hero,
    .closing-room {
      grid-template-columns: 1fr;
    }

    .hero-visual {
      order: -1;
    }

    .about-hero h1 {
      max-width: none;
    }
  }

  @media (max-width: 720px) {
    .about-world {
      gap: 1.15rem;
    }

    .about-hero,
    .manifesto-room,
    .philosophy-room,
    .bridge-room,
    .closing-room {
      border-radius: 28px;
      padding: 1.15rem;
    }

    .hero-image-frame img {
      min-height: 320px;
    }

    .hero-note {
      position: static;
      max-width: none;
      margin-top: 0.9rem;
    }

    .bridge-step {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .bridge-link,
    .bridge-count {
      justify-self: start;
    }
  }

  @media (max-width: 520px) {
    .about-hero h1,
    .manifesto-intro h2,
    .bridge-intro h2,
    .philosophy-copy h2,
    .closing-copy h2 {
      font-size: 2rem;
    }

    .manifesto-text {
      font-size: 1.05rem;
    }

    .hero-footnote,
    .hero-note {
      width: 100%;
      box-sizing: border-box;
    }
  }
</style>
