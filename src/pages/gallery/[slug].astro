---
import Layout from '../../layouts/Layout.astro';
import { getEntry, type CollectionEntry } from 'astro:content';
import { getGalleryGenreBucket } from '../../lib/gallery-taxonomy';
import { getPublishedGallery, hasDetailContent, sortGalleryEntries } from '../../utils/gallery';

export async function getStaticPaths() {
  const entries = await getPublishedGallery();

  return entries
    .filter((entry) => hasDetailContent(entry))
    .map((entry) => ({
      params: { slug: entry.slug },
      props: { entry },
    }));
}

type Props = {
  entry: CollectionEntry<'gallery'>;
};

const { entry } = Astro.props as Props;
const { title, image, genre, author, note, description } = entry.data;

const base = import.meta.env.BASE_URL;
const baseWithSlash = base.endsWith('/') ? base : `${base}/`;
const galleryListUrl = `${baseWithSlash}gallery/`;
const reviewsListUrl = `${baseWithSlash}reviews/`;
const isAbsoluteUrl = (value: string) =>
  /^(?:[a-z][a-z\d+.-]*:|\/\/)/i.test(value);

const withBase = (assetPath: string) => {
  if (!assetPath) return baseWithSlash;
  if (isAbsoluteUrl(assetPath)) return assetPath;
  if (assetPath.startsWith(baseWithSlash)) return assetPath;
  return `${baseWithSlash}${assetPath.replace(/^\/+/, '')}`;
};

const resolveAbsoluteImageUrl = (assetPath: string) => {
  const resolved = withBase(assetPath);
  if (isAbsoluteUrl(resolved)) return resolved;
  return new URL(resolved, Astro.site!).toString();
};

let relatedReview: CollectionEntry<'reviews'> | null = null;
if (entry.data.relatedReview) {
  const linkedReview = (await getEntry(entry.data.relatedReview)) ?? null;
  relatedReview = linkedReview?.data.published === true ? linkedReview : null;
}

const allGalleryEntries = sortGalleryEntries(await getPublishedGallery());
const relatedScenes = allGalleryEntries
  .filter((galleryEntry) => galleryEntry.slug !== entry.slug)
  .filter((galleryEntry) => (genre ? galleryEntry.data.genre === genre : true))
  .slice(0, 3);

const fallbackScenes =
  relatedScenes.length > 0
    ? relatedScenes
    : allGalleryEntries.filter((galleryEntry) => galleryEntry.slug !== entry.slug).slice(0, 3);

const pageDescription = description ?? `${genre ?? 'ギャラリー'}の展示作品`;
const sceneMemo = note ?? '読後に残った空気を、画像の前でもう一度たしかめるための景色です。';

const coverImageUrl = resolveAbsoluteImageUrl(image);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site!).toString();
const galleryJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: title,
  description: pageDescription,
  image: [coverImageUrl],
  genre: genre,
  url: canonicalUrl,
  creator: author
    ? {
        '@type': 'Person',
        name: author,
      }
    : undefined,
  isPartOf: {
    '@type': 'CollectionPage',
    name: 'Gallery',
    url: new URL(galleryListUrl, Astro.site!).toString(),
  },
};

const relatedReviewUrl = relatedReview ? `${baseWithSlash}reviews/${relatedReview.slug}/` : reviewsListUrl;
const sceneShelfTitle = genre
  ? `${genre}の棚で見返す景色`
  : '読後の余韻を見返す棚';
const genreBucket = getGalleryGenreBucket(genre);
const sceneShelfCopy = genreBucket === 'learning'
  ? '学びが結論になる前の揺れを、暮らしに近い温度で受け止めるための棚です。'
  : genreBucket === 'horizon'
    ? '少し遠くの時代や熱量へ歩いていくときに、景色の広がりを静かに確かめるための棚です。'
    : '物語や感情の気配が先に残るとき、言葉の外側にある温度を見返すための棚です。';
const reviewBridgeTitle = relatedReview
  ? 'この景色の向こうにある言葉を読む。'
  : '主導線の Reviews に戻って、言葉の輪郭を拾い直す。';
const reviewBridgeCopy = relatedReview
  ? ''
  : 'Gallery は景色の副導線です。読後の輪郭を言葉で確かめたいときは、Reviews の流れへ戻るのが自然です。';

const galleryPurchaseLinks = entry.data.purchaseLinks ?? [];
const purchaseLinks = relatedReview?.data.purchaseLinks ?? galleryPurchaseLinks;
const hasPurchaseLinks = purchaseLinks.length > 0;
---

<Layout
  title={`${title} | Gallery | 読書 with Coco`}
  description={pageDescription}
  image={image}
  type="article"
  jsonLd={galleryJsonLd}
>
  <div class="scene-detail">
    <section class="scene-hero" aria-labelledby="gallery-title">
      <div class="scene-copy">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href={galleryListUrl}>Gallery</a>
          <span class="separator" aria-hidden="true">/</span>
          <span class="current" aria-current="page">{title}</span>
        </nav>

        <p class="section-label">Gallery / Scene Detail</p>
        <p class="scene-brand">読書 with Coco</p>
        {genre && <p class="genre-pill">{genre}</p>}
        <h1 id="gallery-title">{title}</h1>
        {author && <p class="author">著者: {author}</p>}
        <p class="scene-description">{pageDescription}</p>


        <div class="scene-actions ui-action-group ui-action-group--stack">
          {relatedReview ? (
            <a class="scene-link scene-link-primary ui-action" href={relatedReviewUrl}>
              この景色の言葉を読む
            </a>
          ) : hasPurchaseLinks ? (
            <a class="scene-link scene-link-primary ui-action"
               href={purchaseLinks[0].url}
               target="_blank"
               rel="noopener noreferrer nofollow">
              この本を見る
            </a>
          ) : (
            <a class="scene-link scene-link-primary ui-action" href={relatedReviewUrl}>
              レビューの主導線へ戻る
            </a>
          )}
          <a class="scene-link scene-link-secondary ui-action" href={galleryListUrl}>Gallery に戻る</a>
        </div>
      </div>

      <figure class="scene-visual">
        <img src={withBase(image)} alt={`${title}の展示画像`} loading="eager" decoding="async" width="1200" height="1500" />
      </figure>
    </section>

    <section class="scene-notes" aria-labelledby="scene-notes-title">
      <div class="notes-intro">
        <p class="section-label">Scene Notes</p>
        <h2 id="scene-notes-title">画像の前で立ち止まるための、短いメモ。</h2>
      </div>

      <div class="notes-grid">
        <article class="note-card">
          <p class="note-label">What Lingers</p>
          <p>{sceneMemo}</p>
        </article>

        <article class="note-card">
          <p class="note-label">Shelf Position</p>
          <h3>{sceneShelfTitle}</h3>
          <p>{sceneShelfCopy}</p>
          {genre && <p class="note-meta">Genre: {genre}</p>}
        </article>
      </div>
    </section>

    <section class="review-bridge" aria-labelledby="review-bridge-title">
      <div class="bridge-copy">
        <p class="section-label">From Image To Words</p>
        <h2 id="review-bridge-title">{reviewBridgeTitle}</h2>
        {reviewBridgeCopy && <p>{reviewBridgeCopy}</p>}
      </div>

      <div class="bridge-actions ui-action-group ui-action-group--stack">
        {relatedReview ? (
          <>
            <a class="scene-link scene-link-primary ui-action" href={relatedReviewUrl}>
              レビューを読む
            </a>
            {hasPurchaseLinks && (
              <div class="bridge-purchase-links ui-action-group">
                {purchaseLinks.map((link) => (
                  <a
                    class="scene-link scene-link-secondary ui-action"
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer nofollow"
                    aria-label={`${title}の購入先: ${link.label}`}
                  >
                    {link.label}
                  </a>
                ))}
                <p class="bridge-purchase-note">外部ストアへ移動します</p>
              </div>
            )}
          </>
        ) : hasPurchaseLinks ? (
          <>
            <div class="bridge-purchase-links ui-action-group">
              {purchaseLinks.map((link) => (
                <a
                  class="scene-link scene-link-primary ui-action"
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer nofollow"
                  aria-label={`${title}の購入先: ${link.label}`}
                >
                  {link.label}
                </a>
              ))}
              <p class="bridge-purchase-note">外部ストアへ移動します</p>
            </div>
            <a class="scene-link scene-link-secondary ui-action" href={relatedReviewUrl}>
              レビュー一覧を見る
            </a>
          </>
        ) : (
          <a class="scene-link scene-link-primary ui-action" href={relatedReviewUrl}>
            レビュー一覧を見る
          </a>
        )}
      </div>
    </section>

    {fallbackScenes.length > 0 && (
      <section class="related-scenes" aria-labelledby="related-scenes-title">
        <div class="notes-intro">
          <p class="section-label">More Scenes</p>
          <h2 id="related-scenes-title">
            {genre ? `同じ ${genre} の棚で、もう少し景色をめくる。` : 'もう少しだけ、別の景色をめくる。'}
          </h2>
        </div>

        <div class="related-grid">
          {fallbackScenes.map((scene) => {
            const href = hasDetailContent(scene) ? `${baseWithSlash}gallery/${scene.slug}/` : null;
            const summary = scene.data.note ?? scene.data.description ?? '読後の空気を静かにたしかめる展示です。';

            return href ? (
              <a class="related-card" href={href} aria-label={`${scene.data.title}の景色を見る`}>
                <div class="related-media">
                  <img
                    src={withBase(scene.data.image)}
                    alt={`${scene.data.title}の展示画像`}
                    loading="lazy"
                    decoding="async"
                    width="720"
                    height="900"
                  />
                </div>
                <div class="related-body">
                  {scene.data.genre && <p class="note-meta">{scene.data.genre}</p>}
                  <h3>{scene.data.title}</h3>
                  <p>{summary}</p>
                  <span class="related-action">景色を見る</span>
                </div>
              </a>
            ) : (
              <article class="related-card">
                <div class="related-media">
                  <img
                    src={withBase(scene.data.image)}
                    alt={`${scene.data.title}の展示画像`}
                    loading="lazy"
                    decoding="async"
                    width="720"
                    height="900"
                  />
                </div>
                <div class="related-body">
                  {scene.data.genre && <p class="note-meta">{scene.data.genre}</p>}
                  <h3>{scene.data.title}</h3>
                  <p>{summary}</p>
                  <span class="related-status">展示中</span>
                </div>
              </article>
            );
          })}
        </div>
      </section>
    )}
  </div>
</Layout>

<style>
  .scene-detail {
    display: grid;
    gap: clamp(1.5rem, 4vw, 2.8rem);
  }

  .scene-hero,
  .scene-notes,
  .review-bridge,
  .related-scenes {
    position: relative;
    overflow: clip;
    border: 1px solid rgba(100, 76, 42, 0.14);
    border-radius: clamp(26px, 4vw, 40px);
    box-shadow: 0 24px 70px rgba(83, 55, 28, 0.1);
  }

  .scene-hero {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(320px, 1.08fr);
    gap: clamp(1.4rem, 3vw, 2.8rem);
    padding: clamp(1.5rem, 4vw, 3rem);
    background:
      radial-gradient(circle at top left, rgba(247, 214, 176, 0.84), transparent 28%),
      radial-gradient(circle at bottom right, rgba(62, 93, 139, 0.18), transparent 30%),
      linear-gradient(135deg, rgba(255, 250, 243, 0.98), rgba(236, 242, 248, 0.92));
  }

  .scene-copy,
  .notes-intro,
  .bridge-copy {
    display: grid;
    align-content: start;
    gap: 0.95rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
    font-size: 0.92rem;
    color: rgba(32, 22, 15, 0.72);
  }

  .separator {
    opacity: 0.45;
  }

  .current {
    font-weight: 700;
  }

  .section-label,
  .note-label,
  .note-meta {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(66, 52, 35, 0.62);
  }

  .scene-brand {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2vw, 1.5rem);
  }

  .genre-pill {
    margin: 0;
    width: fit-content;
    padding: 0.4rem 0.8rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(100, 76, 42, 0.12);
    color: rgba(32, 22, 15, 0.84);
    font-size: 0.85rem;
  }

  .scene-copy h1,
  .notes-intro h2,
  .bridge-copy h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.08;
  }

  .author,
  .scene-description,
  .note-card p,
  .bridge-copy p,
  .related-body p {
    margin: 0;
    line-height: 1.8;
    color: rgba(32, 22, 15, 0.84);
  }

  .author {
    color: rgba(66, 52, 35, 0.74);
  }

  .scene-actions,
  .bridge-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 0.35rem;
  }

  .scene-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.9rem 1.3rem;
    border-radius: 999px;
    border: 1px solid rgba(82, 56, 28, 0.16);
    font-weight: 700;
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .scene-link:hover,
  .related-card:hover {
    transform: translateY(-3px);
  }

  .scene-link-primary {
    background: rgba(255, 252, 248, 0.94);
    box-shadow: 0 16px 32px rgba(83, 55, 28, 0.1);
  }

  .scene-link-secondary {
    background: rgba(255, 255, 255, 0.58);
  }

  .scene-visual {
    margin: 0;
    overflow: hidden;
    border-radius: clamp(22px, 3vw, 30px);
    background: rgba(63, 42, 25, 0.08);
    box-shadow: 0 20px 40px rgba(83, 55, 28, 0.12);
  }

  .scene-visual img,
  .related-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .scene-notes,
  .review-bridge,
  .related-scenes {
    padding: clamp(1.4rem, 4vw, 2.5rem);
    background:
      radial-gradient(circle at top right, rgba(247, 214, 176, 0.18), transparent 28%),
      linear-gradient(180deg, rgba(255, 250, 243, 0.97), rgba(246, 242, 236, 0.94));
  }

  .notes-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.2rem;
  }

  .note-card {
    display: grid;
    gap: 0.7rem;
    padding: 1.1rem;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.74);
    border: 1px solid rgba(100, 76, 42, 0.1);
  }

  .note-card h3,
  .related-body h3 {
    margin: 0;
    font-size: clamp(1.18rem, 2vw, 1.5rem);
    line-height: 1.2;
  }

  .review-bridge {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.5fr);
    gap: clamp(0.8rem, 2vw, 1.4rem);
    align-items: start;
    background:
      radial-gradient(circle at top left, rgba(205, 223, 236, 0.3), transparent 28%),
      linear-gradient(135deg, rgba(248, 249, 245, 0.98), rgba(236, 244, 247, 0.95));
  }

  .bridge-purchase-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
  }

  .bridge-purchase-note {
    margin: 0;
    width: 100%;
    font-size: 0.84rem;
    color: rgba(66, 52, 35, 0.55);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.2rem;
  }

  .related-card {
    display: grid;
    gap: 0.9rem;
    padding: 0.9rem;
    color: inherit;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.74);
    border: 1px solid rgba(100, 76, 42, 0.1);
    box-shadow: 0 18px 36px rgba(83, 55, 28, 0.08);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .related-media {
    overflow: hidden;
    border-radius: 18px;
    aspect-ratio: 0.9 / 1;
    background: rgba(63, 42, 25, 0.08);
  }

  .related-body {
    display: grid;
    gap: 0.6rem;
  }

  .related-action,
  .related-status {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.92rem;
    font-weight: 700;
    color: #0a4a8b;
  }

  .related-action::after {
    content: "→";
  }

  .related-status {
    color: rgba(66, 52, 35, 0.72);
  }

  @media (max-width: 1040px) {
    .scene-hero,
    .review-bridge {
      grid-template-columns: 1fr;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .notes-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .scene-detail {
      gap: 1.3rem;
    }

    .scene-hero,
    .scene-notes,
    .review-bridge,
    .related-scenes {
      border-radius: 26px;
      padding: 1.2rem;
    }

    .scene-link {
      width: 100%;
    }

    .scene-copy h1,
    .notes-intro h2,
    .bridge-copy h2 {
      font-size: clamp(1.8rem, 8vw, 2.6rem);
    }
  }
</style>
