---
import Layout from '../../layouts/Layout.astro';
import { getEntry, type CollectionEntry } from 'astro:content';
import { getPublishedGallery, hasDetailContent } from '../../utils/gallery';
import { getPublishedReviews } from '../../utils/reviews';

export async function getStaticPaths() {
  const reviews = await getPublishedReviews();
  return reviews.map((review) => ({
    params: { slug: review.slug },
    props: { review },
  }));
}

type Props = {
  review: CollectionEntry<'reviews'>;
};

const { review } = Astro.props as Props;
const {
  title,
  description,
  date,
  cover,
  bookTitle,
  author,
  tags,
  infographic,
  recommendedFor,
  excerpt,
  purchaseLinks,
} = review.data;
const { Content } = await review.render();

const formatDate = (value: Date) =>
  new Intl.DateTimeFormat('ja-JP', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  }).format(value);

const stripMarkdown = (value: string) =>
  value
    .replace(/^#{1,6}\s+/gm, '')
    .replace(/!\[([^\]]*)\]\([^)]+\)/g, '$1')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[*_`>#-]/g, '')
    .replace(/\n{3,}/g, '\n\n')
    .trim();

const clampText = (text: string, maxLength: number): string => {
  const normalized = stripMarkdown(text).replace(/\s+/g, ' ').trim();
  if (!normalized) return '';
  if (normalized.length <= maxLength) return normalized;
  return `${normalized.slice(0, maxLength).trimEnd()}…`;
};

const base = import.meta.env.BASE_URL;
const baseWithSlash = base.endsWith('/') ? base : `${base}/`;
const reviewsListUrl = `${baseWithSlash}reviews/`;
const galleryListUrl = `${baseWithSlash}gallery/`;

const isAbsoluteUrl = (value: string) =>
  /^(?:[a-z][a-z\d+.-]*:|\/\/)/i.test(value);

const withBase = (assetPath: string) => {
  if (!assetPath) return baseWithSlash;
  if (isAbsoluteUrl(assetPath)) return assetPath;
  if (assetPath.startsWith(baseWithSlash)) return assetPath;
  return `${baseWithSlash}${assetPath.replace(/^\/+/, '')}`;
};

const resolveImageUrl = (imagePath: string | undefined): string | null => {
  if (!imagePath) return null;
  if (isAbsoluteUrl(imagePath)) return imagePath;
  if (imagePath.startsWith(baseWithSlash)) {
    return new URL(imagePath, Astro.site!).toString();
  }
  const normalized = imagePath.startsWith('/') ? imagePath : `/${imagePath}`;
  return new URL(`${baseWithSlash}${normalized.replace(/^\/+/, '')}`, Astro.site!).toString();
};

const allReviews = await getPublishedReviews();
const otherReviews = allReviews
  .filter((entry) => entry.id !== review.id)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2)
  .map((entry) => ({
    title: entry.data.title,
    href: `${baseWithSlash}reviews/${entry.slug}/`,
    dateLabel: formatDate(entry.data.date),
    summary: clampText(entry.data.description ?? entry.data.excerpt ?? entry.body ?? '', 90),
  }));

const relatedGalleryEntries = (
  await Promise.all(
    (await getPublishedGallery()).map(async (entry) => {
      if (!entry.data.relatedReview || !hasDetailContent(entry)) return null;
      const linkedReview = await getEntry(entry.data.relatedReview);
      return linkedReview?.id === review.id ? entry : null;
    })
  )
).filter((entry): entry is CollectionEntry<'gallery'> => entry !== null);

const primaryRelatedGallery = relatedGalleryEntries[0] ?? null;
const relatedGalleryUrl = primaryRelatedGallery
  ? `${baseWithSlash}gallery/${primaryRelatedGallery.slug}/`
  : galleryListUrl;
const heroImage = infographic ?? cover ?? primaryRelatedGallery?.data.image ?? null;
const heroImageUrl = heroImage ? resolveImageUrl(heroImage) : null;
const supplementalTitle = bookTitle && bookTitle !== title ? bookTitle : null;
const hasGuidance = Boolean((recommendedFor && recommendedFor.length > 0) || (tags && tags.length > 0));
const primaryPurchaseLink = purchaseLinks?.[0] ?? null;
const hasMultiplePurchaseLinks = (purchaseLinks?.length ?? 0) > 1;
const openingPurchaseHref = hasMultiplePurchaseLinks ? '#review-purchase-shelf' : primaryPurchaseLink?.url;
const openingPurchaseLabel = hasMultiplePurchaseLinks
  ? '購入先をまとめて見る'
  : primaryPurchaseLink?.label ?? 'この本を見る';
const pageDescription = description ?? excerpt ?? `${title}のレビュー詳細`;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site!).toString();
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: pageDescription,
  image: heroImageUrl || undefined,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  author: {
    '@type': 'Organization',
    name: '読書 with Coco',
  },
  publisher: {
    '@type': 'Organization',
    name: '読書 with Coco',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
};
---

<Layout
  title={`${title} | Reviews`}
  description={pageDescription}
  image={heroImage ?? undefined}
  type="article"
  jsonLd={articleJsonLd}
>
  <section class="review-story" aria-labelledby="review-title">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href={reviewsListUrl}>Reviews</a>
      <span class="separator" aria-hidden="true">/</span>
      <span class="current" aria-current="page">{title}</span>
    </nav>

    <article class="story-shell">
      <header class="opening">
        <div class="opening-copy">
          <p class="eyebrow">Review Detail / 読後のしおり</p>

          {tags && tags.length > 0 && (
            <ul class="tags" aria-label="タグ">
              {tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
          )}

          <h1 class="title" id="review-title">{title}</h1>
          {supplementalTitle && <p class="book-title">{supplementalTitle}</p>}

          <div class="meta">
            {author && <span>著者: {author}</span>}
            <time class="date" datetime={date.toISOString()}>
              {formatDate(date)}
            </time>
          </div>

          {description && <p class="lead">{description}</p>}

          {excerpt && (
            <blockquote class="opening-quote">
              <p>“{excerpt}”</p>
            </blockquote>
          )}

          <p class="opening-note">
            言葉を追うだけで終わらせず、読み終えたあとに残る景色まで受け取れるように、
            本文の前後に静かな導線を添えました。
          </p>

          <div class="opening-actions ui-action-group ui-action-group--stack">
            <a class="primary-link ui-action" href="#review-body">本文を読む</a>
            <a class="secondary-link ui-action" href={primaryRelatedGallery ? relatedGalleryUrl : reviewsListUrl}>
              {primaryRelatedGallery ? 'この本から広がる景色へ' : '次の一冊を探す'}
            </a>
            {primaryPurchaseLink && (
              <a
                class="secondary-link ui-action"
                href={openingPurchaseHref}
                target={hasMultiplePurchaseLinks ? undefined : '_blank'}
                rel={hasMultiplePurchaseLinks ? undefined : 'noopener noreferrer nofollow'}
              >
                {openingPurchaseLabel}
              </a>
            )}
          </div>

          {hasMultiplePurchaseLinks && (
            <p class="purchase-shortcut-note">
              購入先の一覧はページ下部の Reading Shelf にまとめています。
            </p>
          )}
        </div>

        <div class="opening-visual">
          <div class="hero-media">
            {heroImage ? (
              <img
                src={withBase(heroImage)}
                alt={`${title}のレビューイメージ`}
                loading="eager"
                decoding="async"
                width="640"
                height="800"
              />
            ) : (
              <div class="hero-fallback" aria-hidden="true">
                <span>Review</span>
                <strong>{title}</strong>
              </div>
            )}
          </div>

          <aside class="companion-note" aria-labelledby="companion-title">
            <p class="companion-label">Reading Compass</p>
            <h2 id="companion-title">読みはじめる前の、ひとこと。</h2>
            <p>
              ココちゃんと一緒に歩くように、まずはこの本がどんな気分の日に寄り添うのかを先に置いておきます。
            </p>

            {recommendedFor && recommendedFor.length > 0 && (
              <ul class="companion-list">
                {recommendedFor.slice(0, 3).map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            )}
          </aside>
        </div>
      </header>

      {hasGuidance && (
        <section class="guidance" aria-labelledby="guidance-title">
          <div class="guidance-head">
            <p class="section-label">Reading Note</p>
            <h2 id="guidance-title">ページに入る前の、短い手がかり。</h2>
          </div>

          <div class="guidance-grid">
            {recommendedFor && recommendedFor.length > 0 && (
              <section class="guidance-panel" aria-labelledby="recommended-title">
                <p class="panel-kicker">For Readers</p>
                <h3 id="recommended-title">こんな人におすすめ</h3>
                <ul>
                  {recommendedFor.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </section>
            )}

            {tags && tags.length > 0 && (
              <section class="guidance-panel guidance-panel-soft" aria-labelledby="theme-title">
                <p class="panel-kicker">Themes</p>
                <h3 id="theme-title">この本の余韻に残る言葉</h3>
                <ul class="theme-list" aria-label="レビューのテーマ">
                  {tags.map((tag) => (
                    <li>{tag}</li>
                  ))}
                </ul>
              </section>
            )}
          </div>
        </section>
      )}

      <section class="body-section" id="review-body" aria-labelledby="impression-title">
        <div class="section-head">
          <div>
            <p class="section-label">Impression</p>
            <h2 id="impression-title">ことばの散歩道</h2>
          </div>
          <p class="section-copy">
            本文は読みやすさを最優先に整えています。段落ごとの呼吸を残したまま、余白と行間で静かに読ませます。
          </p>
        </div>

        <div class="body-surface">
          <div class="body">
            <Content />
          </div>
        </div>
      </section>

      <section class="afterglow" aria-labelledby="afterglow-title">
        <div class="section-head">
          <div>
            <p class="section-label">Afterglow</p>
            <h2 id="afterglow-title">言葉を読み終えたあと、景色のほうへ。</h2>
          </div>
          <p class="section-copy">
            読後の余韻をそのまま閉じずに、景色か次の一冊へゆるやかにつなぎます。
            読み終わった手の温度に合わせた、静かな終端です。
          </p>
        </div>

        <div class="afterglow-grid">
          {primaryRelatedGallery ? (
            <a class="afterglow-gallery ui-action" href={relatedGalleryUrl}>
              <div class="afterglow-gallery-media">
                <img
                  src={withBase(primaryRelatedGallery.data.image)}
                  alt={`${primaryRelatedGallery.data.title}のギャラリーイメージ`}
                  loading="lazy"
                  decoding="async"
                  width="960"
                  height="720"
                />
              </div>

              <div class="afterglow-gallery-copy">
                <p class="panel-kicker">From Review To Gallery</p>
                <h3>{primaryRelatedGallery.data.title}</h3>
                <p>
                  {primaryRelatedGallery.data.description ??
                    'この本から広がった景色を、画像のほうからもう一度たどれます。'}
                </p>
                <span>ギャラリーで景色を見る</span>
              </div>
            </a>
          ) : (
            <div class="afterglow-message">
              <p class="panel-kicker">Lingering Note</p>
              <h3>読後の景色は、まだ静かに育っています。</h3>
              <p>
                いまは言葉の余韻を中心に置いたページです。景色の展示が増えたら、この先の導線もここからつながります。
              </p>
            </div>
          )}

          <div class="afterglow-rail">
            <div class="next-step">
              <p class="panel-kicker">Next Step</p>
              <h3>次の行き先を、急がず選ぶ。</h3>
              <p>
                もう少しこの世界にいたいときはギャラリーへ。別の一冊を探したくなったらレビュー一覧へ戻れます。
              </p>

              <div class="next-links ui-action-group ui-action-group--stack">
                <a class="primary-link ui-action" href={primaryRelatedGallery ? relatedGalleryUrl : galleryListUrl}>
                  {primaryRelatedGallery ? '景色のページへ' : 'ギャラリーを見る'}
                </a>
                <a class="secondary-link ui-action" href={reviewsListUrl}>レビュー一覧へ戻る</a>
              </div>

              {otherReviews.length > 0 ? (
                <ul class="other-reviews" aria-label="関連レビュー">
                  {otherReviews.map((entry) => (
                    <li>
                      <a href={entry.href}>
                        <span>{entry.dateLabel}</span>
                        <strong>{entry.title}</strong>
                        {entry.summary && <small>{entry.summary}</small>}
                      </a>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="single-review-note">
                  現在公開中のレビューはこの一冊が中心です。一覧ページは、次の更新を迎える入口として残しています。
                </p>
              )}
            </div>

            {purchaseLinks && purchaseLinks.length > 0 && (
              <aside
                id="review-purchase-shelf"
                class="reading-shelf"
                aria-labelledby="reading-shelf-title"
                data-testid="review-purchase-shelf"
              >
                <p class="panel-kicker">Reading Shelf</p>
                <h3 id="reading-shelf-title">読み返したくなったら、この本を手元に。</h3>
                <p>
                  読後の熱がまだ残っているうちに、本そのものへ戻りたい人のための静かな棚です。
                </p>

                <div class="purchase-links ui-action-group ui-action-group--stack">
                  {purchaseLinks.map((link, index) => (
                    <a
                      class="purchase-link ui-action"
                      data-testid={index === 0 ? 'review-purchase-link' : undefined}
                      href={link.url}
                      target="_blank"
                      rel="noopener noreferrer nofollow"
                    >
                      {link.label}
                    </a>
                  ))}
                </div>

                <p class="purchase-note">外部ストアへ移動します。</p>
              </aside>
            )}
          </div>
        </div>
      </section>
    </article>
  </section>
</Layout>

<style>
  .review-story {
    max-width: 1080px;
    margin: 0 auto;
    padding: 28px 0 64px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
    color: var(--color-muted);
    font-size: 0.92rem;
  }

  .breadcrumb a {
    transition: opacity 0.2s ease;
  }

  .breadcrumb a:hover {
    opacity: 0.7;
  }

  .separator {
    opacity: 0.45;
  }

  .current {
    font-weight: 700;
    color: var(--color-text);
  }

  .story-shell {
    display: grid;
    gap: 30px;
  }

  .opening,
  .guidance,
  .body-section,
  .afterglow {
    position: relative;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(circle at top right, rgba(243, 223, 180, 0.34), transparent 32%),
      color-mix(in srgb, var(--color-surface-strong) 92%, white);
    box-shadow: var(--shadow-soft);
  }

  .opening {
    display: grid;
    gap: 30px;
    padding: clamp(1.25rem, 2vw, 2.25rem);
  }

  .opening-copy {
    display: grid;
    align-content: start;
    gap: 14px;
  }

  .eyebrow,
  .section-label,
  .panel-kicker,
  .companion-label {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .tags,
  .theme-list,
  .companion-list,
  .guidance-panel ul,
  .other-reviews {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tags li,
  .theme-list li {
    width: fit-content;
    padding: 7px 12px;
    border-radius: var(--radius-pill);
    background: rgba(141, 91, 42, 0.12);
    color: #7c4d21;
    font-size: 0.84rem;
    font-weight: 700;
  }

  .title {
    margin: 0;
    font-size: clamp(2.2rem, 4vw, 3.6rem);
    line-height: 1.05;
  }

  .book-title {
    margin: -8px 0 0;
    color: var(--color-muted);
    font-size: 1rem;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 18px;
    color: var(--color-muted);
    font-size: 0.96rem;
  }

  .lead {
    margin: 0;
    max-width: 39rem;
    font-size: clamp(1.05rem, 1vw + 0.9rem, 1.24rem);
    line-height: 1.9;
    color: rgba(32, 22, 15, 0.9);
  }

  .opening-quote {
    margin: 0;
    max-width: 38rem;
    padding: 18px 20px;
    border-left: 4px solid rgba(141, 91, 42, 0.35);
    border-radius: 0 20px 20px 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.82), rgba(243, 223, 180, 0.34));
  }

  .opening-quote p {
    margin: 0;
    font-family: var(--font-headline);
    font-size: clamp(1.02rem, 1vw + 0.88rem, 1.18rem);
    line-height: 1.8;
  }

  .opening-note {
    margin: 0;
    max-width: 38rem;
    line-height: 1.8;
    color: var(--color-muted);
  }

  .purchase-shortcut-note {
    margin: -2px 0 0;
    color: var(--color-muted);
    font-size: 0.92rem;
    line-height: 1.7;
  }

  .opening-actions,
  .next-links {
    display: flex;
    gap: 12px;
  }

  .primary-link,
  .secondary-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 12px 18px;
    border-radius: var(--radius-pill);
    font-weight: 700;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .primary-link {
    background: var(--color-text);
    color: var(--color-surface-strong);
    box-shadow: 0 14px 28px rgba(32, 22, 15, 0.18);
  }

  .secondary-link {
    border: 1px solid var(--color-border-strong);
    background: rgba(255, 255, 255, 0.72);
    color: var(--color-text);
  }

  .primary-link:hover,
  .secondary-link:hover,
  .afterglow-gallery:hover,
  .other-reviews a:hover {
    transform: translateY(-2px);
  }

  .opening-visual {
    display: grid;
    gap: 16px;
    align-content: start;
  }

  .hero-media {
    overflow: hidden;
    border-radius: calc(var(--radius-lg) - 0.3rem);
    background:
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.9), transparent 42%),
      linear-gradient(160deg, rgba(10, 74, 139, 0.08), rgba(122, 92, 23, 0.16));
  }

  .hero-media img {
    display: block;
    width: 100%;
    height: auto;
  }

  .hero-fallback {
    display: grid;
    align-content: end;
    gap: 12px;
    min-height: 340px;
    padding: 24px;
    color: #17324d;
    background:
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.85), transparent 42%),
      linear-gradient(160deg, rgba(10, 74, 139, 0.08), rgba(122, 92, 23, 0.16));
  }

  .hero-fallback span {
    width: fit-content;
    padding: 6px 10px;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.76);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-fallback strong {
    font-size: 1.8rem;
    line-height: 1.3;
  }

  .companion-note {
    display: grid;
    gap: 12px;
    padding: 18px 20px;
    border-radius: calc(var(--radius-lg) - 0.45rem);
    background:
      radial-gradient(circle at bottom right, rgba(10, 74, 139, 0.08), transparent 34%),
      rgba(250, 246, 239, 0.92);
    border: 1px solid rgba(141, 91, 42, 0.12);
  }

  .companion-note h2,
  .guidance-panel h3,
  .afterglow-gallery-copy h3,
  .afterglow-message h3,
  .next-step h3 {
    margin: 0;
    font-size: clamp(1.15rem, 1vw + 1rem, 1.5rem);
    line-height: 1.35;
  }

  .companion-note p,
  .guidance-panel li,
  .afterglow-gallery-copy p,
  .afterglow-message p,
  .next-step p,
  .section-copy,
  .single-review-note {
    margin: 0;
    line-height: 1.8;
    color: var(--color-muted);
  }

  .companion-list {
    display: grid;
    gap: 10px;
  }

  .companion-list li,
  .guidance-panel li {
    position: relative;
    padding-left: 1.1rem;
  }

  .companion-list li::before,
  .guidance-panel li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: rgba(141, 91, 42, 0.52);
  }

  .guidance,
  .body-section,
  .afterglow {
    padding: clamp(1.35rem, 2vw, 2.15rem);
  }

  .guidance {
    display: grid;
    gap: 20px;
  }

  .guidance-grid,
  .afterglow-grid {
    display: grid;
    gap: 20px;
  }

  .afterglow-rail {
    display: grid;
    gap: 14px;
    align-content: start;
  }

  .guidance-panel,
  .afterglow-message,
  .next-step,
  .reading-shelf {
    display: grid;
    gap: 10px;
    padding: 18px;
    border-radius: calc(var(--radius-lg) - 0.45rem);
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(141, 91, 42, 0.1);
  }

  .guidance-panel-soft {
    background: linear-gradient(135deg, rgba(243, 223, 180, 0.22), rgba(255, 255, 255, 0.78));
  }

  .theme-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .section-head {
    display: grid;
    gap: 12px;
    margin-bottom: 20px;
  }

  .section-head h2 {
    margin: 6px 0 0;
    font-size: clamp(1.5rem, 2vw, 2.1rem);
