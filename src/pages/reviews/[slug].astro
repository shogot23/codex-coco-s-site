---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const reviews = await getCollection('reviews');
  return reviews.map((review) => ({
    params: { slug: review.slug },
    props: { review },
  }));
}

type Props = {
  review: CollectionEntry<'reviews'>;
};

const { review } = Astro.props as Props;
const { title, description, date, cover } = review.data;
const { Content } = await review.render();

const formatDate = (value: Date) =>
  new Intl.DateTimeFormat('ja-JP', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(value);

const base = import.meta.env.BASE_URL;
const reviewsListUrl = `${base}reviews/`;

// Resolve cover image URL to absolute URL
const resolveImageUrl = (imagePath: string | undefined): string | null => {
  if (!imagePath) return null;
  // If already absolute URL, return as-is
  if (/^(?:[a-z][a-z\d+.-]*:|\/\/)/i.test(imagePath)) return imagePath;
  // Already includes base path
  if (imagePath.startsWith(base)) {
    return new URL(imagePath, Astro.site!).toString();
  }
  // Add base path and convert to absolute URL
  const normalized = imagePath.startsWith('/') ? imagePath : `/${imagePath}`;
  return new URL(`${base}${normalized.replace(/^\/+/, '')}`, Astro.site!).toString();
};

const coverImageUrl = resolveImageUrl(cover);

// Build Article JSON-LD structured data
const canonicalUrl = new URL(Astro.url.pathname, Astro.site!).toString();
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description || '',
  image: coverImageUrl || undefined,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  author: {
    '@type': 'Organization',
    name: '読書 with Coco',
  },
  publisher: {
    '@type': 'Organization',
    name: '読書 with Coco',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
};
---

<Layout
  title={`${title} | Reviews`}
  description={description}
  image={coverImageUrl ?? undefined}
  type="article"
  jsonLd={articleJsonLd}
>
  <section class="review-detail" aria-labelledby="review-title">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href={reviewsListUrl}>Reviews</a>
      <span class="separator" aria-hidden="true">/</span>
      <span class="current" aria-current="page">{title}</span>
    </nav>

    <article class="article">
      <header class="header">
        <h1 class="title" id="review-title">{title}</h1>
        {description && <p class="description">{description}</p>}
        <time class="date" datetime={date.toISOString()}>
          {formatDate(date)}
        </time>
      </header>

      {coverImageUrl && (
        <div class="cover">
          <img src={coverImageUrl} alt={title} loading="lazy" decoding="async" width="800" height="450" />
        </div>
      )}

      <div class="body">
        <Content />
      </div>
    </article>

    <nav class="back-nav">
      <a href={reviewsListUrl}>レビュー一覧へ戻る</a>
    </nav>
  </section>
</Layout>

<style>
  .review-detail {
    max-width: 720px;
    margin: 0 auto;
    padding: 32px 16px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    margin-bottom: 24px;
    opacity: 0.85;
  }

  .breadcrumb a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .breadcrumb a:hover {
    opacity: 0.7;
    text-decoration: underline;
  }

  .breadcrumb .separator {
    opacity: 0.5;
  }

  .breadcrumb .current {
    font-weight: 600;
  }

  .article {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.04);
  }

  .header {
    margin-bottom: 20px;
  }

  .title {
    margin: 0 0 12px;
    font-size: 1.75rem;
    line-height: 1.3;
  }

  .description {
    margin: 0 0 12px;
    opacity: 0.85;
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .date {
    display: block;
    font-size: 0.9rem;
    opacity: 0.7;
  }

  .cover {
    margin: 20px 0;
    border-radius: 12px;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.04);
  }

  .cover img {
    width: 100%;
    height: auto;
    display: block;
  }

  .body {
    line-height: 1.8;
    font-size: 1rem;
  }

  .body :global(h1),
  .body :global(h2),
  .body :global(h3),
  .body :global(h4) {
    margin: 1.5em 0 0.5em;
    line-height: 1.4;
  }

  .body :global(h2) {
    font-size: 1.4rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    padding-bottom: 8px;
  }

  .body :global(h3) {
    font-size: 1.2rem;
  }

  .body :global(p) {
    margin: 1em 0;
  }

  .body :global(ul),
  .body :global(ol) {
    margin: 1em 0;
    padding-left: 1.5em;
  }

  .body :global(li) {
    margin: 0.5em 0;
  }

  .body :global(blockquote) {
    margin: 1em 0;
    padding: 12px 16px;
    border-left: 4px solid rgba(0, 0, 0, 0.15);
    background: rgba(0, 0, 0, 0.03);
    border-radius: 0 8px 8px 0;
  }

  .body :global(code) {
    background: rgba(0, 0, 0, 0.06);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .body :global(pre) {
    margin: 1em 0;
    padding: 16px;
    background: rgba(0, 0, 0, 0.05);
    border-radius: 8px;
    overflow-x: auto;
  }

  .body :global(pre code) {
    background: none;
    padding: 0;
  }

  .body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }

  .back-nav {
    margin-top: 32px;
    text-align: center;
  }

  .back-nav a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 20px;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 600;
    color: inherit;
    text-decoration: none;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .back-nav a:hover {
    background: rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }

  @media (max-width: 600px) {
    .review-detail {
      padding: 20px 12px;
    }

    .article {
      padding: 18px;
      border-radius: 12px;
    }

    .title {
      font-size: 1.5rem;
    }
  }
</style>
