---
import Layout from '../../layouts/Layout.astro';
import { type CollectionEntry } from 'astro:content';
import { getPublishedReviews } from '../../utils/reviews';

export async function getStaticPaths() {
  const reviews = await getPublishedReviews();
  return reviews.map((review) => ({
    params: { slug: review.slug },
    props: { review },
  }));
}

type Props = {
  review: CollectionEntry<'reviews'>;
};

const { review } = Astro.props as Props;
const { title, description, date, cover, bookTitle, author, tags, infographic, recommendedFor } = review.data;
const { Content } = await review.render();

const formatDate = (value: Date) =>
  new Intl.DateTimeFormat('ja-JP', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  }).format(value);

const base = import.meta.env.BASE_URL;
const baseWithSlash = base.endsWith('/') ? base : `${base}/`;
const reviewsListUrl = `${baseWithSlash}reviews/`;

const isAbsoluteUrl = (value: string) =>
  /^(?:[a-z][a-z\d+.-]*:|\/\/)/i.test(value);

const withBase = (assetPath: string) => {
  if (!assetPath) return baseWithSlash;
  if (isAbsoluteUrl(assetPath)) return assetPath;
  if (assetPath.startsWith(baseWithSlash)) return assetPath;
  return `${baseWithSlash}${assetPath.replace(/^\/+/, '')}`;
};

// Resolve cover image URL to absolute URL
const resolveImageUrl = (imagePath: string | undefined): string | null => {
  if (!imagePath) return null;
  if (isAbsoluteUrl(imagePath)) return imagePath;
  if (imagePath.startsWith(baseWithSlash)) {
    return new URL(imagePath, Astro.site!).toString();
  }
  const normalized = imagePath.startsWith('/') ? imagePath : `/${imagePath}`;
  return new URL(`${baseWithSlash}${normalized.replace(/^\/+/, '')}`, Astro.site!).toString();
};

const heroImage = infographic ?? cover;
const heroImageUrl = resolveImageUrl(heroImage);
const supplementalTitle = bookTitle && bookTitle !== title ? bookTitle : null;

// Build Article JSON-LD structured data
const canonicalUrl = new URL(Astro.url.pathname, Astro.site!).toString();
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description || '',
  image: heroImageUrl || undefined,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  author: {
    '@type': 'Organization',
    name: '読書 with Coco',
  },
  publisher: {
    '@type': 'Organization',
    name: '読書 with Coco',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
};
---

<Layout
  title={`${title} | Reviews`}
  description={description}
  image={heroImage ?? undefined}
  type="article"
  jsonLd={articleJsonLd}
>
  <section class="review-detail" aria-labelledby="review-title">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href={reviewsListUrl}>Reviews</a>
      <span class="separator" aria-hidden="true">/</span>
      <span class="current" aria-current="page">{title}</span>
    </nav>

    <article class="article">
      <header class="hero">
        <div class="hero-media">
          {heroImage ? (
            <img
              src={withBase(heroImage)}
              alt={`${title}のインフォグラフィック`}
              loading="eager"
              decoding="async"
              width="412"
              height="512"
            />
          ) : (
            <div class="hero-fallback" aria-hidden="true">
              <span>Review</span>
              <strong>{title}</strong>
            </div>
          )}
        </div>

        <div class="hero-copy">
          {tags && tags.length > 0 && (
            <ul class="tags" aria-label="タグ">
              {tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
          )}

          <h1 class="title" id="review-title">{title}</h1>
          {supplementalTitle && <p class="book-title">{supplementalTitle}</p>}

          <div class="meta">
            {author && <span>著者: {author}</span>}
            <time class="date" datetime={date.toISOString()}>
              {formatDate(date)}
            </time>
          </div>

          {description && <p class="description">{description}</p>}
        </div>
      </header>

      {recommendedFor && recommendedFor.length > 0 && (
        <section class="recommendation" aria-labelledby="recommended-title">
          <h2 id="recommended-title">おすすめしたい人</h2>
          <ul>
            {recommendedFor.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      )}

      <section class="body-section" aria-labelledby="impression-title">
        <h2 id="impression-title">感想</h2>
        <div class="body">
          <Content />
        </div>
      </section>
    </article>

    <nav class="back-nav">
      <a href={reviewsListUrl}>レビュー一覧へ戻る</a>
    </nav>
  </section>
</Layout>

<style>
  .review-detail {
    max-width: 720px;
    margin: 0 auto;
    padding: 32px 16px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    margin-bottom: 24px;
    opacity: 0.85;
  }

  .breadcrumb a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .breadcrumb a:hover {
    opacity: 0.7;
    text-decoration: underline;
  }

  .breadcrumb .separator {
    opacity: 0.5;
  }

  .breadcrumb .current {
    font-weight: 600;
  }

  .article {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 18px;
    padding: 22px;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.05);
  }

  .hero {
    display: grid;
    gap: 22px;
    align-items: start;
  }

  .hero-media {
    overflow: hidden;
    border-radius: 14px;
    background: linear-gradient(160deg, rgba(10, 74, 139, 0.08), rgba(122, 92, 23, 0.14));
  }

  .hero-media img {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero-fallback {
    display: grid;
    align-content: end;
    gap: 12px;
    min-height: 340px;
    padding: 24px;
    color: #17324d;
    background:
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.85), transparent 42%),
      linear-gradient(160deg, rgba(10, 74, 139, 0.08), rgba(122, 92, 23, 0.16));
  }

  .hero-fallback span {
    width: fit-content;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.76);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-fallback strong {
    font-size: 1.8rem;
    line-height: 1.3;
  }

  .hero-copy {
    display: grid;
    align-content: start;
    gap: 14px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tags li {
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(10, 74, 139, 0.08);
    color: #0a4a8b;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .title {
    margin: 0;
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    line-height: 1.25;
  }

  .book-title {
    margin: -6px 0 0;
    font-size: 1rem;
    color: rgba(17, 17, 17, 0.72);
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 16px;
    font-size: 0.92rem;
    color: rgba(17, 17, 17, 0.68);
  }

  .description {
    margin: 0;
    opacity: 0.85;
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .recommendation,
  .body-section {
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .recommendation h2,
  .body-section h2 {
    margin: 0;
    font-size: 1.15rem;
  }

  .recommendation ul {
    display: grid;
    gap: 12px;
    margin: 16px 0 0;
    padding-left: 1.2em;
  }

  .recommendation li {
    line-height: 1.7;
  }

  .body {
    margin-top: 16px;
    line-height: 1.8;
    font-size: 1rem;
  }

  .body :global(h1),
  .body :global(h2),
  .body :global(h3),
  .body :global(h4) {
    margin: 1.5em 0 0.5em;
    line-height: 1.4;
  }

  .body :global(h3) {
    font-size: 1.2rem;
  }

  .body :global(p) {
    margin: 1em 0;
  }

  .body :global(ul),
  .body :global(ol) {
    margin: 1em 0;
    padding-left: 1.5em;
  }

  .body :global(li) {
    margin: 0.5em 0;
  }

  .body :global(blockquote) {
    margin: 1em 0;
    padding: 12px 16px;
    border-left: 4px solid rgba(0, 0, 0, 0.15);
    background: rgba(0, 0, 0, 0.03);
    border-radius: 0 8px 8px 0;
  }

  .body :global(code) {
    background: rgba(0, 0, 0, 0.06);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .body :global(pre) {
    margin: 1em 0;
    padding: 16px;
    background: rgba(0, 0, 0, 0.05);
    border-radius: 8px;
    overflow-x: auto;
  }

  .body :global(pre code) {
    background: none;
    padding: 0;
  }

  .body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }

  .back-nav {
    margin-top: 32px;
    text-align: center;
  }

  .back-nav a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 20px;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 600;
    color: inherit;
    text-decoration: none;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .back-nav a:hover {
    background: rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }

  @media (max-width: 600px) {
    .review-detail {
      padding: 20px 12px;
    }

    .article {
      padding: 18px;
      border-radius: 12px;
    }
  }

  @media (min-width: 860px) {
    .hero {
      grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.95fr);
    }
  }
</style>
