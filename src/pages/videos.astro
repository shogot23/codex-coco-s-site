---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const videoEntries = await getCollection("videos");
const baseWithSlash = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const reviewsUrl = `${baseWithSlash}reviews/`;
const galleryUrl = `${baseWithSlash}gallery/`;

const fragmentNotes = [
  "読書を閉じた直後に残る、まだ名前のつかない空気をつかまえる断片です。",
  "言葉より少し遅れてやってくる気配を、ココちゃんの歩幅で見返すための断片です。",
  "レビューとギャラリーのあいだで揺れていた感情を、静かに整えるための断片です。",
];

const videos = [...videoEntries]
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((entry, index) => ({
    title: entry.data.title,
    thumbnail: entry.data.thumbnail,
    url: entry.data.url,
    note: fragmentNotes[index % fragmentNotes.length],
    sequence: `Fragment ${String(index + 1).padStart(2, "0")}`,
  }));

// Helper to extract YouTube video ID from URL using URL API
function getYouTubeId(urlString: string): string | null {
  try {
    const url = new URL(urlString);
    // Check host is YouTube
    if (!['youtube.com', 'www.youtube.com', 'youtu.be'].includes(url.hostname)) {
      return null;
    }
    // youtu.be short URL
    if (url.hostname === 'youtu.be') {
      const id = url.pathname.slice(1);
      if (/^[a-zA-Z0-9_-]{11}$/.test(id)) return id;
      return null;
    }
    // youtube.com - check for watch or embed
    if (url.pathname.startsWith('/embed/')) {
      const id = url.pathname.slice(7);
      if (/^[a-zA-Z0-9_-]{11}$/.test(id)) return id;
    }
    const v = url.searchParams.get('v');
    if (v && /^[a-zA-Z0-9_-]{11}$/.test(v)) return v;
    return null;
  } catch {
    return null;
  }
}

// Helper to extract Instagram post ID from URL using URL API
function getInstagramId(urlString: string): string | null {
  try {
    const url = new URL(urlString);
    // Check host is Instagram
    if (!['instagram.com', 'www.instagram.com'].includes(url.hostname)) {
      return null;
    }
    // Check for /p/ or /reel/ path
    const pathMatch = url.pathname.match(/^\/(p|reel)\/([a-zA-Z0-9_-]+)/);
    if (pathMatch) return pathMatch[2];
    return null;
  } catch {
    return null;
  }
}

// Determine embed type
function getEmbedInfo(url: string | undefined): { type: "youtube" | "instagram" | "none"; id: string | null } {
  if (!url) return { type: "none", id: null };
  const ytId = getYouTubeId(url);
  if (ytId) return { type: "youtube", id: ytId };
  const igId = getInstagramId(url);
  if (igId) return { type: "instagram", id: igId };
  return { type: "none", id: null };
}
---

<Layout
  title="Moving Fragments | 読書 with Coco"
  description="レビューとギャラリーを読み終えたあとにだけ開く、読後の余韻を少しだけ動かした断片の部屋。"
>
  <div class="fragments-shell">
    <section class="hero" aria-labelledby="videos-page-title">
      <div class="hero-copy">
        <p class="eyebrow">Moving Fragments</p>
        <h1 id="videos-page-title">読後の余韻を、少しだけ動かして置いておく。</h1>
        <p class="lead">
          ここは動画ライブラリではありません。レビューで言葉を受け取り、ギャラリーで景色を見たあとにだけ、
          読書の空気が動いた瞬間をそっと見返すための小さな補助室です。
        </p>
        <p class="quiet-note">
          主役へ戻りたくなったら <a href={reviewsUrl}>Reviews</a>、景色の続きが見たくなったら
          <a href={galleryUrl}>Gallery</a> へ。
        </p>

        <div class="hero-actions ui-action-group ui-action-group--stack">
          <a class="hero-link hero-link-primary ui-action" href={reviewsUrl}>レビューへ戻る</a>
          <a class="hero-link hero-link-secondary ui-action" href={galleryUrl}>ギャラリーへ寄る</a>
        </div>
      </div>

      <aside class="hero-aside">
        <p class="aside-label">Role</p>
        <p>
          ここに並ぶのは作品一覧ではなく、読後に残った呼吸の断片です。更新は少なくてよく、
          必要なときだけ静かに増えていけば十分です。
        </p>
      </aside>
    </section>

    <section class="fragments-list" aria-labelledby="fragments-list-title">
      <div class="section-head">
        <p class="section-label">Quiet Shelf</p>
        <h2 id="fragments-list-title">動きは主張ではなく、余韻の補助線として置いておく。</h2>
      </div>

      <div class="stack">
        {videos.map((v) => {
          const embed = getEmbedInfo(v.url);
          return (
            <article class="fragment-card">
              <div class="fragment-copy">
                <p class="fragment-sequence">{v.sequence}</p>
                <h3>{v.title}</h3>
                <p class="fragment-note">{v.note}</p>
              </div>

              <div class="fragment-media">
                {embed.type === "youtube" && embed.id ? (
                  <iframe
                    src={`https://www.youtube.com/embed/${embed.id}`}
                    title={v.title}
                    loading="lazy"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                  />
                ) : embed.type === "instagram" && embed.id ? (
                  <iframe
                    src={`https://www.instagram.com/p/${embed.id}/embed`}
                    title={v.title}
                    loading="lazy"
                  />
                ) : (
                  <img src={v.thumbnail} alt={v.title} loading="lazy" decoding="async" width="800" height="520" />
                )}
              </div>
            </article>
          );
        })}
      </div>
    </section>
  </div>
</Layout>

<style>
  .fragments-shell {
    width: min(100%, 980px);
    margin-inline: auto;
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    padding-bottom: clamp(1rem, 2vw, 2rem);
  }

  .hero,
  .fragments-list {
    position: relative;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(260px, 0.8fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    padding: clamp(1.8rem, 4vw, 3rem);
    border-radius: 32px;
    background:
      radial-gradient(circle at top left, rgba(249, 235, 205, 0.9), transparent 34%),
      linear-gradient(140deg, rgba(255, 250, 243, 0.98), rgba(235, 241, 247, 0.94));
    border: 1px solid rgba(113, 84, 44, 0.16);
    box-shadow: 0 26px 68px rgba(70, 50, 29, 0.12);
  }

  .hero-copy,
  .hero-aside {
    position: relative;
    z-index: 1;
  }

  .eyebrow,
  .section-label,
  .aside-label,
  .fragment-sequence {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7a5c17;
  }

  h1,
  h2,
  h3 {
    margin: 0;
  }

  h1 {
    margin-top: 0.45rem;
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 1.08;
  }

  .lead,
  .quiet-note,
  .hero-aside p,
  .fragment-note {
    margin: 0;
    color: var(--color-muted);
    line-height: 1.7;
  }

  .lead {
    margin-top: 1rem;
    max-width: 42rem;
  }

  .quiet-note {
    margin-top: 1rem;
  }

  .quiet-note a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .hero-actions {
    margin-top: 1.4rem;
  }

  .hero-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    min-height: 48px;
    padding: 0.85rem 1.2rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    transition: transform 0.24s ease, box-shadow 0.24s ease, background-color 0.24s ease;
  }

  .hero-link:hover {
    transform: translateY(-1px);
  }

  .hero-link-primary {
    background: #1d3a66;
    color: #fffaf2;
    box-shadow: 0 14px 30px rgba(29, 58, 102, 0.22);
  }

  .hero-link-secondary {
    border: 1px solid rgba(29, 58, 102, 0.18);
    background: rgba(255, 255, 255, 0.62);
    color: var(--color-text);
  }

  .hero-aside {
    align-self: end;
    padding: 1.2rem 1.3rem;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.58);
    border: 1px solid rgba(120, 90, 50, 0.14);
  }

  .hero-aside p {
    margin-top: 0.7rem;
  }

  .section-head {
    display: grid;
    gap: 0.6rem;
    max-width: 44rem;
    margin-bottom: 1.4rem;
  }

  .section-head h2 {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    line-height: 1.16;
  }

  .stack {
    display: grid;
    gap: 1.2rem;
  }

  .fragment-card {
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(280px, 1.12fr);
    gap: clamp(1rem, 3vw, 1.6rem);
    align-items: stretch;
    padding: clamp(1rem, 3vw, 1.35rem);
    border-radius: 28px;
    background: rgba(255, 253, 248, 0.9);
    border: 1px solid rgba(122, 92, 23, 0.14);
    box-shadow: 0 16px 42px rgba(52, 41, 28, 0.08);
  }

  .fragment-copy {
    display: grid;
    align-content: start;
    gap: 0.9rem;
    padding: 0.4rem;
  }

  .fragment-copy h3 {
    font-size: clamp(1.35rem, 2.5vw, 2rem);
    line-height: 1.2;
  }

  .fragment-media {
    overflow: hidden;
    min-height: 240px;
    border-radius: 22px;
    background: rgba(13, 24, 43, 0.08);
  }

  .fragment-media img,
  .fragment-media iframe {
    width: 100%;
    height: 100%;
    border: none;
    object-fit: cover;
  }

  @media (max-width: 820px) {
    .hero,
    .fragment-card {
      grid-template-columns: minmax(0, 1fr);
    }

    .hero-aside {
      align-self: start;
    }
  }
</style>
