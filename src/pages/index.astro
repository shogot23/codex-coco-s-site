---
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import { getPublishedGallery, hasDetailContent } from '../utils/gallery';
import { getPublishedReviews } from '../utils/reviews';

const BASE_URL = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const isAbsoluteUrl = (value: string) =>
  /^(?:[a-z][a-z\d+.-]*:|\/\/)/i.test(value);

const withBase = (path: string) => {
  if (!path) return BASE_URL;
  if (isAbsoluteUrl(path)) return path;
  if (path.startsWith(BASE_URL)) return path;
  return `${BASE_URL}${path.replace(/^\/+/, '')}`;
};

const publicDir = join(process.cwd(), 'public');

const resolvePublicAsset = (assetPath: string, fallback: string) => {
  if (!assetPath) return fallback;
  if (isAbsoluteUrl(assetPath)) return assetPath;

  const normalized = assetPath.startsWith('/') ? assetPath : `/${assetPath}`;
  const localPath = join(publicDir, normalized.replace(/^\/+/, ''));
  return existsSync(localPath) ? withBase(normalized) : fallback;
};

const clampText = (value: string, maxLength: number) => {
  const normalized = value.replace(/\s+/g, ' ').trim();
  if (!normalized) return '';
  if (normalized.length <= maxLength) return normalized;
  return `${normalized.slice(0, maxLength).trimEnd()}…`;
};

const stripMarkdown = (value: string) =>
  value
    .replace(/^#{1,6}\s+/gm, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[*_`>-]/g, '')
    .replace(/\n{3,}/g, '\n\n')
    .trim();

const getParagraphs = (value: string) =>
  stripMarkdown(value)
    .split(/\n\s*\n/)
    .map((paragraph) => paragraph.replace(/\s*\n\s*/g, ' ').trim())
    .filter(Boolean);

const reviewDetailRoutePath = join(process.cwd(), 'src/pages/reviews/[slug].astro');
const hasReviewDetailRoute = existsSync(reviewDetailRoutePath);

const formatReviewDate = (value: Date) =>
  new Intl.DateTimeFormat('ja-JP', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC',
  }).format(value);

const reviewsUrl = withBase('reviews/');
const galleryUrl = withBase('gallery/');
const aboutUrl = withBase('about/');
const profileUrl = withBase('profile/');

const getHomeReviewImage = (cover?: string, infographic?: string) =>
  resolvePublicAsset(cover ?? infographic ?? '', previewFallbackImage);

let avatar = '/uploads/img_6088.png';

try {
  const entry = await getEntry('profile', 'profile');
  avatar = entry?.data?.avatar ?? avatar;
} catch {
  // Profile content is optional during local content setup.
}

const avatarUrl = withBase(avatar);
const previewFallbackImage = resolvePublicAsset('/uploads/img_6088.png', avatarUrl);

let aboutEntry = null;

try {
  aboutEntry = await getEntry('about', 'about');
} catch {
  // About content is optional during local content setup.
}
const aboutParagraphs = aboutEntry ? getParagraphs(aboutEntry.body) : [];

const reviewEntries = await getPublishedReviews();
const sortedReviews = [...reviewEntries].sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime() || a.slug.localeCompare(b.slug)
);
const featuredReviewEntry = sortedReviews[0];
const supportingReviewEntries = sortedReviews.slice(1, 3);

const featuredReview = featuredReviewEntry
  ? {
      title: featuredReviewEntry.data.title,
      bookTitle: featuredReviewEntry.data.bookTitle ?? featuredReviewEntry.data.title,
      author: featuredReviewEntry.data.author,
      summary: clampText(
        featuredReviewEntry.data.description ??
          featuredReviewEntry.data.excerpt ??
          featuredReviewEntry.body ??
          '',
        140
      ),
      excerpt: clampText(
        featuredReviewEntry.data.excerpt ?? featuredReviewEntry.body ?? '',
        84
      ),
      dateLabel: formatReviewDate(featuredReviewEntry.data.date),
      image: getHomeReviewImage(featuredReviewEntry.data.cover, featuredReviewEntry.data.infographic),
      href: hasReviewDetailRoute
        ? withBase(`reviews/${featuredReviewEntry.id.replace(/\.md$/, '')}/`)
        : reviewsUrl,
      linkLabel: hasReviewDetailRoute ? 'このレビューを読む' : 'レビュー一覧へ',
      tags: featuredReviewEntry.data.tags ?? [],
      recommendedFor: featuredReviewEntry.data.recommendedFor ?? [],
      purchaseLinks: featuredReviewEntry.data.purchaseLinks ?? [],
    }
  : null;

const supportingReviews = supportingReviewEntries.map((entry) => ({
  title: entry.data.title,
  dateLabel: formatReviewDate(entry.data.date),
  href: hasReviewDetailRoute ? withBase(`reviews/${entry.id.replace(/\.md$/, '')}/`) : reviewsUrl,
}));

const galleryEntries = await getPublishedGallery();
const getGalleryTimestamp = (generatedAt?: string) => {
  if (!generatedAt) return 0;
  const timestamp = Date.parse(generatedAt);
  return Number.isNaN(timestamp) ? 0 : timestamp;
};

const galleryHighlights = [...galleryEntries]
  .sort((a, b) => getGalleryTimestamp(b.data.generated_at) - getGalleryTimestamp(a.data.generated_at))
  .slice(0, 3)
  .map((entry) => ({
    title: entry.data.title,
    author: entry.data.author,
    description: clampText(
      entry.data.description ?? entry.data.note ?? `${entry.data.genre ?? '読書'}の情景`,
      90
    ),
    image: resolvePublicAsset(entry.data.image, previewFallbackImage),
    href: hasDetailContent(entry) ? withBase(`gallery/${entry.slug}/`) : galleryUrl,
  }));

const heroPostcards = galleryHighlights.slice(0, 2);
const galleryLead = galleryHighlights[0] ?? null;
const galleryTrail = galleryHighlights.slice(1, 3);

const videoEntries = await getCollection('videos');
const publishedVideoCount = videoEntries.length;

const supportItems = [
  {
    label: 'Review',
    title: '読後の手ざわりを、言葉で残す。',
    body: '本を閉じたあとに残る感情や学びを、短く深くたどる主導線です。',
  },
  {
    label: 'Gallery',
    title: '読書からこぼれた景色を、そっと見返す。',
    body: '気になった一冊の空気を、ココちゃんと一緒にビジュアルで確かめます。',
  },
  {
    label: 'Fragments',
    title: '余韻が動いた瞬間だけ、静かな断片として残す。',
    body: `${publishedVideoCount}本の動くメモは、レビューとギャラリーを読み終えたあとにだけ、そっと開ける補助室です。`,
  },
];

const aboutLead =
  aboutParagraphs[0] ??
  '読書 with Coco は、本を読み終えたあとに静かに残る気配を、もう一度見つめ直すための場所です。';
const aboutBridge =
  aboutParagraphs[1] ??
  '読んで終わりにしない。本のそばにココちゃんがいることで、言葉だけでは届かない景色や学びに、やわらかな呼吸を与えます。';
const worldAsideCopy =
  'ココちゃんは、このサイトで読後の景色をやわらかく見つめ直すための案内役です。';
---

<Layout
  title="読書 with Coco - 読書で生まれた世界を、ココちゃんが旅する"
  description="レビューを主導線に、ギャラリーと静かな断片で読書の余韻を深める『読書 with Coco』のトップページ。"
  image={avatarUrl}
>
  <div class="home-story">
    <section class="hero" aria-labelledby="home-hero-heading">
      <div class="hero-copy">
        <p class="hero-kicker">本 × ココちゃん × 学び</p>
        <p class="hero-brand">読書 with Coco</p>
        <h1 id="home-hero-heading">読書で生まれた世界を、ココちゃんが旅する。</h1>
        <p class="hero-lead">
          一冊の余韻をレビューで言葉に、ギャラリーで景色に。読み終えたあとにもう一度ひらく、
          静かな読書の入口です。
        </p>

        <div class="hero-actions ui-action-group ui-action-group--stack">
          <a class="hero-button hero-button-primary ui-action" href={reviewsUrl}>レビューを見る</a>
          <a class="hero-button hero-button-secondary ui-action" href={galleryUrl}>ギャラリーを見る</a>
        </div>

        {featuredReview && (
          <p class="hero-note">
            今ひらける一冊は <span>{featuredReview.title}</span>。まずは言葉の窓からどうぞ。
          </p>
        )}
      </div>

      <section class="hero-visual" aria-label="ココちゃんと読書の世界">
        <div class="hero-visual-stage">
          <div class="hero-orbit hero-orbit-left">
            {heroPostcards[0] && (
              <figure class="hero-postcard">
                <img
                  src={heroPostcards[0].image}
                  alt={`${heroPostcards[0].title}のギャラリーイメージ`}
                  loading="lazy"
                  decoding="async"
                  width="232"
                  height="232"
                />
                <figcaption>{heroPostcards[0].title}</figcaption>
              </figure>
            )}
          </div>

          <figure class="hero-portrait">
            <img
              class="hero-avatar"
              src={avatarUrl}
              alt="読書 with Coco の案内役、ココちゃん"
              width="560"
              height="560"
              loading="eager"
              decoding="async"
            />
            <figcaption>読書の余韻を案内する、ココちゃん</figcaption>
          </figure>

          <div class="hero-orbit hero-orbit-right">
            {heroPostcards[1] && (
              <figure class="hero-postcard hero-postcard-tilt">
                <img
                  src={heroPostcards[1].image}
                  alt={`${heroPostcards[1].title}のギャラリーイメージ`}
                  loading="lazy"
                  decoding="async"
                  width="232"
                  height="232"
                />
                <figcaption>{heroPostcards[1].title}</figcaption>
              </figure>
            )}
          </div>
        </div>
      </section>
    </section>

    <section class="support-section" aria-labelledby="support-heading">
      <div class="section-intro">
        <p class="section-label">Three Quiet Windows</p>
        <h2 id="support-heading">一冊の余韻を、三つの窓でひらく。</h2>
        <p>
          主役はいつもレビューです。そのまわりでギャラリーと静かな断片が、本から広がった景色をそっと支えます。
        </p>
      </div>

      <div class="support-list">
        {supportItems.map((item, index) => (
          <article class="support-item">
            <p class="support-index">{String(index + 1).padStart(2, '0')}</p>
            <div class="support-body">
              <p class="support-label">{item.label}</p>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="reviews-section" aria-labelledby="featured-reviews-heading">
      <div class="section-head">
        <div>
          <p class="section-label">Featured Reviews</p>
          <h2 id="featured-reviews-heading">まずは、言葉の入口から。</h2>
        </div>
        <a class="section-link ui-action" href={reviewsUrl}>レビュー一覧へ</a>
      </div>

      {featuredReview ? (
        <div class="review-feature">
          <div class="review-image-wrap">
            <img
              class="review-image"
              src={featuredReview.image}
              alt={`${featuredReview.title}のレビューイメージ`}
              loading="lazy"
              decoding="async"
              width="720"
              height="920"
            />
          </div>

          <div class="review-copy">
            <p class="review-date">{featuredReview.dateLabel}</p>
            <h3>{featuredReview.title}</h3>
            {featuredReview.author && <p class="review-author">著者: {featuredReview.author}</p>}
            <p class="review-summary">{featuredReview.summary}</p>
            <blockquote>{featuredReview.excerpt}</blockquote>

            {featuredReview.tags.length > 0 && (
              <ul class="review-tags" aria-label="注目レビューのタグ">
                {featuredReview.tags.map((tag) => (
                  <li>{tag}</li>
                ))}
              </ul>
            )}

            {featuredReview.recommendedFor.length > 0 && (
              <div class="review-for">
                <p class="review-for-label">こんな読後感が好きな人へ</p>
                <ul>
                  {featuredReview.recommendedFor.slice(0, 3).map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            )}

            <div class="review-actions ui-action-group ui-action-group--stack">
              <a class="inline-button inline-button-primary ui-action" href={featuredReview.href}>
                {featuredReview.linkLabel}
              </a>
              <a class="inline-button inline-button-secondary ui-action" href={reviewsUrl}>
                すべてのレビューを見る
              </a>
              {featuredReview.purchaseLinks.length > 0 && (
                <a
                  class="inline-button inline-button-secondary ui-action"
                  href={featuredReview.purchaseLinks[0].url}
                  target="_blank"
                  rel="noopener noreferrer nofollow"
                >
                  この本を見る
                </a>
              )}
            </div>
          </div>
        </div>
      ) : (
        <p class="empty-state">レビューは準備中です。最初の一冊が公開されるまで、しばらくお待ちください。</p>
      )}

      {supportingReviews.length > 0 && (
        <div class="review-rail" aria-label="最近のレビュー">
          {supportingReviews.map((review) => (
            <a class="review-rail-item ui-action" href={review.href}>
              <span>{review.dateLabel}</span>
              <strong>{review.title}</strong>
            </a>
          ))}
        </div>
      )}
    </section>

    <section class="gallery-section" aria-labelledby="featured-gallery-heading">
      <div class="section-head">
        <div>
          <p class="section-label">Featured Gallery</p>
          <h2 id="featured-gallery-heading">景色は、副旋律として寄り添う。</h2>
        </div>
        <a class="section-link ui-action" href={galleryUrl}>ギャラリー一覧へ</a>
      </div>

      {galleryLead ? (
        <div class="gallery-feature">
          <a class="gallery-lead ui-action" href={galleryLead.href}>
            <div class="gallery-lead-media">
              <img
                src={galleryLead.image}
                alt={`${galleryLead.title}のギャラリーイメージ`}
                loading="lazy"
                decoding="async"
                width="980"
                height="720"
              />
            </div>
            <div class="gallery-lead-copy">
              <p class="gallery-kicker">Gallery Lead</p>
              <h3>{galleryLead.title}</h3>
              {galleryLead.author && <p class="gallery-author">{galleryLead.author}</p>}
              <p>{galleryLead.description}</p>
            </div>
          </a>

          <div class="gallery-trail">
            {galleryTrail.map((item) => (
              <a class="gallery-trail-item ui-action" href={item.href}>
                <div class="gallery-trail-media">
                  <img
                    src={item.image}
                    alt={`${item.title}のギャラリーイメージ`}
                    loading="lazy"
                    decoding="async"
                    width="420"
                    height="320"
                  />
                </div>
                <div class="gallery-trail-copy">
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      ) : (
        <p class="empty-state">ギャラリーは準備中です。</p>
      )}
    </section>

    <section class="world-bridge" aria-labelledby="world-bridge-heading">
      <div class="world-copy">
        <p class="section-label">About / World Bridge</p>
        <h2 id="world-bridge-heading">このサイトの心臓部を、静かにのぞく。</h2>
        <p>{aboutLead}</p>
        <p>{aboutBridge}</p>
      </div>

      <aside class="world-aside">
        <p class="world-aside-label">Coco&apos;s Note</p>
        <p class="world-aside-copy">{worldAsideCopy}</p>
        <div class="world-links ui-action-group ui-action-group--stack">
          <a class="inline-button inline-button-secondary ui-action" href={aboutUrl}>About をひらく</a>
          <a class="inline-button inline-button-secondary ui-action" href={profileUrl}>ココちゃんの紹介へ</a>
        </div>
      </aside>
    </section>

    <section class="final-cta" aria-labelledby="final-cta-heading">
      <p class="section-label">Final CTA</p>
      <h2 id="final-cta-heading">次にひらくのは、言葉の景色。</h2>
      <p>
        入口はレビューです。気になった一冊の余韻を言葉でたどり、景色はそのあとにそっと寄り道できます。
      </p>
      <div class="final-actions ui-action-group ui-action-group--stack">
        <a class="hero-button hero-button-primary ui-action" href={reviewsUrl}>レビューを見る</a>
        <a class="hero-button hero-button-secondary ui-action" href={galleryUrl}>ギャラリーを見る</a>
      </div>
    </section>
  </div>

  <style>
    .home-story {
      display: grid;
      gap: clamp(2.25rem, 5vw, 4.6rem);
      padding-bottom: clamp(1rem, 2vw, 2rem);
    }

    .hero,
    .support-section,
    .reviews-section,
    .gallery-section,
    .world-bridge,
    .final-cta {
      position: relative;
    }

    .hero {
      overflow: clip;
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
      gap: clamp(2rem, 4vw, 4rem);
      align-items: center;
      padding: clamp(1.75rem, 4.4vw, 3.3rem);
      border-radius: clamp(28px, 4vw, 44px);
      background:
        radial-gradient(circle at top left, rgba(252, 241, 214, 0.95), transparent 34%),
        radial-gradient(circle at bottom right, rgba(49, 76, 118, 0.18), transparent 36%),
        linear-gradient(135deg, rgba(255, 251, 244, 0.98), rgba(236, 242, 248, 0.94));
      border: 1px solid rgba(100, 76, 42, 0.14);
      box-shadow: 0 32px 80px rgba(83, 55, 28, 0.12);
    }

    .hero::before,
    .hero::after {
      content: '';
      position: absolute;
      border-radius: 50%;
      pointer-events: none;
      filter: blur(6px);
    }

    .hero::before {
      inset: auto auto -120px -80px;
      width: 260px;
      height: 260px;
      background: rgba(243, 223, 180, 0.34);
    }

    .hero::after {
      inset: -120px -80px auto auto;
      width: 300px;
      height: 300px;
      background: rgba(29, 58, 102, 0.12);
    }

    .hero-copy,
    .hero-visual {
      position: relative;
      z-index: 1;
    }

    .hero-kicker,
    .hero-note,
    .section-label,
    .support-label,
    .support-index,
    .review-date,
    .gallery-kicker,
    .world-aside-label {
      margin: 0;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .hero-kicker,
    .section-label,
    .support-label,
    .review-date,
    .gallery-kicker,
    .world-aside-label {
      font-size: 0.78rem;
      font-weight: 700;
      color: var(--color-accent);
    }

    .hero-brand {
      margin-top: 0.7rem;
      font-family: var(--font-display);
      font-size: clamp(1.5rem, 2vw, 1.9rem);
      font-weight: 700;
      color: #1f2430;
    }

    .hero h1,
    .section-intro h2,
    .section-head h2,
    .world-copy h2,
    .final-cta h2 {
      margin: 0;
      font-family: var(--font-display);
      line-height: 1.08;
      letter-spacing: 0.02em;
      color: #1b2330;
    }

    .hero h1 {
      margin-top: 0.85rem;
      font-size: clamp(2.3rem, 4.8vw, 4.1rem);
      max-width: 10.5ch;
      text-wrap: balance;
    }

    .hero-lead {
      margin: 1rem 0 0;
      max-width: 29rem;
      line-height: 1.85;
      color: rgba(32, 22, 15, 0.82);
      font-size: clamp(0.98rem, 1.2vw, 1.05rem);
    }

    .hero-note {
      margin-top: 1rem;
      max-width: 29rem;
      line-height: 1.7;
      color: rgba(32, 22, 15, 0.7);
      font-size: 0.86rem;
    }

    .hero-note span {
      color: #1f2430;
      font-weight: 700;
    }

    .hero-actions,
    .review-actions,
    .final-actions,
    .world-links {
      display: flex;
      gap: 0.9rem;
      margin-top: 1.6rem;
    }

    .hero-button,
    .inline-button,
    .section-link,
    .support-link,
    .review-rail-item,
    .gallery-lead,
    .gallery-trail-item {
      transition:
        transform 0.2s ease,
        box-shadow 0.2s ease,
        background-color 0.2s ease,
        border-color 0.2s ease;
    }

    .hero-button,
    .inline-button,
    .section-link,
    .support-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 0.85rem 1.35rem;
      border-radius: 999px;
      font-weight: 700;
    }

    .hero-button-primary,
    .inline-button-primary {
      background: linear-gradient(135deg, #8f5b2f, #ae7443);
      color: #fffaf2;
      box-shadow: 0 22px 38px rgba(141, 91, 42, 0.24);
    }

    .hero-button-secondary,
    .inline-button-secondary,
    .section-link,
    .support-link {
      background: rgba(255, 255, 255, 0.44);
      color: #2b3240;
      border: 1px solid rgba(100, 76, 42, 0.12);
      box-shadow: 0 12px 22px rgba(28, 32, 40, 0.06);
    }

    .hero-button:hover,
    .inline-button:hover,
    .section-link:hover,
    .support-link:hover,
    .review-rail-item:hover,
    .gallery-lead:hover,
    .gallery-trail-item:hover {
      transform: translateY(-2px);
    }

    .hero-visual-stage {
      position: relative;
      min-height: clamp(320px, 42vw, 560px);
      display: grid;
      place-items: center;
    }

    .hero-portrait {
      position: relative;
      z-index: 2;
      width: min(100%, 28rem);
      margin: 0;
      padding: clamp(1rem, 2vw, 1.35rem);
      border-radius: 38px;
      background:
        linear-gradient(160deg, rgba(255, 255, 255, 0.68), rgba(255, 249, 238, 0.3)),
        rgba(255, 255, 255, 0.38);
      box-shadow: 0 34px 70px rgba(18, 33, 58, 0.2);
      backdrop-filter: blur(8px);
    }

    .hero-portrait::before {
      content: '';
      position: absolute;
      inset: 10% 12%;
      border-radius: 32px;
      background: radial-gradient(circle, rgba(243, 223, 180, 0.38), transparent 70%);
      z-index: 0;
    }

    .hero-avatar {
      position: relative;
      z-index: 1;
      display: block;
      width: 100%;
      aspect-ratio: 1 / 1;
      object-fit: cover;
      border-radius: 28px;
      background: linear-gradient(180deg, rgba(246, 235, 214, 0.42), rgba(255, 255, 255, 0.7));
    }

    .hero-portrait figcaption {
      position: relative;
      z-index: 1;
      margin-top: 0.9rem;
      text-align: center;
      color: rgba(32, 22, 15, 0.72);
