---
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import { getPublishedGallery, hasDetailContent } from '../utils/gallery';
import { getPublishedReviews } from '../utils/reviews';

const BASE_URL = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const isAbsoluteUrl = (value: string) =>
  /^(?:[a-z][a-z\d+.-]*:|\/\/)/i.test(value);

const withBase = (path: string) => {
  if (!path) return BASE_URL;
  if (isAbsoluteUrl(path)) return path;
  if (path.startsWith(BASE_URL)) return path;
  return `${BASE_URL}${path.replace(/^\/+/, '')}`;
};

const publicDir = join(process.cwd(), 'public');

const resolvePublicAsset = (assetPath: string, fallback: string) => {
  if (!assetPath) return fallback;
  if (isAbsoluteUrl(assetPath)) return assetPath;

  const normalized = assetPath.startsWith('/') ? assetPath : `/${assetPath}`;
  const localPath = join(publicDir, normalized.replace(/^\/+/, ''));
  return existsSync(localPath) ? withBase(normalized) : fallback;
};

const clampText = (value: string, maxLength: number) => {
  const normalized = value.replace(/\s+/g, ' ').trim();
  if (!normalized) return '';
  if (normalized.length <= maxLength) return normalized;
  return `${normalized.slice(0, maxLength).trimEnd()}…`;
};

const reviewDetailRoutePath = join(process.cwd(), 'src/pages/reviews/[slug].astro');
const hasReviewDetailRoute = existsSync(reviewDetailRoutePath);

const formatReviewDate = (value: Date) =>
  new Intl.DateTimeFormat('ja-JP', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC',
  }).format(value);

// Format video date in YYYY-MM-DD format (same as videos.astro)
const formatVideoDate = (value: Date) =>
  new Intl.DateTimeFormat('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
    timeZone: 'UTC',
  }).format(value).replace(/\//g, '-');

const reviewsUrl = withBase('reviews/');
const galleryUrl = withBase('gallery/');
const videosUrl = withBase('videos/');

const pathCards = [
  {
    title: 'Reviews',
    description: '読んだ本の感想と学びを記録。',
    href: reviewsUrl,
    jumpLabel: 'レビューを読む',
  },
  {
    title: 'Gallery',
    description: '本の情景をビジュアルで再現。',
    href: galleryUrl,
    jumpLabel: 'ギャラリーを見る',
  },
  {
    title: 'Videos',
    description: '読書の世界観を動画で体験。',
    href: videosUrl,
    jumpLabel: '動画を見る',
  },
];

let avatar = '/uploads/img_6088.png';

try {
  const entry = await getEntry('profile', 'profile');
  avatar = entry?.data?.avatar ?? avatar;
} catch (e) {}

const avatarUrl = withBase(avatar);
const previewFallbackImage = resolvePublicAsset('/uploads/img_6088.png', avatarUrl);

const reviewEntries = await getPublishedReviews();
const latestReviews = [...reviewEntries]
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3)
  .map((entry) => {
    const slug = entry.id.replace(/\.md$/, '');
    const summarySource = entry.data.excerpt ?? entry.data.description ?? entry.body ?? '';
    return {
      title: entry.data.title,
      summary: clampText(summarySource, 84),
      dateLabel: formatReviewDate(entry.data.date),
      href: hasReviewDetailRoute ? withBase(`reviews/${slug}/`) : reviewsUrl,
      linkLabel: hasReviewDetailRoute ? '詳細を読む' : 'レビュー一覧で読む',
    };
  });

// Fetch gallery from Content Collection
const galleryEntries = await getPublishedGallery();
const getGalleryTimestamp = (generatedAt?: string) => {
  if (!generatedAt) return 0;
  const timestamp = Date.parse(generatedAt);
  return Number.isNaN(timestamp) ? 0 : timestamp;
};

const heroGalleryCandidates = galleryEntries
  .filter((entry) => entry.data.image && !entry.data.image.startsWith('/placeholder-'))
  .map((entry) => {
    const src = resolvePublicAsset(entry.data.image, '');
    if (!src) return null;
    return src;
  })
  .filter((entry): entry is string => entry !== null);

const hasHeroSlideshow = heroGalleryCandidates.length >= 3;

const latestGallery = [...galleryEntries]
  .sort((a, b) => getGalleryTimestamp(b.data.generated_at) - getGalleryTimestamp(a.data.generated_at))
  .slice(0, 3)
  .map((entry) => ({
    title: entry.data.title,
    description: entry.data.description ?? entry.data.note ?? `${entry.data.genre}ジャンルのビジュアル`,
    image: resolvePublicAsset(entry.data.image, previewFallbackImage),
    href: hasDetailContent(entry) ? withBase(`gallery/${entry.slug}/`) : galleryUrl,
  }));

// Fetch videos from Content Collection
const videoEntries = await getCollection('videos');
const latestVideos = [...videoEntries]
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3)
  .map((entry) => ({
    title: entry.data.title,
    description: `公開日: ${formatVideoDate(entry.data.date)}`,
    image: resolvePublicAsset(entry.data.thumbnail, previewFallbackImage),
    href: videosUrl,
  }));
---

<Layout
  title="読書 with Coco - 本の記憶を、イメージで深める"
  description="読書 with Cocoは、レビュー、ギャラリー、動画を通じて本の世界を再び楽しむサイト。ココちゃんが案内する読書体験のアーカイブ。"
  image={avatarUrl}
>
  <section class="home-shell">
    <section class="hero">
      {hasHeroSlideshow && (
        <div
          class="hero-bg-slideshow"
          aria-hidden="true"
          data-slideshow-candidates={JSON.stringify(heroGalleryCandidates)}
        >
          <img class="hero-bg-slide" alt="" />
          <img class="hero-bg-slide" alt="" />
          <img class="hero-bg-slide" alt="" />
          <noscript>
            {heroGalleryCandidates.slice(0, 3).map((imageSrc) => (
              <img
                class="hero-bg-slide"
                src={imageSrc}
                alt=""
                loading="lazy"
                decoding="async"
              />
            ))}
          </noscript>
        </div>
      )}

      {hasHeroSlideshow && <div class="hero-overlay" aria-hidden="true"></div>}

      <div class="hero-visual">
        <img
          class="main-image"
          src={avatarUrl}
          alt="ココちゃんのメインビジュアル"
          width="560"
          height="560"
          loading="eager"
          decoding="async"
        />
        <div class="hero-glow"></div>
        <div class="hero-particles"></div>
      </div>

      <div class="hero-copy">
        <p class="eyebrow">読書体験を、イメージで広げる</p>
        <h1>本の記憶を、イメージで深める。</h1>
        <p class="lead">
          レビュー、ギャラリー、動画を通じて、読んだ本の世界を再び訪れます。
        </p>
        <div class="hero-cta ui-action-group ui-action-group--stack">
          <a class="btn btn-primary ui-action" href={galleryUrl}>ギャラリーを見る</a>
          <a class="btn btn-secondary ui-action" href={reviewsUrl}>レビューを読む</a>
        </div>
      </div>
    </section>

    <script is:inline>
      (function () {
        const container = document.querySelector('.hero-bg-slideshow');
        if (!container) return;

        const candidatesJson = container.getAttribute('data-slideshow-candidates');
        if (!candidatesJson) return;

        let candidates;
        try {
          candidates = JSON.parse(candidatesJson);
        } catch (error) {
          return;
        }

        if (
          !Array.isArray(candidates) ||
          candidates.length < 3 ||
          !candidates.every(function (value) { return typeof value === 'string'; })
        ) {
          return;
        }

        const shuffled = candidates.slice();
        for (let index = shuffled.length - 1; index > 0; index -= 1) {
          const swapIndex = Math.floor(Math.random() * (index + 1));
          const current = shuffled[index];
          shuffled[index] = shuffled[swapIndex];
          shuffled[swapIndex] = current;
        }

        const slides = Array.from(container.children).filter(function (element) {
          return element.tagName === 'IMG' && element.classList.contains('hero-bg-slide');
        });
        if (slides.length !== 3) return;

        slides.forEach(function (slide, index) {
          slide.setAttribute('src', shuffled[index]);
          slide.setAttribute('loading', 'lazy');
          slide.setAttribute('decoding', 'async');
        });

        container.removeAttribute('data-slideshow-candidates');
      })();
    </script>

    <section class="paths" aria-label="主要コンテンツへの導線">
      {pathCards.map((card) => (
        <a class="path-card ui-action" href={card.href}>
          <h2>{card.title}</h2>
          <p>{card.description}</p>
          <span class="jump">{card.jumpLabel}</span>
        </a>
      ))}
    </section>

    <section class="latest-stack" aria-label="最新コンテンツ">
      <section class="latest-section">
        <div class="latest-head ui-action-group">
          <h2>Latest Reviews</h2>
          <a class="latest-more ui-action" href={reviewsUrl}>すべてのレビューを見る</a>
        </div>
        {latestReviews.length ? (
          <div class="preview-grid reviews-grid">
            {latestReviews.map((review) => (
              <article class="preview-card text-card">
                <div class="card-meta">{review.dateLabel}</div>
                <h3>{review.title}</h3>
                <p>{review.summary || 'レビュー本文を公開しています。'}</p>
                <a class="card-link" href={review.href}>{review.linkLabel}</a>
              </article>
            ))}
          </div>
        ) : (
          <p class="preview-empty">レビューがまだありません。最初の1冊を公開予定です。</p>
        )}
      </section>

      <section class="latest-section">
        <div class="latest-head ui-action-group">
          <h2>Latest Gallery</h2>
          <a class="latest-more ui-action" href={galleryUrl}>ギャラリーをもっと見る</a>
        </div>
        {latestGallery.length ? (
          <div class="preview-grid media-grid">
            {latestGallery.map((item) => (
              <article class="preview-card media-card">
                <a class="media-link" href={item.href}>
                  <div class="media-thumb">
                    <img src={item.image} alt={item.title} loading="lazy" decoding="async" width="400" height="300" />
                  </div>
                  <div class="media-body">
                    <h3>{item.title}</h3>
                    <p>{item.description}</p>
                  </div>
                </a>
              </article>
            ))}
          </div>
        ) : (
          <p class="preview-empty">ギャラリーは準備中です。</p>
        )}
      </section>

      <section class="latest-section">
        <div class="latest-head ui-action-group">
          <h2>Latest Videos</h2>
          <a class="latest-more ui-action" href={videosUrl}>動画をもっと見る</a>
        </div>
        {latestVideos.length ? (
          <div class="preview-grid media-grid video-grid">
            {latestVideos.map((item) => (
              <article class="preview-card media-card">
                <a class="media-link" href={item.href}>
                  <div class="media-thumb video-thumb">
                    <img src={item.image} alt={item.title} loading="lazy" decoding="async" width="400" height="225" />
                  </div>
                  <div class="media-body">
                    <h3>{item.title}</h3>
                    <p>{item.description}</p>
                  </div>
                </a>
              </article>
            ))}
          </div>
        ) : (
          <p class="preview-empty">動画は準備中です。</p>
        )}
      </section>
    </section>

    <section class="about">
      <h2>About</h2>
      <p>
        ココちゃんが案内する、読書体験のアーカイブ。レビュー、ビジュアル、動画を通じて、本の世界を再び訪れます。
      </p>
    </section>
  </section>

  <style>
    .home-shell {
      position: relative;
      overflow: hidden;
      padding: clamp(20px, 4vw, 32px);
      border-radius: 32px;
      background: linear-gradient(155deg, #060f23 0%, #0a1d3f 48%, #17396d 100%);
      color: #f8f7f1;
      box-shadow: 0 24px 56px rgba(2, 8, 23, 0.35);
      display: grid;
      gap: clamp(24px, 3vw, 34px);
    }

    .home-shell::before {
      content: '';
      position: absolute;
      top: -120px;
      right: -90px;
      width: 360px;
      height: 360px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255, 232, 186, 0.3) 0%, rgba(255, 232, 186, 0) 72%);
      pointer-events: none;
    }

    .hero {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr;
      gap: clamp(24px, 4vw, 36px);
      align-items: center;
      background: linear-gradient(145deg, rgba(9, 24, 50, 0.95), rgba(20, 46, 86, 0.9));
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 26px;
      padding: clamp(22px, 4vw, 40px);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.1), 0 18px 40px rgba(5, 14, 33, 0.35);
    }

    .hero-bg-slideshow,
    .hero-overlay {
      position: absolute;
      inset: 0;
      border-radius: 26px;
    }

    .hero-bg-slideshow {
      z-index: 0;
      overflow: hidden;
    }

    .hero-bg-slide {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0;
      animation: slideFade 15s infinite;
    }

    .hero-bg-slide:nth-child(1) {
      animation-delay: 0s;
    }

    .hero-bg-slide:nth-child(2) {
      animation-delay: 5s;
    }

    .hero-bg-slide:nth-child(3) {
      animation-delay: 10s;
    }

    .hero-overlay {
      z-index: 1;
      background: linear-gradient(145deg, rgba(9, 24, 50, 0.62), rgba(20, 46, 86, 0.56));
    }

    .eyebrow {
      margin: 0;
      font-size: 0.9rem;
      letter-spacing: 0.04em;
      color: #f5dfad;
      font-weight: 600;
    }

    .hero h1 {
      margin: 10px 0 0;
      font-size: clamp(2.2rem, 5vw, 3.2rem);
      line-height: 1.2;
      letter-spacing: 0.02em;
    }

    .lead {
      margin: 18px 0 0;
      color: rgba(248, 247, 241, 0.9);
      line-height: 1.75;
      max-width: 38ch;
    }

    .hero-cta {
      margin-top: 24px;
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 11px 18px;
      border-radius: 999px;
      font-weight: 700;
      font-size: 0.95rem;
      transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    }

    .btn:hover {
      transform: translateY(-2px);
    }

    .btn-primary {
      background: linear-gradient(135deg, #f3e0b4, #e5c982);
      color: #172742;
      box-shadow: 0 10px 24px rgba(237, 205, 133, 0.28);
    }

    .btn-primary:hover {
      box-shadow: 0 14px 28px rgba(237, 205, 133, 0.38);
    }

    .btn-secondary {
      border: 1px solid rgba(243, 224, 180, 0.65);
      color: #f8f7f1;
      background: rgba(255, 255, 255, 0.06);
    }

    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.14);
    }

    .hero-visual {
      position: relative;
      z-index: 2;
      justify-self: center;
      width: min(100%, 420px);
      aspect-ratio: 1 / 1;
      border-radius: 28px;
      padding: 10px;
      background: linear-gradient(145deg, rgba(245, 223, 173, 0.5), rgba(250, 244, 232, 0.15));
      box-shadow: 0 16px 40px rgba(3, 10, 25, 0.45);
    }

    .main-image {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
      border-radius: 20px;
      border: 1px solid rgba(255, 255, 255, 0.35);
      background: rgba(255, 255, 255, 0.08);
    }

    .hero-glow {
      position: absolute;
      inset: -20px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(245, 223, 173, 0.25) 0%, rgba(245, 223, 173, 0) 70%);
      pointer-events: none;
      z-index: -1;
    }

    .hero-copy {
      position: relative;
      z-index: 2;
    }

    .hero-particles {
      position: absolute;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
      border-radius: 28px;
    }

    .hero-particles::before,
    .hero-particles::after {
      content: '';
      position: absolute;
      width: 3px;
      height: 3px;
      background: rgba(245, 223, 173, 0.6);
      border-radius: 50%;
      animation: float 8s ease-in-out infinite;
    }

    .hero-particles::before {
      top: 20%;
      left: 15%;
      box-shadow:
        40px 80px 0 rgba(245, 223, 173, 0.4),
        120px 40px 0 rgba(245, 223, 173, 0.3),
        200px 100px 0 rgba(245, 223, 173, 0.5),
        80px 150px 0 rgba(245, 223, 173, 0.35),
        160px 200px 0 rgba(245, 223, 173, 0.45),
        30px 180px 0 rgba(245, 223, 173, 0.25),
        220px 60px 0 rgba(245, 223, 173, 0.4);
    }

    .hero-particles::after {
      top: 60%;
      left: 25%;
      animation-delay: -4s;
      box-shadow:
        60px 40px 0 rgba(245, 223, 173, 0.35),
        140px 90px 0 rgba(245, 223, 173, 0.45),
        20px 120px 0 rgba(245, 223, 173, 0.3),
        180px 30px 0 rgba(245, 223, 173, 0.4),
        100px 160px 0 rgba(245, 223, 173, 0.25);
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }

    @keyframes slideFade {
      0%, 27% { opacity: 0.42; }
      7%, 20% { opacity: 0.58; }
      33%, 100% { opacity: 0; }
    }

    @media (prefers-reduced-motion: reduce) {
      .hero-bg-slide {
        animation: none;
        opacity: 0;
      }

      .hero-bg-slide:first-child {
        opacity: 0.2;
      }

      .hero-particles::before,
      .hero-particles::after {
        animation: none;
      }
    }

    .paths {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 14px;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .path-card {
      display: grid;
      gap: 10px;
      padding: 20px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.14);
      box-shadow: 0 14px 30px rgba(4, 11, 26, 0.32);
      transition: transform 0.2s ease, background-color 0.2s ease, border-color 0.2s ease;
      min-height: 176px;
    }

    .path-card:hover {
      transform: translateY(-5px);
      background: rgba(255, 255, 255, 0.12);
      border-color: rgba(243, 224, 180, 0.52);
    }

    .path-card h2 {
      margin: 0;
      font-size: 1.25rem;
      color: #fff9e7;
    }

    .path-card p {
      margin: 0;
      color: rgba(248, 247, 241, 0.85);
      line-height: 1.65;
    }

    .jump {
      margin-top: auto;
      color: #f3dfb2;
      font-weight: 700;
      font-size: 0.93rem;
    }

    .latest-stack {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 16px;
    }

    .latest-section {
      padding: clamp(18px, 2.6vw, 24px);
      border-radius: 22px;
      background: rgba(6, 16, 36, 0.55);
      border: 1px solid rgba(255, 255, 255, 0.12);
      box-shadow: 0 12px 28px rgba(2, 9, 22, 0.28);
    }

    .latest-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 14px;
    }

    .latest-head h2 {
      margin: 0;
      color: #f7e3b4;
      font-size: clamp(1.15rem, 2.3vw, 1.4rem);
    }

    .latest-more {
      color: rgba(248, 247, 241, 0.9);
      font-size: 0.9rem;
      font-weight: 700;
      padding: 7px 11px;
      border-radius: 999px;
      border: 1px solid rgba(248, 247, 241, 0.28);
      background: rgba(255, 255, 255, 0.05);
      transition: background-color 0.2s ease, border-color 0.2s ease;
    }

    .latest-more:hover {
      background: rgba(255, 255, 255, 0.12);
      border-color: rgba(243, 224, 180, 0.62);
    }

    .preview-grid {
      display: grid;
      gap: 12px;
    }

    .reviews-grid,
    .media-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .video-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .preview-card {
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.14);
      background: rgba(255, 255, 255, 0.06);
      box-shadow: 0 10px 24px rgba(3, 9, 21, 0.3);
      overflow: hidden;
    }

    .text-card {
      display: grid;
      gap: 8px;
      padding: 16px;
    }

    .card-meta {
      color: rgba(243, 224, 180, 0.9);
      font-size: 0.8rem;
      letter-spacing: 0.02em;
    }

    .text-card h3,
    .media-body h3 {
      margin: 0;
      font-size: 1.02rem;
      line-height: 1.45;
      color: #fff9ea;
    }

    .text-card p,
    .media-body p {
      margin: 0;
      color: rgba(248, 247, 241, 0.84);
      line-height: 1.6;
      font-size: 0.92rem;
    }

    .card-link {
      margin-top: 2px;
      color: #f3dfb2;
      font-weight: 700;
      font-size: 0.9rem;
    }

    .media-link {
      display: grid;
      color: inherit;
      height: 100%;
      transition: transform 0.2s ease;
    }

    .media-link:hover {
      transform: translateY(-3px);
    }

    .media-thumb {
      aspect-ratio: 4 / 3;
      background: rgba(0, 0, 0, 0.28);
    }

    .video-thumb {
      aspect-ratio: 16 / 9;
    }

    .media-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .media-body {
      display: grid;
      gap: 7px;
      padding: 12px 14px 14px;
    }

    .preview-empty {
      margin: 0;
      color: rgba(248, 247, 241, 0.78);
      font-size: 0.93rem;
    }

    .about {
      position: relative;
      z-index: 1;
      padding: clamp(20px, 3vw, 28px);
      border-radius: 24px;
      background: rgba(4, 12, 29, 0.5);
