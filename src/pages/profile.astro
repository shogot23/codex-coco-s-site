---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const items = await getCollection("profile");
const entry = items[0] ?? null;

const BASE_URL = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const isAbsoluteUrl = (value: string) =>
  /^(?:[a-z][a-z\d+.-]*:|\/\/)/i.test(value);

const withBase = (path: string) => {
  if (!path) return BASE_URL;
  if (isAbsoluteUrl(path)) return path;
  if (path.startsWith(BASE_URL)) return path;
  return `${BASE_URL}${path.replace(/^\/+/, "")}`;
};

const title = entry?.data?.title ?? "プロフィール";
const description = entry?.data?.description ?? "読書 with Coco のプロフィール";
const avatarPath = entry?.data?.avatar || "/uploads/img_6088.png";
const avatarUrl = withBase(avatarPath);
const updatedLabel = entry?.data?.updatedAt
  ? new Intl.DateTimeFormat("ja-JP", {
      year: "numeric",
      month: "long",
      day: "numeric",
    }).format(entry.data.updatedAt)
  : null;

const galleryUrl = withBase("gallery/");
const reviewsUrl = withBase("reviews/");
const videosUrl = withBase("videos/");

const guideLinks = [
  {
    label: "Gallery",
    href: galleryUrl,
    copy: "読書から生まれた情景を、ココちゃんと一緒に眺める。",
  },
  {
    label: "Reviews",
    href: reviewsUrl,
    copy: "読み終えた本の余韻を、短く深く言葉でたどる。",
  },
  {
    label: "Videos",
    href: videosUrl,
    copy: "物語の空気を、短い映像としてもう一度味わう。",
  },
];

let Content = null;
if (entry) {
  ({ Content } = await entry.render());
}
---

<Layout title={title} description={description} image={avatarUrl}>
  <section class="profile-shell">
    <section class="profile-hero">
      <div class="hero-visual">
        <figure class="visual-card">
          <img
            src={avatarUrl}
            alt="本に囲まれたココちゃんのポートレート"
            width="720"
            height="720"
            loading="eager"
            decoding="async"
          />
        </figure>
        <p class="visual-note">Reading with Coco</p>
      </div>

      <div class="hero-copy">
        <p class="eyebrow">案内犬</p>
        <h1>ココ</h1>
        <p class="hero-lead">わが家の小さな相棒・ココちゃんが、この場所の案内役です。</p>
        <p class="hero-description">{description}</p>

        {updatedLabel && <p class="hero-meta">更新: {updatedLabel}</p>}

        <div class="hero-actions">
          <a class="hero-link hero-link-primary" href={galleryUrl}>ギャラリーを見る</a>
          <a class="hero-link hero-link-secondary" href={reviewsUrl}>レビューを読む</a>
        </div>
      </div>
    </section>

    <section class="profile-guides" aria-label="プロフィールからの導線">
      {guideLinks.map((link) => (
        <a class="guide-card" href={link.href}>
          <span class="guide-label">{link.label}</span>
          <p>{link.copy}</p>
        </a>
      ))}
    </section>

    <section class="profile-content">
      <div class="content-head">
        <p class="content-kicker">Profile Story</p>
        <h2>この場所について</h2>
      </div>

      {Content ? (
        <div class="content-body">
          <Content />
        </div>
      ) : (
        <p class="content-empty">profile コンテンツが見つかりません（src/content/profile/profile.md を確認）</p>
      )}
    </section>
  </section>
</Layout>

<style>
  .profile-shell {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: clamp(18px, 3vw, 28px);
    padding: clamp(18px, 4vw, 32px);
    border-radius: 32px;
    background: linear-gradient(155deg, #060f23 0%, #0a1d3f 48%, #17396d 100%);
    color: #f8f5ef;
    box-shadow: 0 24px 56px rgba(2, 8, 23, 0.35);
  }

  .profile-shell::before,
  .profile-shell::after {
    content: "";
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .profile-shell::before {
    top: -120px;
    right: -90px;
    width: 360px;
    height: 360px;
    background: radial-gradient(circle, rgba(255, 232, 186, 0.3) 0%, rgba(255, 232, 186, 0) 72%);
  }

  .profile-shell::after {
    bottom: -140px;
    left: -110px;
    width: 320px;
    height: 320px;
    background: radial-gradient(circle, rgba(94, 167, 255, 0.2) 0%, rgba(94, 167, 255, 0) 70%);
  }

  .profile-hero,
  .profile-content {
    position: relative;
    z-index: 1;
    border-radius: 28px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08), 0 18px 40px rgba(5, 14, 33, 0.32);
  }

  .profile-hero {
    display: grid;
    grid-template-columns: minmax(0, 0.94fr) minmax(0, 1.06fr);
    gap: clamp(24px, 4vw, 42px);
    align-items: center;
    padding: clamp(22px, 4vw, 40px);
    background: linear-gradient(145deg, rgba(9, 24, 50, 0.95), rgba(21, 44, 83, 0.88));
  }

  .hero-visual {
    position: relative;
    justify-self: center;
    width: min(100%, 420px);
  }

  .hero-visual::before {
    content: "";
    position: absolute;
    inset: 10% 10% -10%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(245, 223, 173, 0.32) 0%, rgba(245, 223, 173, 0) 72%);
    filter: blur(16px);
    z-index: -1;
  }

  .visual-card {
    margin: 0;
    border-radius: 30px;
    padding: 10px;
    background: linear-gradient(145deg, rgba(245, 223, 173, 0.5), rgba(250, 244, 232, 0.14));
    box-shadow: 0 18px 44px rgba(3, 10, 25, 0.45);
  }

  .visual-card img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 22px;
    border: 1px solid rgba(255, 255, 255, 0.32);
    background: rgba(255, 255, 255, 0.08);
  }

  .visual-note {
    position: absolute;
    right: 18px;
    bottom: 18px;
    margin: 0;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(9, 24, 50, 0.72);
    border: 1px solid rgba(245, 223, 173, 0.52);
    color: #fff4da;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .hero-copy h1 {
    margin: 10px 0 0;
    font-size: clamp(2.8rem, 6vw, 4.4rem);
    line-height: 0.98;
    letter-spacing: 0.03em;
    color: #fff9ec;
  }

  .eyebrow {
    margin: 0;
    color: #f5dfad;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  .hero-lead {
    margin: 20px 0 0;
    max-width: 28ch;
    color: #fff4de;
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.75;
  }

  .hero-description {
    margin: 14px 0 0;
    max-width: 34ch;
    color: rgba(248, 245, 239, 0.84);
    line-height: 1.8;
  }

  .hero-meta {
    margin: 18px 0 0;
    color: rgba(248, 245, 239, 0.7);
    font-size: 0.92rem;
    letter-spacing: 0.02em;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .hero-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 11px 18px;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 700;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
  }

  .hero-link:hover {
    transform: translateY(-2px);
  }

  .hero-link-primary {
    background: linear-gradient(135deg, #f3e0b4, #e5c982);
    color: #172742;
    box-shadow: 0 10px 24px rgba(237, 205, 133, 0.28);
  }

  .hero-link-primary:hover {
    box-shadow: 0 14px 28px rgba(237, 205, 133, 0.36);
  }

  .hero-link-secondary {
    color: #f8f5ef;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(243, 224, 180, 0.65);
  }

  .hero-link-secondary:hover {
    background: rgba(255, 255, 255, 0.14);
  }

  .profile-guides {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .guide-card {
    display: grid;
    gap: 10px;
    min-height: 148px;
    padding: 20px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow: 0 14px 30px rgba(4, 11, 26, 0.32);
    transition: transform 0.2s ease, background-color 0.2s ease, border-color 0.2s ease;
  }

  .guide-card:hover {
    transform: translateY(-4px);
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(243, 224, 180, 0.52);
  }

  .guide-label {
    font-size: 1.05rem;
    font-weight: 700;
    color: #fff9e7;
    letter-spacing: 0.02em;
  }

  .guide-card p {
    margin: 0;
    color: rgba(248, 245, 239, 0.84);
    line-height: 1.7;
  }

  .profile-content {
    padding: clamp(22px, 4vw, 32px);
    background: rgba(7, 18, 39, 0.58);
  }

  .content-head {
    display: grid;
    gap: 8px;
    margin-bottom: 20px;
  }

  .content-kicker {
    margin: 0;
    color: #f5dfad;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .content-head h2 {
    margin: 0;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: #fff9ec;
  }

  .content-body {
    color: rgba(248, 245, 239, 0.86);
  }

  .content-body :global(p) {
    margin: 0 0 1.1rem;
    line-height: 1.9;
  }

  .content-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .content-body :global(strong) {
    color: #fff7e0;
  }

  .content-empty {
    margin: 0;
    color: rgba(248, 245, 239, 0.82);
    line-height: 1.8;
  }

  @media (max-width: 900px) {
    .profile-hero {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-lead,
    .hero-description {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .profile-guides {
      grid-template-columns: 1fr;
    }

    .guide-card {
      min-height: auto;
    }
  }

  @media (max-width: 600px) {
    .profile-shell {
      padding: 16px;
      border-radius: 24px;
    }

    .profile-hero,
    .profile-content {
      padding: 18px;
      border-radius: 22px;
    }

    .hero-visual {
      width: min(100%, 260px);
    }

    .visual-note {
      left: 50%;
      right: auto;
      bottom: 14px;
      transform: translateX(-50%);
      white-space: nowrap;
    }

    .hero-copy h1 {
      font-size: clamp(2.4rem, 13vw, 3.2rem);
    }

    .hero-actions {
      flex-direction: column;
    }

    .hero-link {
      width: 100%;
    }
  }
</style>
