---
import { getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";

let entry = null;

try {
  entry = await getEntry("profile", "profile");
} catch {
  // Profile content is optional during local content setup.
}

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const isAbsoluteUrl = (value: string) => /^(?:[a-z][a-z\d+.-]*:|\/\/)/i.test(value);

const withBase = (path: string) => {
  if (!path) return base;
  if (isAbsoluteUrl(path)) return path;
  if (path.startsWith(base)) return path;
  return `${base}${path.replace(/^\/+/, "")}`;
};

const stripMarkdown = (value: string) =>
  value
    .replace(/^#{1,6}\s+/gm, "")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/[*_`>-]/g, "")
    .replace(/\n{3,}/g, "\n\n")
    .trim();

const getParagraphs = (value: string) =>
  stripMarkdown(value)
    .split(/\n\s*\n/)
    .map((paragraph) => paragraph.replace(/\s*\n\s*/g, " ").trim())
    .filter(Boolean);

const title = entry ? `${entry.data.title} | 読書 with Coco` : "プロフィール | 読書 with Coco";
const description = entry?.data?.description ?? "読書 with Coco のプロフィール";
const avatarUrl = withBase(entry?.data?.avatar ?? "/uploads/profile.png");
const reviewsUrl = withBase("reviews/");
const galleryUrl = withBase("gallery/");
const homeUrl = withBase("");

const profileItems = entry?.data?.profileItems ?? [];
const favoriteItems = entry?.data?.favoriteItems ?? [];
const sensitiveItems = entry?.data?.sensitiveItems ?? [];
const roleText = entry?.data?.roleText ?? "";
const closingQuote = entry?.data?.closingQuote ?? "";

const profileParagraphs = entry ? getParagraphs(entry.body) : [];
const profileLead = profileParagraphs[0] ?? "ココちゃんは、このサイトの案内役です。";
const profileBridge = profileParagraphs[1] ?? null;

const updatedAtLabel = entry?.data?.updatedAt
  ? new Intl.DateTimeFormat("ja-JP", {
      year: "numeric",
      month: "long",
      day: "numeric",
      timeZone: "UTC",
    }).format(entry.data.updatedAt)
  : null;
---

<Layout title={title} description={description} image={avatarUrl}>
  <div class="profile-world">
    <section class="profile-hero" aria-labelledby="profile-title">
      <div class="hero-copy">
        <p class="section-label">Profile / Site Guide</p>
        <h2 class="section-caption">ココちゃんについて</h2>
        <p class="hero-brand">読書 with Coco</p>
        <h1 id="profile-title">このサイトの案内役、ココちゃん。</h1>
        <p class="hero-lead">{profileLead}</p>
        {profileBridge && <p class="hero-bridge">{profileBridge}</p>}

        <div class="hero-actions ui-action-group ui-action-group--stack">
          <a class="hero-link hero-link-primary ui-action" href={reviewsUrl}>レビューを見る</a>
          <a class="hero-link hero-link-secondary ui-action" href={galleryUrl}>ギャラリーを見る</a>
        </div>

        <div class="hero-footnote">
          <p>{entry?.data?.description ?? "ココちゃんについて"}</p>
          {updatedAtLabel && <span>更新: {updatedAtLabel}</span>}
        </div>
      </div>

      <div class="hero-visual">
        <figure class="hero-image-frame">
          <img
            src={avatarUrl}
            alt="読書 with Coco の案内役、ココちゃん"
            width="720"
            height="720"
            loading="eager"
            decoding="async"
          />
        </figure>
      </div>
    </section>

    <section class="character-room" aria-labelledby="character-title">
      <div class="character-intro">
        <p class="section-label">Coco&apos;s Character</p>
        <h2 id="character-title">ココちゃんのこと、少しだけ。</h2>
      </div>

      <div class="character-rows">
        {profileItems.map((item) => (
          <article class="character-row">
            <p class="character-label">{item.label}</p>
            <p class="character-value">{item.value}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="favorites-room" aria-labelledby="favorites-title">
      <div class="favorites-intro">
        <p class="section-label">What Coco Loves</p>
        <h2 id="favorites-title">ココちゃんがすきなこと。</h2>
      </div>

      <div class="favorites-grid">
        {favoriteItems.map((item, index) => (
          <article class="favorite-card">
            <p class="favorite-count">{String(index + 1).padStart(2, "0")}</p>
            <p class="favorite-text">{item}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="sensitive-room" aria-labelledby="sensitive-title">
      <div class="sensitive-intro">
        <p class="section-label">What Coco Watches Carefully</p>
        <h2 id="sensitive-title">ココちゃんがにがてなこと。</h2>
      </div>

      <div class="sensitive-grid">
        {sensitiveItems.map((item, index) => (
          <article class="sensitive-card">
            <p class="sensitive-count">{String(index + 1).padStart(2, "0")}</p>
            <p class="sensitive-text">{item}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="closing-room" aria-labelledby="closing-title">
      <div class="closing-copy">
        <p class="section-label">Coco&apos;s Role / Site Guide</p>
        <h3 class="section-caption">このサイトでのおしごと</h3>
        <h2 id="closing-title">本の世界を、やわらかく案内する相棒。</h2>
        <p>{roleText}</p>
        <blockquote class="closing-quote">{closingQuote}</blockquote>
      </div>

      <div class="closing-links ui-action-group ui-action-group--stack">
        <a class="hero-link hero-link-primary ui-action" href={reviewsUrl}>レビューを見る</a>
        <a class="hero-link hero-link-secondary ui-action" href={homeUrl}>Home へ戻る</a>
      </div>
    </section>
  </div>
</Layout>

<style>
  .profile-world {
    display: grid;
    gap: clamp(1.75rem, 4vw, 3.25rem);
  }

  .profile-hero,
  .character-room,
  .favorites-room,
  .sensitive-room,
  .closing-room {
    position: relative;
    overflow: clip;
    border: 1px solid rgba(100, 76, 42, 0.14);
    border-radius: clamp(26px, 4vw, 40px);
    box-shadow: 0 24px 70px rgba(83, 55, 28, 0.1);
  }

  .profile-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(320px, 0.98fr);
    gap: clamp(1.5rem, 3vw, 3rem);
    padding: clamp(1.6rem, 4vw, 3rem);
    background:
      radial-gradient(circle at top left, rgba(247, 214, 176, 0.84), transparent 30%),
      radial-gradient(circle at bottom right, rgba(62, 93, 139, 0.18), transparent 32%),
      linear-gradient(135deg, rgba(255, 250, 243, 0.98), rgba(236, 242, 248, 0.92));
  }

  .character-room,
  .favorites-room,
  .sensitive-room,
  .closing-room {
    padding: clamp(1.35rem, 3vw, 2.3rem);
    background: linear-gradient(180deg, rgba(255, 253, 249, 0.98), rgba(247, 240, 230, 0.88));
  }

  .favorites-room {
    background:
      radial-gradient(circle at top right, rgba(244, 219, 186, 0.45), transparent 24%),
      linear-gradient(180deg, rgba(255, 252, 247, 0.98), rgba(244, 238, 229, 0.9));
  }

  .sensitive-room {
    background:
      radial-gradient(circle at bottom left, rgba(62, 93, 139, 0.08), transparent 28%),
      linear-gradient(180deg, rgba(255, 253, 248, 0.98), rgba(246, 238, 226, 0.92));
  }

  .hero-copy,
  .hero-visual,
  .closing-copy {
    position: relative;
    z-index: 1;
  }

  .section-label,
  .character-label,
  .favorite-count,
  .sensitive-count {
    margin: 0;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-label,
  .character-label {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .hero-brand {
    margin: 0.85rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 2vw, 1.9rem);
    color: #1f2430;
  }

  .section-caption {
    margin: 0.35rem 0 0;
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.4;
    color: #5d3c20;
  }

  .profile-hero h1,
  .character-intro h2,
  .favorites-intro h2,
  .sensitive-intro h2,
  .closing-copy h2 {
    margin: 0;
    font-family: var(--font-display);
    line-height: 1.1;
    letter-spacing: 0.02em;
    color: #1b2330;
  }

  .profile-hero h1 {
    margin-top: 1rem;
    font-size: clamp(2.6rem, 5vw, 4.7rem);
    max-width: 9ch;
    text-wrap: balance;
  }

  .character-intro,
  .favorites-intro,
  .sensitive-intro,
  .closing-copy {
    display: grid;
    gap: 0.65rem;
    max-width: 38rem;
  }

  .character-intro h2,
  .favorites-intro h2,
  .sensitive-intro h2,
  .closing-copy h2 {
    font-size: clamp(2rem, 3vw, 2.8rem);
    text-wrap: balance;
  }

  .hero-lead,
  .hero-bridge,
  .closing-copy p,
  .favorite-text,
  .sensitive-text {
    color: rgba(33, 23, 16, 0.78);
  }

  .hero-lead,
  .hero-bridge {
    margin: 1.2rem 0 0;
    max-width: 34rem;
    line-height: 1.9;
    font-size: clamp(1rem, 1.3vw, 1.1rem);
  }

  .hero-actions,
  .closing-links {
    display: flex;
    gap: 0.9rem;
    margin-top: 1.8rem;
  }

  .hero-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.85rem 1.3rem;
    border-radius: 999px;
    font-weight: 700;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  .hero-link:hover {
    transform: translateY(-1px);
  }

  .hero-link-primary {
    background: #1f2430;
    color: #fffaf1;
    box-shadow: 0 18px 34px rgba(31, 36, 48, 0.18);
  }

  .hero-link-secondary {
    border: 1px solid rgba(100, 76, 42, 0.16);
    background: rgba(255, 255, 255, 0.72);
    color: #5d3c20;
  }

  .hero-footnote {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    align-items: center;
    width: fit-content;
    margin-top: 1.5rem;
    padding: 0.8rem 1rem;
    border: 1px solid rgba(100, 76, 42, 0.12);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.68);
    backdrop-filter: blur(10px);
  }

  .hero-footnote p,
  .hero-footnote span {
    margin: 0;
    color: rgba(33, 23, 16, 0.7);
    font-size: 0.9rem;
  }

  .hero-visual {
    display: grid;
    align-items: stretch;
  }

  .hero-image-frame {
    margin: 0;
    overflow: hidden;
    border-radius: clamp(24px, 3vw, 34px);
    min-height: 100%;
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.64), rgba(237, 212, 184, 0.76));
  }

  .hero-image-frame img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 460px;
    object-fit: cover;
  }

  .character-room {
    display: grid;
    gap: 1.6rem;
  }

  .character-rows {
    display: grid;
    gap: 1rem;
  }

  .character-row {
    display: grid;
    gap: 0.55rem;
    padding: 1.15rem 0;
    border-top: 1px solid rgba(100, 76, 42, 0.12);
  }

  .character-row:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .character-label {
    font-size: 0.76rem;
    font-weight: 700;
    color: #8d5b2a;
  }

  .character-value {
    margin: 0;
    max-width: 40rem;
    font-family: var(--font-headline);
    font-size: clamp(1.15rem, 1.8vw, 1.45rem);
    line-height: 1.65;
    color: #2c2017;
  }

  .favorites-room,
  .sensitive-room {
    display: grid;
    gap: 1.75rem;
  }

  .favorites-grid,
  .sensitive-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.95rem;
  }

  .favorite-card,
  .sensitive-card {
    display: grid;
    gap: 0.85rem;
    padding: 1.15rem;
    border: 1px solid rgba(100, 76, 42, 0.12);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.66);
    transition:
      transform 0.2s ease,
      background-color 0.2s ease,
      border-color 0.2s ease;
  }

  .favorite-card:hover,
  .sensitive-card:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.8);
  }

  .favorite-count,
  .sensitive-count {
    display: grid;
    place-items: center;
    width: 54px;
    height: 54px;
    border-radius: 16px;
    background: rgba(247, 214, 176, 0.42);
    color: #7d4c22;
    font-weight: 700;
    font-size: 0.82rem;
  }

  .favorite-text,
  .sensitive-text {
    margin: 0;
    font-family: var(--font-headline);
    font-size: clamp(1.1rem, 1.7vw, 1.35rem);
    line-height: 1.6;
    color: #2c2017;
  }

  .closing-room {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.6rem;
    align-items: center;
  }

  .closing-copy {
    gap: 0.95rem;
  }

  .closing-copy p {
    margin: 0;
    line-height: 1.85;
  }

  .closing-quote {
    margin: 0.25rem 0 0;
    padding: 1rem 1.1rem;
    border-left: 3px solid rgba(100, 76, 42, 0.4);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.55);
    color: #5d3c20;
    font-family: var(--font-headline);
    font-size: clamp(1.05rem, 1.5vw, 1.2rem);
    line-height: 1.7;
  }

  @media (max-width: 920px) {
    .profile-hero,
    .closing-room {
      grid-template-columns: 1fr;
    }

    .hero-visual {
      order: -1;
    }

    .profile-hero h1 {
      max-width: none;
    }
  }

  @media (max-width: 720px) {
    .profile-world {
      gap: 1.15rem;
    }

    .profile-hero,
    .character-room,
    .favorites-room,
    .sensitive-room,
    .closing-room {
      border-radius: 28px;
      padding: 1.15rem;
    }

    .hero-image-frame img {
      min-height: 320px;
    }

    .favorites-grid,
    .sensitive-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .profile-hero h1,
    .character-intro h2,
    .favorites-intro h2,
    .sensitive-intro h2,
    .closing-copy h2 {
      font-size: 2rem;
    }

    .hero-footnote {
      width: 100%;
      box-sizing: border-box;
    }
  }
</style>
