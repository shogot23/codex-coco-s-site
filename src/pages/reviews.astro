---
import Layout from "../layouts/Layout.astro";
import { buildReviewGalleryMap, getPublishedGallery } from "../utils/gallery";
import { getPublishedReviews } from "../utils/reviews";

const reviews = await getPublishedReviews();
const sortedReviews = [...reviews].sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime() || a.slug.localeCompare(b.slug)
);
const galleryEntries = await getPublishedGallery();
const reviewGalleryMap = buildReviewGalleryMap(galleryEntries);

const base = import.meta.env.BASE_URL;
const baseWithSlash = base.endsWith("/") ? base : `${base}/`;

const isAbsoluteUrl = (value: string) =>
  /^(?:[a-z][a-z\d+.-]*:|\/\/)/i.test(value);

const withBase = (assetPath: string) => {
  if (!assetPath) return baseWithSlash;
  if (isAbsoluteUrl(assetPath)) return assetPath;
  if (assetPath.startsWith(baseWithSlash)) return assetPath;
  return `${baseWithSlash}${assetPath.replace(/^\/+/, "")}`;
};

const formatDate = (value: Date) =>
  new Intl.DateTimeFormat("ja-JP", {
    year: "numeric",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  }).format(value);

const stripMarkdown = (value: string) =>
  value
    .replace(/^#{1,6}\s+/gm, "")
    .replace(/!\[([^\]]*)\]\([^)]+\)/g, "$1")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/[*_`>#-]/g, "")
    .replace(/\n{3,}/g, "\n\n")
    .trim();

const clampText = (text: string, maxLength: number): string => {
  const normalized = stripMarkdown(text).replace(/\s+/g, " ").trim();
  if (!normalized) return "";
  if (normalized.length <= maxLength) return normalized;
  return `${normalized.slice(0, maxLength).trimEnd()}…`;
};

const reviewCards = sortedReviews.map((review) => {
  const href = `${baseWithSlash}reviews/${review.slug}/`;
  const summarySource = review.data.description ?? review.data.excerpt ?? review.body ?? "";
  const quoteSource = review.data.excerpt ?? review.body ?? review.data.description ?? "";
  const galleryImage = reviewGalleryMap.get(review.slug)?.data.image;
  const thumbnail = galleryImage ?? review.data.cover ?? review.data.infographic;
  const supplementalTitle =
    review.data.bookTitle && review.data.bookTitle !== review.data.title
      ? review.data.bookTitle
      : null;

  return {
    slug: review.slug,
    title: review.data.title,
    supplementalTitle,
    author: review.data.author,
    date: review.data.date,
    dateLabel: formatDate(review.data.date),
    href,
    thumbnail,
    summary: clampText(summarySource, 120),
    quote: clampText(quoteSource, 88),
    tags: review.data.tags ?? [],
    recommendedFor: review.data.recommendedFor ?? [],
    purchaseLinks: review.data.purchaseLinks ?? [],
  };
});

const featuredReview = reviewCards[0] ?? null;
const remainingReviews = reviewCards.slice(1);

const themeCounts = reviewCards.reduce<Record<string, number>>((acc, review) => {
  for (const tag of review.tags) {
    acc[tag] = (acc[tag] ?? 0) + 1;
  }
  return acc;
}, {});

const spotlightThemes = Object.entries(themeCounts)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], "ja"))
  .slice(0, 4)
  .map(([name]) => name);

const readingCues = Array.from(
  new Set(reviewCards.flatMap((review) => review.recommendedFor))
).slice(0, 3);

const galleryUrl = `${baseWithSlash}gallery/`;
const reviewCountLabel = `${reviewCards.length}冊のレビュー`;
const latestReviewLabel = featuredReview ? featuredReview.dateLabel : null;
---

<Layout
  title="Reviews | 読書 with Coco"
  description="次に読みたくなる一冊へ向かうための、読書 with Coco のレビュー一覧ページ。"
>
  <div class="reviews-story">
    <section class="hero" aria-labelledby="reviews-heading">
      <div class="hero-copy">
        <p class="hero-kicker">読書 with Coco / Reviews</p>
        <p class="hero-brand">読書 with Coco</p>
        <h1 id="reviews-heading">次の一冊をひらく前に、言葉の余韻をひとくち。</h1>
        <p class="hero-lead">
          トップページから続く主導線の先で、本を閉じたあとに残る感情や学びを静かにたどります。
          まずは今いちばん手前にある一冊からどうぞ。
        </p>

        {featuredReview && (
          <p class="hero-note">
            いま前にあるのは <span>{featuredReview.title}</span>。読む理由が先に見えるように、
            余韻の輪郭だけを添えて並べています。
          </p>
        )}

        <div class="hero-actions ui-action-group ui-action-group--stack">
          <a
            class="hero-button hero-button-primary ui-action"
            href={featuredReview ? featuredReview.href : "#review-stream"}
          >
            {featuredReview ? "最新レビューを読む" : "一覧を見る"}
          </a>
          {featuredReview && (
            <a class="hero-button hero-button-secondary ui-action" href="#review-stream">
              {remainingReviews.length > 0 ? "一覧から選ぶ" : "読む前のしおりを見る"}
            </a>
          )}
        </div>
      </div>

      <aside class="hero-panel" aria-label="レビューのしおり">
        <p class="panel-label">Reading Notes</p>

        <dl class="panel-stats">
          <div>
            <dt>棚にある言葉</dt>
            <dd>{reviewCountLabel}</dd>
          </div>
          {latestReviewLabel && (
            <div>
              <dt>いちばん新しい一冊</dt>
              <dd>{latestReviewLabel}</dd>
            </div>
          )}
        </dl>

        {spotlightThemes.length > 0 && (
          <div class="panel-block">
            <p>このページでめぐれるテーマ</p>
            <ul class="theme-list" aria-label="テーマ">
              {spotlightThemes.map((theme) => (
                <li>{theme}</li>
              ))}
            </ul>
          </div>
        )}

        {readingCues.length > 0 && (
          <div class="panel-block">
            <p>こんな気分の日に</p>
            <ul class="cue-list">
              {readingCues.map((cue) => (
                <li>{cue}</li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    </section>

    {featuredReview ? (
      <>
        <section class="featured-section" aria-labelledby="featured-review-heading">
          <div class="section-header">
            <div>
              <p class="section-label">Featured Review</p>
              <h2 id="featured-review-heading">まずは、この一冊から。</h2>
            </div>
            <p class="section-copy">
              一覧の先頭は、トップページから続く最初の入口です。短い抜粋とおすすめ対象から、
              その日の距離感で読みはじめられるようにしています。
            </p>
          </div>

          <article class="featured-review">
            <a
              class="featured-media"
              href={featuredReview.href}
              aria-label={`${featuredReview.title}のレビューを読む`}
            >
              {featuredReview.thumbnail ? (
                <img
                  src={withBase(featuredReview.thumbnail)}
                  alt={`${featuredReview.title}のレビューイメージ`}
                  loading="eager"
                  decoding="async"
                  width="520"
                  height="640"
                />
              ) : (
                <div class="media-fallback" aria-hidden="true">
                  <span>Review</span>
                  <strong>{featuredReview.title}</strong>
                </div>
              )}
            </a>

            <div class="featured-body">
              <p class="featured-eyebrow">Latest Arrival</p>
              <h3 class="featured-title">
                <a href={featuredReview.href}>{featuredReview.title}</a>
              </h3>
              {featuredReview.supplementalTitle && (
                <p class="featured-book-title">{featuredReview.supplementalTitle}</p>
              )}

              <div class="featured-meta">
                {featuredReview.author && <span>著者: {featuredReview.author}</span>}
                <time datetime={featuredReview.date.toISOString()}>{featuredReview.dateLabel}</time>
              </div>

              {featuredReview.summary && <p class="featured-summary">{featuredReview.summary}</p>}
              {featuredReview.quote && <blockquote>{featuredReview.quote}</blockquote>}

              <div class="featured-details">
                {featuredReview.tags.length > 0 && (
                  <ul class="tag-list" aria-label="タグ">
                    {featuredReview.tags.map((tag) => (
                      <li>{tag}</li>
                    ))}
                  </ul>
                )}

                {featuredReview.recommendedFor.length > 0 && (
                  <div class="reader-note">
                    <p class="reader-note-label">こんな人に</p>
                    <ul>
                      {featuredReview.recommendedFor.slice(0, 3).map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>

              <div class="review-actions ui-action-group ui-action-group--stack">
                <a class="hero-button hero-button-primary ui-action" href={featuredReview.href}>
                  このレビューを読む
                </a>
                <a class="hero-button hero-button-secondary ui-action" href="#review-stream">
                  {remainingReviews.length > 0 ? "他のレビューを見る" : "読む前のしおりを見る"}
                </a>
                {featuredReview.purchaseLinks.length > 0 && (
                  <div class="review-purchase-links ui-action-group ui-action-group--stack">
                    {featuredReview.purchaseLinks.map((link) => (
                      <a
                        class="hero-button hero-button-secondary ui-action"
                        href={link.url}
                        target="_blank"
                        rel="noopener noreferrer nofollow"
                      >
                        {link.label ?? "この本を見る"}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </article>
        </section>

        {remainingReviews.length > 0 ? (
          <section class="stream-section" id="review-stream" aria-labelledby="review-stream-heading">
            <div class="section-header">
              <div>
                <p class="section-label">Review Stream</p>
                <h2 id="review-stream-heading">気になる余韻から、次の一冊へ。</h2>
              </div>
              <p class="section-copy">
                すべてを同じ強さでは並べず、テーマ、抜粋、おすすめ対象のどこからでも入れる流れにしています。
              </p>
            </div>

            <ol class="review-stream">
              {remainingReviews.map((review, index) => (
                <li class="stream-item">
                  <div class="stream-aside">
                    <p class="stream-order">{String(index + 2).padStart(2, "0")}</p>
                    <time class="stream-date" datetime={review.date.toISOString()}>{review.dateLabel}</time>
                    <a
                      class="stream-media"
                      href={review.href}
                      aria-label={`${review.title}のレビューを読む`}
                    >
                      {review.thumbnail ? (
                        <img
                          src={withBase(review.thumbnail)}
                          alt={`${review.title}のレビューイメージ`}
                          loading="lazy"
                          decoding="async"
                          width="260"
                          height="320"
                        />
                      ) : (
                        <div class="media-fallback media-fallback-small" aria-hidden="true">
                          <span>Review</span>
                          <strong>{review.title}</strong>
                        </div>
                      )}
                    </a>
                  </div>

                  <div class="stream-body">
                    <p class="stream-theme">
                      {review.tags.length > 0 ? review.tags.slice(0, 2).join(" / ") : "Review"}
                    </p>
                    <h3>
                      <a href={review.href}>{review.title}</a>
                    </h3>
                    {review.supplementalTitle && <p class="stream-book-title">{review.supplementalTitle}</p>}

                    <div class="stream-meta">
                      {review.author && <span>著者: {review.author}</span>}
                    </div>

                    {review.summary && <p class="stream-summary">{review.summary}</p>}
                    {review.quote && <p class="stream-quote">“{review.quote}”</p>}

                    <div class="stream-footer">
                      {review.recommendedFor[0] && (
                        <p class="stream-cue">
                          <span>こんな人に</span>
                          {review.recommendedFor[0]}
                        </p>
                      )}

                      <div class="stream-actions">
                        <a class="stream-link ui-action" href={review.href}>レビューを読む</a>
                        {review.purchaseLinks.length > 0 && (
                          <div class="stream-purchase-links ui-action-group ui-action-group--stack">
                            {review.purchaseLinks.map((link) => (
                              <a
                                class="stream-purchase ui-action"
                                href={link.url}
                                target="_blank"
                                rel="noopener noreferrer nofollow"
                                aria-label={`${review.supplementalTitle ?? review.title}の購入先: ${link.label ?? "この本を見る"}`}
                              >
                                {link.label ?? "この本を見る"}
                              </a>
                            ))}
                          </div>
                        )}
                      </div>
                    </div>
                  </div>
                </li>
              ))}
            </ol>
          </section>
        ) : (
          <section class="compass-section" id="review-stream" aria-labelledby="compass-heading">
            <div class="section-header">
              <div>
                <p class="section-label">Reading Compass</p>
                <h2 id="compass-heading">いまは、この一冊をじっくりどうぞ。</h2>
              </div>
              <p class="section-copy">
                公開中のレビューがまだ少ないぶん、最初の一冊を深く読めるように入口を厚くしています。
              </p>
            </div>

            <div class="compass-card">
              <div>
                <p class="compass-lead">
                  読みはじめる前に、テーマとおすすめ対象を先に見ておくと、その一冊が今の自分に合うかを判断しやすくなります。
                </p>

                {featuredReview.tags.length > 0 && (
                  <ul class="tag-list" aria-label="注目テーマ">
                    {featuredReview.tags.map((tag) => (
                      <li>{tag}</li>
                    ))}
                  </ul>
                )}
              </div>

              {featuredReview.recommendedFor.length > 0 && (
                <ul class="compass-list">
                  {featuredReview.recommendedFor.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              )}

              <a class="hero-button hero-button-primary ui-action" href={featuredReview.href}>
                {featuredReview.title}を読む
              </a>
            </div>
          </section>
        )}
      </>
    ) : (
      <section class="empty-state" id="review-stream" aria-labelledby="empty-heading">
        <p class="section-label">Reviews</p>
        <h2 id="empty-heading">レビューを準備中です。</h2>
        <p>
          いまはまだ一覧がありません。公開されたら、ここが次に読みたくなる入口になります。
        </p>
      </section>
    )}

    <section class="afterword" aria-labelledby="afterword-heading">
      <div>
        <p class="section-label">After Reading</p>
        <h2 id="afterword-heading">言葉の次は、ココちゃんと景色へ。</h2>
      </div>
      <p>
        レビューで輪郭をつかんだあと、同じ一冊の空気をもう少し別の入口からたどりたいときはギャラリーへ。
      </p>
      <a class="hero-button hero-button-secondary ui-action" href={galleryUrl}>ギャラリーを見る</a>
    </section>
  </div>
</Layout>

<style>
  .reviews-story {
    display: grid;
    gap: clamp(2.2rem, 4vw, 3.8rem);
    padding: clamp(0.5rem, 1vw, 1rem) 0 clamp(2rem, 4vw, 3rem);
  }

  .hero,
  .featured-section,
  .stream-section,
  .compass-section,
  .empty-state,
  .afterword {
    position: relative;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(18rem, 0.75fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
    padding: clamp(2rem, 4.5vw, 3.8rem);
    border: 1px solid var(--color-border);
    border-radius: 2.3rem;
    background:
      radial-gradient(circle at top left, rgba(235, 224, 209, 0.6), transparent 38%),
      linear-gradient(145deg, rgba(252, 249, 244, 0.98), rgba(247, 244, 239, 0.92));
    box-shadow: var(--shadow-soft);
    overflow: hidden;
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: auto -6rem -6rem auto;
    width: 15rem;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(141, 91, 42, 0.16), transparent 68%);
    pointer-events: none;
  }

  .hero-copy,
  .hero-panel,
  .featured-body,
  .compass-card {
    position: relative;
    z-index: 1;
  }

  .hero-kicker,
  .section-label,
  .featured-eyebrow,
  .panel-label,
  .stream-theme,
  .reader-note-label {
    margin: 0;
    color: var(--color-accent);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero-copy {
    display: grid;
    align-content: center;
    gap: 0.85rem;
  }

  .hero-brand {
    margin: 0;
    font-size: clamp(1.35rem, 1.9vw, 1.65rem);
    color: color-mix(in srgb, var(--color-text) 92%, transparent);
  }

  .hero h1 {
    margin: 0;
    max-width: 10.5ch;
    font-size: clamp(2.6rem, 5vw, 4.6rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
  }

  .hero-lead,
  .hero-note,
  .section-copy,
  .featured-summary,
  .stream-summary,
  .compass-lead,
  .afterword p,
  .empty-state p {
    margin: 0;
    color: rgba(32, 22, 15, 0.82);
    line-height: 1.8;
  }

  .hero-lead,
  .hero-note {
    max-width: 31rem;
  }

  .hero-note span {
    font-weight: 700;
    color: #6b4020;
  }

  .hero-actions,
  .review-actions {
    display: flex;
    gap: 0.9rem;
    margin-top: 0.7rem;
  }

  .hero-button,
  .stream-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.85rem 1.35rem;
    border-radius: 999px;
    font-weight: 700;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      background-color 0.2s ease,
      border-color 0.2s ease;
  }

  .hero-button-primary {
    background: linear-gradient(180deg, rgba(50, 45, 41, 0.96), rgba(29, 27, 25, 0.96));
    color: #fffdf9;
    box-shadow: 0 18px 34px rgba(26, 22, 20, 0.16);
  }

  .hero-button-secondary,
  .stream-link {
    background: rgba(255, 255, 255, 0.78);
    color: color-mix(in srgb, var(--color-text) 86%, transparent);
    border: 1px solid var(--color-border);
    box-shadow: 0 10px 24px rgba(40, 30, 20, 0.05);
  }

  .hero-button:hover,
  .stream-link:hover,
  .featured-media:hover,
  .stream-media:hover {
    transform: translateY(-2px);
  }

  .hero-button:focus-visible,
  .stream-link:focus-visible,
  .featured-media:focus-visible,
  .stream-media:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 3px;
  }

  .hero-panel {
    align-self: stretch;
    display: grid;
    align-content: start;
    gap: 1rem;
    padding: clamp(1.15rem, 2vw, 1.65rem);
    border-radius: 1.8rem;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid var(--color-border);
  }

  .panel-stats {
    display: grid;
    gap: 0.9rem;
    margin: 0;
  }

  .panel-stats div {
    display: grid;
    gap: 0.35rem;
  }

  .panel-stats dt {
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .panel-stats dd {
    margin: 0;
    font-family: var(--font-headline);
    font-size: clamp(1.25rem, 2vw, 1.7rem);
    line-height: 1.2;
  }

  .panel-block {
    display: grid;
    gap: 0.75rem;
  }

  .panel-block p {
    margin: 0;
    font-weight: 700;
    color: #493221;
  }

  .theme-list,
  .cue-list,
  .tag-list,
  .reader-note ul,
  .compass-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .theme-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .theme-list li,
  .tag-list li {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.55rem 0.85rem;
    border-radius: 999px;
    background: rgba(141, 91, 42, 0.1);
    color: #6b4020;
    font-size: 0.88rem;
    font-weight: 700;
  }

  .cue-list,
  .reader-note ul,
  .compass-list {
    display: grid;
    gap: 0.7rem;
  }

  .cue-list li,
  .reader-note li,
  .compass-list li {
    position: relative;
    padding-left: 1.1rem;
    color: rgba(32, 22, 15, 0.82);
    line-height: 1.7;
  }

  .cue-list li::before,
  .reader-note li::before,
  .compass-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.7rem;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: rgba(141, 91, 42, 0.7);
  }

  .section-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(16rem, 28rem);
    gap: 1rem 2rem;
    align-items: end;
    margin-bottom: 1.35rem;
  }

  .section-copy {
    max-width: 26rem;
  }

  .section-header h2,
  .afterword h2,
  .empty-state h2 {
    margin: 0.3rem 0 0;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1.18;
  }

  .featured-review,
  .compass-card {
    display: grid;
    grid-template-columns: minmax(0, 0.86fr) minmax(0, 1.14fr);
    gap: clamp(1.5rem, 3vw, 2.8rem);
    padding: clamp(1.35rem, 3vw, 2.15rem);
    border-radius: 2rem;
    border: 1px solid var(--color-border);
    background:
      linear-gradient(160deg, rgba(255, 255, 255, 0.9), rgba(255, 250, 244, 0.96)),
      #fff;
    box-shadow: var(--shadow-soft);
  }

  .featured-media,
  .stream-media {
    display: block;
    overflow: hidden;
    border-radius: 1.6rem;
    background: linear-gradient(160deg, rgba(10, 74, 139, 0.08), rgba(122, 92, 23, 0.14));
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .featured-media {
    aspect-ratio: 4 / 5;
  }

  .featured-media img,
  .stream-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .media-fallback {
    display: grid;
    align-content: end;
    gap: 0.8rem;
    min-height: 100%;
    padding: 1.4rem;
