---
import Layout from "../layouts/Layout.astro";
import { getPublishedReviews } from '../utils/reviews';

const reviews = await getPublishedReviews();
const sortedReviews = [...reviews].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const base = import.meta.env.BASE_URL;
const baseWithSlash = base.endsWith('/') ? base : `${base}/`;

const isAbsoluteUrl = (value: string) =>
  /^(?:[a-z][a-z\d+.-]*:|\/\/)/i.test(value);

const withBase = (assetPath: string) => {
  if (!assetPath) return baseWithSlash;
  if (isAbsoluteUrl(assetPath)) return assetPath;
  if (assetPath.startsWith(baseWithSlash)) return assetPath;
  return `${baseWithSlash}${assetPath.replace(/^\/+/, '')}`;
};

const formatDate = (value: Date) =>
  new Intl.DateTimeFormat('ja-JP', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC',
  }).format(value);

const getExcerpt = (text: string, maxLength: number = 120): string => {
  const normalized = text.replace(/\s+/g, ' ').trim();
  if (!normalized) return '';
  if (normalized.length <= maxLength) return normalized;
  return `${normalized.slice(0, maxLength).trimEnd()}...`;
};
---

<Layout title="Reviews | 読書 with Coco">
  <section class="wrap" aria-labelledby="reviews-heading">
    <h1 id="reviews-heading">Reviews</h1>
    <p class="lead">読んだ本の感想と学びを記録しています。</p>

    {sortedReviews.length === 0 ? (
      <p class="empty">レビューがまだありません。最初のレビューを公開予定です。</p>
    ) : (
      <div class="grid">
        {sortedReviews.map((review) => {
          const href = `${baseWithSlash}reviews/${review.slug}/`;
          const summary = review.data.excerpt
            ? getExcerpt(review.data.excerpt, 100)
            : review.data.description
            ? getExcerpt(review.data.description, 100)
            : getExcerpt(review.body || '', 120);
          const thumbnail = review.data.cover ?? review.data.infographic;
          const supplementalTitle =
            review.data.bookTitle && review.data.bookTitle !== review.data.title
              ? review.data.bookTitle
              : null;

          return (
            <a href={href} class="card-link" aria-label={`${review.data.title}の詳細を見る`}>
              <article class="card">
                <div class="thumb">
                  {thumbnail ? (
                    <img
                      src={withBase(thumbnail)}
                      alt={`${review.data.title}のインフォグラフィック`}
                      loading="lazy"
                      decoding="async"
                      width="412"
                      height="512"
                    />
                  ) : (
                    <div class="thumb-fallback" aria-hidden="true">
                      <span class="thumb-fallback-label">Review</span>
                      <strong>{review.data.title}</strong>
                    </div>
                  )}
                </div>

                <div class="card-body">
                  {review.data.tags && review.data.tags.length > 0 && (
                    <ul class="tags" aria-label="タグ">
                      {review.data.tags.map((tag) => (
                        <li>{tag}</li>
                      ))}
                    </ul>
                  )}

                  <h2 class="title">{review.data.title}</h2>
                  {supplementalTitle && <p class="book-title">{supplementalTitle}</p>}

                  <div class="meta">
                    {review.data.author && <span>著者: {review.data.author}</span>}
                    <time class="date" datetime={review.data.date.toISOString()}>
                      {formatDate(review.data.date)}
                    </time>
                  </div>

                  {summary && <p class="summary">{summary}</p>}
                  <span class="read-more">詳細を読む</span>
                </div>
              </article>
            </a>
          );
        })}
      </div>
    )}
  </section>
</Layout>

<style>
  .wrap {
    max-width: 980px;
    margin: 0 auto;
    padding: 32px 16px;
  }

  h1 {
    margin: 0 0 8px;
  }

  .lead {
    opacity: 0.8;
    margin: 8px 0 24px;
  }

  .empty {
    opacity: 0.7;
    text-align: center;
    padding: 40px 20px;
    background: rgba(0, 0, 0, 0.03);
    border-radius: 14px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }

  .card-link {
    color: inherit;
    text-decoration: none;
  }

  .card {
    display: grid;
    height: 100%;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 14px;
    overflow: hidden;
    background: #fff;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .card-link:hover .card {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.12);
  }

  .card-link:focus-visible {
    outline: none;
  }

  .card-link:focus-visible .card {
    outline: 2px solid #0a5fcc;
    outline-offset: 2px;
  }

  .thumb {
    aspect-ratio: 16 / 10;
    background: linear-gradient(160deg, rgba(10, 74, 139, 0.08), rgba(122, 92, 23, 0.12));
  }

  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .thumb-fallback {
    display: grid;
    align-content: end;
    gap: 10px;
    height: 100%;
    padding: 20px;
    color: #17324d;
    background:
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.85), transparent 42%),
      linear-gradient(160deg, rgba(10, 74, 139, 0.1), rgba(122, 92, 23, 0.16));
  }

  .thumb-fallback-label {
    width: fit-content;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .thumb-fallback strong {
    font-size: 1.35rem;
    line-height: 1.35;
  }

  .card-body {
    display: grid;
    align-content: start;
    gap: 12px;
    padding: 18px 18px 20px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tags li {
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(10, 74, 139, 0.08);
    color: #0a4a8b;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .title {
    margin: 0;
    font-size: 1.2rem;
    line-height: 1.4;
  }

  .book-title {
    margin: -4px 0 0;
    font-size: 0.94rem;
    color: rgba(17, 17, 17, 0.68);
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    align-items: center;
    font-size: 0.88rem;
    color: rgba(17, 17, 17, 0.62);
  }

  .summary {
    margin: 0;
    opacity: 0.85;
    font-size: 0.95rem;
    line-height: 1.6;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .date {
    display: inline-flex;
  }

  .read-more {
    margin-top: auto;
    font-size: 0.9rem;
    font-weight: 600;
    color: #0a4a8b;
    opacity: 0.9;
  }

  .card-link:hover .read-more {
    opacity: 1;
  }

  @media (max-width: 600px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
