---
import type {
  GalleryBrowseChapter,
  GalleryBrowseModel,
  GalleryBrowseSort,
} from '../../utils/gallery';
import {
  GALLERY_ARCHIVE_DEFAULT_VIEW,
  GALLERY_BROWSE_DEFAULT_GENRE,
  GALLERY_BROWSE_DEFAULT_SORT,
  GALLERY_BROWSE_DEFAULT_VIEW,
  sortGalleryBrowseChapters,
  sortGalleryBrowseItems,
} from '../../utils/gallery';

type BrowseView = 'curated' | 'grid';

type Props = {
  browseModel: GalleryBrowseModel;
  defaultView?: BrowseView;
  defaultGenre?: string;
  defaultSort?: GalleryBrowseSort;
  enableSort?: boolean;
  testId?: string;
};

const {
  browseModel,
  defaultView = GALLERY_BROWSE_DEFAULT_VIEW,
  defaultGenre = GALLERY_BROWSE_DEFAULT_GENRE,
  defaultSort = GALLERY_BROWSE_DEFAULT_SORT,
  enableSort = false,
  testId = 'gallery-browse',
} = Astro.props as Props;

const getBrowseStatusText = (view: BrowseView, genre: string) => {
  if (view === 'curated') {
    return genre === GALLERY_BROWSE_DEFAULT_GENRE
      ? '章ごとのまとまりから景色をめくる'
      : `${genre}の景色を章の流れで眺める`;
  }

  return genre === GALLERY_BROWSE_DEFAULT_GENRE
    ? '作品を並べて比べながら探す'
    : `${genre}の景色を一覧で比べながら探す`;
};

const serverGenre = defaultGenre;
const serverItemsBase =
  serverGenre === GALLERY_BROWSE_DEFAULT_GENRE
    ? browseModel.items
    : browseModel.items.filter((item) => item.genre === serverGenre);
const serverItems = enableSort ? sortGalleryBrowseItems(serverItemsBase, defaultSort) : serverItemsBase;

const serverChaptersBase: GalleryBrowseChapter[] = browseModel.chapters
  .map((chapter) => ({
    ...chapter,
    items:
      serverGenre === GALLERY_BROWSE_DEFAULT_GENRE
        ? chapter.items
        : chapter.items.filter((item) => item.genre === serverGenre),
  }))
  .filter((chapter) => chapter.items.length > 0);
const serverChapters = enableSort ? sortGalleryBrowseChapters(serverChaptersBase, defaultSort) : serverChaptersBase;

const chapterSectionId = (chapterId: string) => `chapter-${chapterId}`;
const showCurated = defaultView === GALLERY_BROWSE_DEFAULT_VIEW;
const showGrid = defaultView === GALLERY_ARCHIVE_DEFAULT_VIEW;
---

<div
  class="gallery-browse-shell"
  data-gallery-browse-shell
  data-default-view={defaultView}
  data-default-genre={defaultGenre}
  data-default-sort={enableSort ? defaultSort : undefined}
  data-enable-sort={enableSort ? 'true' : 'false'}
  data-current-view={defaultView}
>
  <div class="browse-controls" data-gallery-controls hidden>
    <div class="browse-control-group">
      <p class="browse-control-label">見かた</p>
      <div class="view-switch" role="group" aria-label="見かた">
        <button
          type="button"
          class:list={['view-switch-button', defaultView === 'curated' && 'is-active']}
          data-view-button="curated"
          aria-pressed={defaultView === 'curated' ? 'true' : 'false'}
        >
          章で見る
        </button>
        <button
          type="button"
          class:list={['view-switch-button', defaultView === 'grid' && 'is-active']}
          data-view-button="grid"
          aria-pressed={defaultView === 'grid' ? 'true' : 'false'}
        >
          一覧で見る
        </button>
      </div>
    </div>

    <div class="browse-control-group browse-control-group-chips">
      <p class="browse-control-label">ジャンル</p>
      <div class="genre-chips" role="group" aria-label="ジャンルフィルタ">
        <button
          type="button"
          class:list={['genre-chip', defaultGenre === GALLERY_BROWSE_DEFAULT_GENRE && 'is-active']}
          data-genre-button="all"
          aria-pressed={defaultGenre === GALLERY_BROWSE_DEFAULT_GENRE ? 'true' : 'false'}
        >
          すべて
        </button>
        {browseModel.genres.map((genre) => (
          <button
            type="button"
            class:list={['genre-chip', defaultGenre === genre && 'is-active']}
            data-genre-button={genre}
            aria-pressed={defaultGenre === genre ? 'true' : 'false'}
          >
            {genre}
          </button>
        ))}
      </div>
    </div>

    {enableSort && (
      <div class="browse-control-group browse-control-group-sort">
        <label class="browse-control-label sort-label" for="gallery-browse-sort">並び順</label>
        <div class="sort-field">
          <select id="gallery-browse-sort" class="sort-select" data-sort-select aria-label="並び順">
            <option value="latest" selected={defaultSort === 'latest'}>最新順</option>
            <option value="title" selected={defaultSort === 'title'}>タイトル順</option>
          </select>
        </div>
      </div>
    )}

    <div class="browse-control-group browse-control-group-status">
      <p class="browse-control-label">いまの見かた</p>
      <p class="browse-status" data-browse-status aria-live="polite">
        {getBrowseStatusText(defaultView, defaultGenre)}
      </p>
    </div>
  </div>

  <div
    class="browse-panels"
    data-gallery-browse-root
    data-current-view={defaultView}
    data-current-genre={defaultGenre}
    data-current-sort={enableSort ? defaultSort : undefined}
    data-testid={testId}
  >
    <div class="browse-curated" data-browse-panel="curated" hidden={!showCurated}>
      {serverChapters.length ? (
        serverChapters.map((chapter) => (
          <section
            class={`chapter-room chapter-room-${chapter.mood}`}
            id={chapterSectionId(chapter.id)}
            aria-labelledby={`${chapterSectionId(chapter.id)}-title`}
            data-chapter-section={chapter.id}
          >
            <div class="chapter-intro">
              <p class="section-label">{chapter.eyebrow}</p>
              <h2 id={`${chapterSectionId(chapter.id)}-title`}>{chapter.title}</h2>
              <p>{chapter.description}</p>
              <p class="chapter-count">全{chapter.items.length}作品</p>
            </div>

            <div class="chapter-stage">
              {chapter.items[0] && (
                chapter.items[0].href ? (
                  <a
                    class="chapter-lead gallery-piece gallery-piece-lead"
                    href={chapter.items[0].href}
                    aria-label={`${chapter.items[0].title}の景色を見る`}
                    data-gallery-piece
                  >
                    <figure class="gallery-piece-figure gallery-piece-figure-lead">
                      <div class="chapter-lead-media gallery-piece-media" data-gallery-piece-media>
                        <img
                          src={chapter.items[0].imageSrc}
                          alt={`${chapter.items[0].title}の展示画像`}
                          loading="lazy"
                          decoding="async"
                          width="960"
                          height="720"
                        />
                      </div>
                      <figcaption class="chapter-lead-body gallery-piece-caption" data-gallery-piece-caption>
                        <div class="gallery-piece-copy">
                          <p class="piece-view-label">章の入口</p>
                          {chapter.items[0].genre && <p class="genre-label">{chapter.items[0].genre}</p>}
                          <h3>{chapter.items[0].title}</h3>
                          <p class="scene-summary">{chapter.items[0].summary}</p>
                        </div>
                        <div class="gallery-piece-meta">
                          {chapter.items[0].author && <p class="scene-author">著者: {chapter.items[0].author}</p>}
                          <span class="scene-action">景色をひらく</span>
                        </div>
                      </figcaption>
                    </figure>
                  </a>
                ) : (
                  <article class="chapter-lead gallery-piece gallery-piece-lead" data-gallery-piece>
                    <figure class="gallery-piece-figure gallery-piece-figure-lead">
                      <div class="chapter-lead-media gallery-piece-media" data-gallery-piece-media>
                        <img
                          src={chapter.items[0].imageSrc}
                          alt={`${chapter.items[0].title}の展示画像`}
                          loading="lazy"
                          decoding="async"
                          width="960"
                          height="720"
                        />
                      </div>
                      <figcaption class="chapter-lead-body gallery-piece-caption" data-gallery-piece-caption>
                        <div class="gallery-piece-copy">
                          <p class="piece-view-label">章の入口</p>
                          {chapter.items[0].genre && <p class="genre-label">{chapter.items[0].genre}</p>}
                          <h3>{chapter.items[0].title}</h3>
                          <p class="scene-summary">{chapter.items[0].summary}</p>
                        </div>
                        <div class="gallery-piece-meta">
                          {chapter.items[0].author && <p class="scene-author">著者: {chapter.items[0].author}</p>}
                          <span class="scene-status">展示中</span>
                        </div>
                      </figcaption>
                    </figure>
                  </article>
                )
              )}

              {chapter.items.length > 1 && (
                <div class="chapter-trail">
                  {chapter.items.slice(1).map((item) => (
                    item.href ? (
                      <a
                        class="trail-card gallery-piece gallery-piece-compact"
                        href={item.href}
                        aria-label={`${item.title}の景色を見る`}
                        data-curated-item
                        data-gallery-piece
                      >
                        <figure class="gallery-piece-figure gallery-piece-figure-compact">
                          <div class="trail-media gallery-piece-media" data-gallery-piece-media>
                            <img
                              src={item.imageSrc}
                              alt={`${item.title}の展示画像`}
                              loading="lazy"
                              decoding="async"
                              width="640"
                              height="480"
                            />
                          </div>
                          <figcaption class="trail-body gallery-piece-caption" data-gallery-piece-caption>
                            <div class="gallery-piece-copy">
                              {item.genre && <p class="genre-label">{item.genre}</p>}
                              <h3>{item.title}</h3>
                              <p class="scene-summary">{item.summary}</p>
                            </div>
                            <div class="gallery-piece-meta">
                              {item.author && <p class="scene-author">著者: {item.author}</p>}
                              <span class="scene-action">景色をひらく</span>
                            </div>
                          </figcaption>
                        </figure>
                      </a>
                    ) : (
                      <article
                        class="trail-card trail-card-static gallery-piece gallery-piece-compact"
                        data-curated-item
                        data-gallery-piece
                      >
                        <figure class="gallery-piece-figure gallery-piece-figure-compact">
                          <div class="trail-media gallery-piece-media" data-gallery-piece-media>
                            <img
                              src={item.imageSrc}
                              alt={`${item.title}の展示画像`}
                              loading="lazy"
                              decoding="async"
                              width="640"
                              height="480"
                            />
                          </div>
                          <figcaption class="trail-body gallery-piece-caption" data-gallery-piece-caption>
                            <div class="gallery-piece-copy">
                              {item.genre && <p class="genre-label">{item.genre}</p>}
                              <h3>{item.title}</h3>
                              <p class="scene-summary">{item.summary}</p>
                            </div>
                            <div class="gallery-piece-meta">
                              {item.author && <p class="scene-author">著者: {item.author}</p>}
                              <span class="scene-status">展示中</span>
                            </div>
                          </figcaption>
                        </figure>
                      </article>
                    )
                  ))}
                </div>
              )}
            </div>
          </section>
        ))
      ) : (
        <div class="browse-empty-state" data-browse-empty>
          <h3>この条件に合う景色はまだ並んでいません。</h3>
          <p>別のジャンルに切り替えると、読後の棚をもう少し広く見返せます。</p>
        </div>
      )}
    </div>

    <div class="browse-grid" data-browse-panel="grid" hidden={!showGrid}>
      <div class="grid-catalog" data-grid-catalog>
        {serverItems.length ? (
          serverItems.map((item) => (
            item.href ? (
              <a class="grid-card gallery-piece gallery-piece-grid" href={item.href} aria-label={`${item.title}の景色を見る`} data-grid-card data-gallery-piece>
                <figure class="gallery-piece-figure gallery-piece-figure-grid">
                  <div class="grid-card-media gallery-piece-media" data-gallery-piece-media>
                    <img
                      src={item.imageSrc}
                      alt={`${item.title}の展示画像`}
                      loading="lazy"
                      decoding="async"
                      width="720"
                      height="860"
                    />
                  </div>
                  <figcaption class="grid-card-body gallery-piece-caption" data-gallery-piece-caption>
                    <div class="gallery-piece-copy">
                      <div class="grid-card-meta">
                        {item.genre ? (
                          <span class="grid-badge">{item.genre}</span>
                        ) : (
                          <span class="grid-badge grid-badge-muted">展示</span>
                        )}
                      </div>
                      <h3>{item.title}</h3>
                    </div>
                    <div class="gallery-piece-meta">
                      {item.author && <p class="grid-card-author">{item.author}</p>}
                      <span class="scene-action">景色をひらく</span>
                    </div>
                  </figcaption>
                </figure>
              </a>
            ) : (
              <article class="grid-card grid-card-static gallery-piece gallery-piece-grid" data-grid-card data-gallery-piece>
                <figure class="gallery-piece-figure gallery-piece-figure-grid">
                  <div class="grid-card-media gallery-piece-media" data-gallery-piece-media>
                    <img
                      src={item.imageSrc}
                      alt={`${item.title}の展示画像`}
                      loading="lazy"
                      decoding="async"
                      width="720"
                      height="860"
                    />
                  </div>
                  <figcaption class="grid-card-body gallery-piece-caption" data-gallery-piece-caption>
                    <div class="gallery-piece-copy">
                      <div class="grid-card-meta">
                        {item.genre ? (
                          <span class="grid-badge">{item.genre}</span>
                        ) : (
                          <span class="grid-badge grid-badge-muted">展示</span>
                        )}
                      </div>
                      <h3>{item.title}</h3>
                    </div>
                    <div class="gallery-piece-meta">
                      {item.author && <p class="grid-card-author">{item.author}</p>}
                      <span class="scene-status">展示中</span>
                    </div>
                  </figcaption>
                </figure>
              </article>
            )
          ))
        ) : (
          <div class="browse-empty-state" data-browse-empty>
            <h3>この条件ではまだ比較できる景色がありません。</h3>
            <p>別のジャンルに切り替えると、目録のように並べて見返せます。</p>
          </div>
        )}
      </div>
    </div>
  </div>
</div>

<script
  is:inline
  define:vars={{
    browseData: browseModel,
    defaultView,
    defaultGenre,
    defaultSort,
    enableSort,
  }}
>
  const shell = document.querySelector('[data-gallery-browse-shell]');

  if (shell) {
    const controls = shell.querySelector('[data-gallery-controls]');
    const root = shell.querySelector('[data-gallery-browse-root]');
    const viewButtons = Array.from(shell.querySelectorAll('[data-view-button]'));
    const genreButtons = Array.from(shell.querySelectorAll('[data-genre-button]'));
    const sortSelect = shell.querySelector('[data-sort-select]');
    const statusNode = shell.querySelector('[data-browse-status]');
    const curatedPanel = root?.querySelector('[data-browse-panel="curated"]');
    const gridPanel = root?.querySelector('[data-browse-panel="grid"]');
    const gridCatalog = root?.querySelector('[data-grid-catalog]');

    if (root && curatedPanel && gridPanel && gridCatalog) {

    const validViews = new Set(['curated', 'grid']);
    const validGenres = new Set(['all', ...browseData.genres]);
    const validSorts = new Set(enableSort ? ['latest', 'title'] : []);
    const expandedChapters = new Set();
    let hasBuiltGrid = defaultView === 'grid';

    const chapterSectionId = (chapterId) => `chapter-${chapterId}`;
    const chapterTrailId = (chapterId) => `chapter-trail-${chapterId}`;
    const getBrowseStatusText = (view, genre) => {
      if (view === 'curated') {
        return genre === 'all'
          ? '章ごとのまとまりから景色をめくる'
          : `${genre}の景色を章の流れで眺める`;
      }

      return genre === 'all'
        ? '作品を並べて比べながら探す'
        : `${genre}の景色を一覧で比べながら探す`;
    };
    const escapeHtml = (value = '') =>
      value
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    const isCompactViewport = () => window.matchMedia('(max-width: 820px)').matches;
    const getVisibleItemCount = () => (isCompactViewport() ? 4 : 5);
    const getTimestamp = (item) => {
      const parsed = Date.parse(item.generatedAt ?? '');
      return Number.isNaN(parsed) ? 0 : parsed;
    };

    const sortItems = (items) => {
      if (!enableSort) {
        return items;
      }

      return [...items].sort((left, right) => {
        if (state.sort === 'title') {
          return left.title.localeCompare(right.title, 'ja');
        }

        const timeDiff = getTimestamp(right) - getTimestamp(left);
        if (timeDiff !== 0) return timeDiff;
        return left.title.localeCompare(right.title, 'ja');
      });
    };

    const getStateFromUrl = () => {
      const params = new URLSearchParams(window.location.search);
      const viewParam = params.get('view');
      const genreParam = params.get('genre');
      const sortParam = params.get('sort');

      return {
        view: validViews.has(viewParam) ? viewParam : defaultView,
        genre: validGenres.has(genreParam) ? genreParam : defaultGenre,
        sort: enableSort && validSorts.has(sortParam) ? sortParam : defaultSort,
      };
    };

    const state = getStateFromUrl();

    const filteredChapters = () =>
      browseData.chapters
        .map((chapter) => ({
          ...chapter,
          items: sortItems(
            chapter.items.filter((item) => state.genre === 'all' || item.genre === state.genre)
          ),
        }))
        .filter((chapter) => chapter.items.length > 0);

    const filteredItems = () =>
      sortItems(browseData.items.filter((item) => state.genre === 'all' || item.genre === state.genre));

    const renderLeadCard = (item) => {
      const genre = item.genre ? `<p class="genre-label">${escapeHtml(item.genre)}</p>` : '';
      const author = item.author ? `<p class="scene-author">著者: ${escapeHtml(item.author)}</p>` : '';
      const summary = `<p class="scene-summary">${escapeHtml(item.summary)}</p>`;
      const media = `
        <div class="chapter-lead-media gallery-piece-media" data-gallery-piece-media>
          <img
            src="${escapeHtml(item.imageSrc || item.image)}"
            alt="${escapeHtml(item.title)}の展示画像"
            loading="lazy"
            decoding="async"
            width="960"
            height="720"
          />
        </div>
      `;
      const body = `
        <figcaption class="chapter-lead-body gallery-piece-caption" data-gallery-piece-caption>
          <div class="gallery-piece-copy">
            <p class="piece-view-label">章の入口</p>
            ${genre}
            <h3>${escapeHtml(item.title)}</h3>
            ${summary}
          </div>
          <div class="gallery-piece-meta">
            ${author}
            <span class="${item.href ? 'scene-action' : 'scene-status'}">${item.href ? '景色をひらく' : '展示中'}</span>
          </div>
        </figcaption>
      `;
      const figure = `<figure class="gallery-piece-figure gallery-piece-figure-lead">${media}${body}</figure>`;

      return item.href
        ? `<a class="chapter-lead gallery-piece gallery-piece-lead" href="${escapeHtml(item.href)}" aria-label="${escapeHtml(item.title)}の景色を見る" data-gallery-piece>${figure}</a>`
        : `<article class="chapter-lead gallery-piece gallery-piece-lead" data-gallery-piece>${figure}</article>`;
    };

    const renderTrailCard = (item) => {
      const genre = item.genre ? `<p class="genre-label">${escapeHtml(item.genre)}</p>` : '';
      const author = item.author ? `<p class="scene-author">著者: ${escapeHtml(item.author)}</p>` : '';
      const content = `
        <figure class="gallery-piece-figure gallery-piece-figure-compact">
          <div class="trail-media gallery-piece-media" data-gallery-piece-media>
            <img
              src="${escapeHtml(item.imageSrc || item.image)}"
              alt="${escapeHtml(item.title)}の展示画像"
              loading="lazy"
              decoding="async"
              width="640"
              height="480"
            />
          </div>
          <figcaption class="trail-body gallery-piece-caption" data-gallery-piece-caption>
            <div class="gallery-piece-copy">
              ${genre}
              <h3>${escapeHtml(item.title)}</h3>
              <p class="scene-summary">${escapeHtml(item.summary)}</p>
            </div>
            <div class="gallery-piece-meta">
              ${author}
              <span class="${item.href ? 'scene-action' : 'scene-status'}">${item.href ? '景色をひらく' : '展示中'}</span>
            </div>
          </figcaption>
        </figure>
      `;

      return item.href
        ? `<a class="trail-card gallery-piece gallery-piece-compact" href="${escapeHtml(item.href)}" aria-label="${escapeHtml(item.title)}の景色を見る" data-curated-item data-gallery-piece>${content}</a>`
        : `<article class="trail-card trail-card-static gallery-piece gallery-piece-compact" data-curated-item data-gallery-piece>${content}</article>`;
    };

    const renderGridCard = (item) => {
      const genre = item.genre
        ? `<span class="grid-badge">${escapeHtml(item.genre)}</span>`
        : `<span class="grid-badge grid-badge-muted">展示</span>`;
      const author = item.author ? `<p class="grid-card-author">${escapeHtml(item.author)}</p>` : '';
      const content = `
        <figure class="gallery-piece-figure gallery-piece-figure-grid">
          <div class="grid-card-media gallery-piece-media" data-gallery-piece-media>
            <img
              src="${escapeHtml(item.imageSrc || item.image)}"
              alt="${escapeHtml(item.title)}の展示画像"
              loading="lazy"
              decoding="async"
              width="720"
              height="860"
            />
          </div>
          <figcaption class="grid-card-body gallery-piece-caption" data-gallery-piece-caption>
            <div class="gallery-piece-copy">
              <div class="grid-card-meta">${genre}</div>
              <h3>${escapeHtml(item.title)}</h3>
            </div>
            <div class="gallery-piece-meta">
              ${author}
              <span class="${item.href ? 'scene-action' : 'scene-status'}">${item.href ? '景色をひらく' : '展示中'}</span>
            </div>
          </figcaption>
        </figure>
      `;

      return item.href
        ? `<a class="grid-card gallery-piece gallery-piece-grid" href="${escapeHtml(item.href)}" aria-label="${escapeHtml(item.title)}の景色を見る" data-grid-card data-gallery-piece>${content}</a>`
        : `<article class="grid-card grid-card-static gallery-piece gallery-piece-grid" data-grid-card data-gallery-piece>${content}</article>`;
    };

    const renderCurated = () => {
      const chapters = filteredChapters();
      const visibleCount = getVisibleItemCount();

      if (!chapters.length) {
        curatedPanel.innerHTML = `
          <div class="browse-empty-state" data-browse-empty>
            <h3>この条件に合う景色はまだ並んでいません。</h3>
            <p>別のジャンルに切り替えると、読後の棚をもう少し広く見返せます。</p>
          </div>
        `;
        return;
      }

      curatedPanel.innerHTML = chapters
        .map((chapter) => {
          const lead = chapter.items[0];
          const trail = chapter.items.slice(1);
          const isExpanded = expandedChapters.has(chapter.id);
          const visibleTrail = isExpanded ? trail : trail.slice(0, Math.max(visibleCount - 1, 0));
          const visibleItems = 1 + visibleTrail.length;
          const remainingCount = Math.max(chapter.items.length - visibleItems, 0);
          const showToggle = chapter.items.length > visibleCount;

          return `
            <section
              class="chapter-room chapter-room-${escapeHtml(chapter.mood)}"
              id="${chapterSectionId(chapter.id)}"
              aria-labelledby="${chapterSectionId(chapter.id)}-title"
              data-chapter-section="${escapeHtml(chapter.id)}"
            >
              <div class="chapter-intro">
                <p class="section-label">${escapeHtml(chapter.eyebrow)}</p>
                <h2 id="${chapterSectionId(chapter.id)}-title">${escapeHtml(chapter.title)}</h2>
                <p>${escapeHtml(chapter.description)}</p>
                <p class="chapter-count">全${chapter.items.length}作品</p>
              </div>

              <div class="chapter-stage">
                ${renderLeadCard(lead)}
                ${
                  visibleTrail.length
                    ? `<div class="chapter-trail" id="${chapterTrailId(chapter.id)}">${visibleTrail.map(renderTrailCard).join('')}</div>`
                    : `<div class="chapter-trail" id="${chapterTrailId(chapter.id)}" hidden></div>`
                }
                ${
                  showToggle
                    ? `<button
                        type="button"
                        class="chapter-more"
                        data-chapter-more="${escapeHtml(chapter.id)}"
                        aria-expanded="${isExpanded ? 'true' : 'false'}"
                        aria-controls="${chapterTrailId(chapter.id)}"
                      >${isExpanded ? '閉じる' : `残り${remainingCount}作品を見る`}</button>`
                    : ''
                }
              </div>
            </section>
          `;
        })
        .join('');
    };

    const renderGrid = () => {
      const items = filteredItems();
      hasBuiltGrid = true;

      gridCatalog.innerHTML = items.length
        ? items.map(renderGridCard).join('')
        : `
          <div class="browse-empty-state" data-browse-empty>
            <h3>この条件ではまだ比較できる景色がありません。</h3>
            <p>別のジャンルに切り替えると、目録のように並べて見返せます。</p>
          </div>
        `;
    };

    const syncControls = () => {
      viewButtons.forEach((button) => {
        const isActive = button.dataset.viewButton === state.view;
        button.setAttribute('aria-pressed', String(isActive));
        button.classList.toggle('is-active', isActive);
      });

      genreButtons.forEach((button) => {
        const isActive = button.dataset.genreButton === state.genre;
        button.setAttribute('aria-pressed', String(isActive));
        button.classList.toggle('is-active', isActive);
      });

      if (sortSelect instanceof HTMLSelectElement && enableSort) {
        sortSelect.value = state.sort;
      }

      shell.dataset.currentView = state.view;
      root.dataset.currentView = state.view;
      root.dataset.currentGenre = state.genre;
      if (enableSort) {
        root.dataset.currentSort = state.sort;
      } else {
        delete root.dataset.currentSort;
      }

      curatedPanel.hidden = state.view !== 'curated';
      gridPanel.hidden = state.view !== 'grid';

      if (statusNode) {
        statusNode.textContent = getBrowseStatusText(state.view, state.genre);
      }
    };

    const syncUrl = (mode = 'replace') => {
      const url = new URL(window.location.href);

      if (state.view === defaultView) {
        url.searchParams.delete('view');
      } else {
        url.searchParams.set('view', state.view);
      }

      if (state.genre === defaultGenre) {
        url.searchParams.delete('genre');
      } else {
        url.searchParams.set('genre', state.genre);
      }

      if (enableSort) {
        if (state.sort === defaultSort) {
          url.searchParams.delete('sort');
        } else {
          url.searchParams.set('sort', state.sort);
        }
      } else {
        url.searchParams.delete('sort');
      }

      if (mode === 'push') {
        history.pushState({}, '', url);
        return;
      }

      if (mode === 'replace') {
        history.replaceState({}, '', url);
      }
    };

    const render = ({ historyMode = 'replace' } = {}) => {
      if (controls instanceof HTMLElement) {
        controls.hidden = false;
      }

      syncControls();
      renderCurated();

      if (state.view === 'grid' || hasBuiltGrid) {
        renderGrid();
      }

      if (historyMode !== 'skip') {
        syncUrl(historyMode);
      }
    };

    viewButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const nextView = button.dataset.viewButton;
        if (!validViews.has(nextView) || nextView === state.view) return;
        state.view = nextView;
        render({ historyMode: 'push' });
      });
    });

    genreButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const nextGenre = button.dataset.genreButton;
        if (!validGenres.has(nextGenre) || nextGenre === state.genre) return;
        state.genre = nextGenre;
        expandedChapters.clear();
        render({ historyMode: 'push' });
      });
    });

    if (sortSelect instanceof HTMLSelectElement && enableSort) {
      sortSelect.addEventListener('change', () => {
        const nextSort = sortSelect.value;
        if (!validSorts.has(nextSort) || nextSort === state.sort) return;
        state.sort = nextSort;
        expandedChapters.clear();
        render({ historyMode: 'push' });
      });
    }

    curatedPanel.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const button = target.closest('[data-chapter-more]');
      if (!(button instanceof HTMLButtonElement)) return;

      const chapterId = button.dataset.chapterMore;
      if (!chapterId) return;

      if (expandedChapters.has(chapterId)) {
        expandedChapters.delete(chapterId);
      } else {
        expandedChapters.add(chapterId);
      }

      renderCurated();
      syncControls();
    });

    const viewportQuery = window.matchMedia('(max-width: 820px)');
    const handleViewportChange = () => {
      if (state.view === 'curated') {
        renderCurated();
        syncControls();
      }
    };

    viewportQuery.addEventListener('change', handleViewportChange);

    window.addEventListener('popstate', () => {
      const nextState = getStateFromUrl();
      state.view = nextState.view;
      state.genre = nextState.genre;
      state.sort = nextState.sort;
      expandedChapters.clear();
      render({ historyMode: 'skip' });
    });

      render();
    }
  }
</script>

